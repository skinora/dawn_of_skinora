{%- comment -%}
  seo-breadcrumbs-jsonld.liquid
  Outputs BreadcrumbList JSON-LD for product, collection, article and page templates.
  Render from theme.liquid (after meta-tags). Outputs nothing when no context exists.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  <!-- [SCHEMA-DEBUG] BreadcrumbList (product) — snippets/seo-breadcrumbs-jsonld.liquid -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Hjem",
          "item": {{ request.origin | append: '/' | json }}
        }
        {%- if collection -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ request.origin | append: '/collections/' | append: collection.handle | json }}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }}
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }}
          }
        {%- endif -%}
      ]
    }
  </script>

