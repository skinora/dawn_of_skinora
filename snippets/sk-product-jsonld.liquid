{%- comment -%}
  sk-product-jsonld.liquid
  Custom Product JSON-LD with brand, sku, gtin and Offer(s).
  Replaces Shopify's {{ product | structured_data }} on product pages
  to add fields Google requires for full Product rich-result eligibility.
{%- endcomment -%}

{%- liquid
  assign pj_first = product.selected_or_first_available_variant
  assign pj_desc = product.description | strip_html | strip_newlines | strip | truncate: 5000

  # ── AI-lag: målte/bekreftede spesifikasjoner per modell (kun i kode, per product.handle) ──
  # Irradians = testverdi konvertert W/m² → mW/cm² (÷10), single output / masken alene på full effekt.
  # NB: legg til instrument + testdato i sk_irr_method før dette går til PROD (målt-påstand krever rapport).
  assign sk_specs = false
  assign sk_irr_method = 'Method: UPRtek MK350 spectroradiometer, January 2026. Report available on request.'
  case product.handle
    when 'skinora-radiance-face'
      assign sk_specs = true
      assign sk_wavelengths = '630 nm, 830 nm, 1072 nm'
      assign sk_irr_mw = '37'
      assign sk_irr_w = '372'
      assign sk_led = '114'
    when 'skinora-radiance-neck'
      assign sk_specs = true
      assign sk_wavelengths = '630 nm, 830 nm, 1072 nm'
      assign sk_irr_mw = '37'
      assign sk_irr_w = '370'
      assign sk_led = '118'
    when 'skinora-clear'
      assign sk_specs = true
      assign sk_wavelengths = '415 nm, 630 nm, 830 nm'
      assign sk_irr_mw = '47'
      assign sk_irr_w = '470'
      assign sk_led = '114'
  endcase
  assign sk_irr_desc = 'Measured at skin contact; equivalent to ' | append: sk_irr_w | append: ' W/m². ' | append: sk_irr_method
-%}
<!-- [SCHEMA-DEBUG] Product — snippets/sk-product-jsonld.liquid -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ request.origin | append: product.url | json }},
    "description": {{ pj_desc | json }},
    "image": [
      {%- for img in product.images -%}
        {{ img | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "brand": {
      "@type": "Brand",
      "name": "Skinora"
    }
    {%- if pj_first.sku != blank -%}
      ,"sku": {{ pj_first.sku | json }}
    {%- endif -%}
    {%- if pj_first.barcode != blank -%}
      ,"gtin": {{ pj_first.barcode | json }}
    {%- endif -%}
    {%- if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count > 0 -%}
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": {{ product.metafields.reviews.rating.value.rating | json }},
      "bestRating": {{ product.metafields.reviews.rating.value.scale_max | json }},
      "ratingCount": {{ product.metafields.reviews.rating_count | json }}
    }
    {%- endif -%}
    {%- if sk_specs -%}
    ,"hasCertification": {
      "@type": "Certification",
      "name": "FDA 510(k) Clearance",
      "certificationIdentification": "K233114",
      "issuedBy": { "@type": "Organization", "name": "U.S. Food and Drug Administration" }
    }
    ,"additionalProperty": [
      {
        "@type": "PropertyValue",
        "name": "Irradiance (at skin contact)",
        "value": {{ sk_irr_mw | json }},
        "unitText": "mW/cm²",
        "description": {{ sk_irr_desc | json }}
      },
      { "@type": "PropertyValue", "name": "Wavelengths", "value": {{ sk_wavelengths | json }} },
      { "@type": "PropertyValue", "name": "LED count", "value": {{ sk_led | json }} },
      { "@type": "PropertyValue", "name": "Power draw (typical / max)", "value": "5–6 W / 12 W" },
      { "@type": "PropertyValue", "name": "Battery", "value": "4000 mAh" },
      { "@type": "PropertyValue", "name": "Material", "value": "Medical-grade silicone" },
      { "@type": "PropertyValue", "name": "Timer", "value": "1–30 min" }
    ]
    {%- endif -%}
    ,"offers": [
      {%- for variant in product.variants -%}
        {
          "@type": "Offer",
          "url": {{ request.origin | append: variant.url | json }},
          "price": {{ variant.price | divided_by: 100.0 }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
          "itemCondition": "https://schema.org/NewCondition"
          {%- if variant.sku != blank -%}
            ,"sku": {{ variant.sku | json }}
          {%- endif -%}
          {%- if variant.barcode != blank -%}
            ,"gtin": {{ variant.barcode | json }}
          {%- endif -%}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>
