        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Kundebilde (valgfritt)"
        },
        {
          "type": "header",
          "content": "Før / etter-bilder (valgfritt)"
        },
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Før-bilde"
