{%- comment -%}
  sk-lp-reviews.liquid
  Customer reviews grid for landing pages. Each review is a block.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-reviews.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Social Proof / Reviews -->
<div class="sk-lp">
  <section class="lp-reviews" id="reviews">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.enable_trustpilot_embed and section.settings.trustpilot_business_unit_id != blank -%}
        <div class="lp-reviews__trustpilot">
          <div
            class="trustpilot-widget"
            data-locale="nb-NO"
            data-template-id="5419b6ffb0d04a076446a9af"
            data-businessunit-id="{{ section.settings.trustpilot_business_unit_id }}"
            data-style-height="24px"
            data-style-width="100%"
            data-theme="light"
          ></div>
          <script
            type="text/javascript"
            src="//widget.trustpilot.com/bootstrap/v5/tp.widget.bootstrap.min.js"
            async
          ></script>
        </div>
      {%- endif -%}

      {%- if section.settings.score != blank -%}
        <div class="lp-reviews__score-row">
          <span class="lp-reviews__score-stars">★★★★★</span>
          <span class="lp-reviews__score-value">{{ section.settings.rating_score | default: '4.8' }}</span>
          <span class="lp-reviews__score-count"
            >· basert på {{ section.settings.review_count | default: '102' }} anmeldelser</span
          >
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        {%- assign visible_count = section.settings.reviews_visible_count | default: 6 -%}
        {%- assign mobile_hero_count = 2 -%}
        {%- assign ranked_reviews = section.blocks | sort: 'settings.priority' -%}
        <div
          class="lp-reviews__grid"
          id="lp-reviews-grid-{{ section.id }}"
          data-reviews-grid
          data-visible-count="{{ visible_count }}"
          data-mobile-hero-count="{{ mobile_hero_count }}"
        >
          {%- for block in ranked_reviews -%}
            {%- assign is_secondary_mobile = false -%}
            {%- if forloop.index > mobile_hero_count -%}{%- assign is_secondary_mobile = true -%}{%- endif -%}
            {%- assign is_hidden_desktop = false -%}
            {%- if forloop.index0 >= visible_count -%}{%- assign is_hidden_desktop = true -%}{%- endif -%}
            <div
              class="lp-review-card{% if is_secondary_mobile %} lp-review-card--secondary{% endif %}"
              {% if is_secondary_mobile %}
                data-review-secondary="true"
              {% endif %}
              {% if is_hidden_desktop %}
                data-review-hidden="true" style="display:none;"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image -%}
                <div class="lp-review-card__avatar">
                  {{ block.settings.image | image_url: width: 96 | image_tag: loading: 'lazy', widths: '48,96' }}
                </div>
              {%- endif -%}
              <div class="lp-review-card__stars">★★★★★</div>
              {%- if block.settings.concern_tag != blank -%}
                <span class="lp-review-card__concern">
                  {{- block.settings.concern_tag -}}
                </span>
              {%- endif -%}
              <p class="lp-review-card__text">{{ block.settings.text }}</p>
              {%- if block.settings.before_image != blank and block.settings.after_image != blank -%}
                <div class="sk-review__ba" data-ba>
                  <figure class="sk-review__ba-item">
                    <button
                      type="button"
                      class="sk-review__ba-btn"
                      data-ba-open
                      data-ba-src="{{ block.settings.before_image | image_url: width: 1400 }}"
                      data-ba-alt="{{ block.settings.before_alt | escape }}"
                      aria-label="Forstørr før-bilde: {{ block.settings.before_alt | escape }}"
                    >
                      <img
                        src="{{ block.settings.before_image | image_url: width: 200 }}"
                        srcset="{{ block.settings.before_image | image_url: width: 200 }} 200w, {{ block.settings.before_image | image_url: width: 400 }} 400w"
                        sizes="(min-width: 768px) 120px, 30vw"
                        width="200"
                        height="250"
                        alt="{{ block.settings.before_alt | escape }}"
                        loading="lazy"
                        decoding="async"
                      >
                      <span class="sk-review__ba-label">{{ block.settings.before_label | default: 'Før' }}</span>
                    </button>
                  </figure>
                  <figure class="sk-review__ba-item">
                    <button
                      type="button"
                      class="sk-review__ba-btn"
                      data-ba-open
                      data-ba-src="{{ block.settings.after_image | image_url: width: 1400 }}"
                      data-ba-alt="{{ block.settings.after_alt | escape }}"
                      aria-label="Forstørr etter-bilde: {{ block.settings.after_alt | escape }}"
                    >
                      <img
                        src="{{ block.settings.after_image | image_url: width: 200 }}"
                        srcset="{{ block.settings.after_image | image_url: width: 200 }} 200w, {{ block.settings.after_image | image_url: width: 400 }} 400w"
                        sizes="(min-width: 768px) 120px, 30vw"
                        width="200"
                        height="250"
                        alt="{{ block.settings.after_alt | escape }}"
                        loading="lazy"
                        decoding="async"
                      >
                      <span class="sk-review__ba-label">{{ block.settings.after_label | default: 'Etter' }}</span>
                    </button>
                  </figure>
                </div>
              {%- endif -%}
              <p class="lp-review-card__author">{{ block.settings.author }}</p>
              <p class="lp-review-card__verified">Verifisert kjøper ✓</p>
              {%- if block.settings.usage_tag != blank -%}
                <span class="lp-review-card__usage">
                  {{- block.settings.usage_tag -}}
                </span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%}
          Toggle button: shown on mobile if there are more than mobile_hero_count reviews,
          shown on desktop only when there are more than visible_count reviews.
          CSS handles the responsive visibility.
        {%- endcomment -%}
        {%- if section.blocks.size > mobile_hero_count -%}
          {%- assign collapsed_label = 'Les alle anmeldelser →' -%}
          {%- assign expanded_label = section.settings.show_less_text | default: 'Vis færre anmeldelser ↑' -%}
          <div class="lp-reviews__more">
            <button
              type="button"
              class="lp-reviews__more-btn lp-reviews__expand btn btn--ghost"
              data-reviews-toggle
              data-show-more-text="{{ collapsed_label | escape }}"
              data-show-less-text="{{ expanded_label | escape }}"
              aria-expanded="false"
              aria-controls="lp-reviews-grid-{{ section.id }}"
            >
              <span class="lp-reviews__expand-label" data-label-collapsed>{{ collapsed_label }}</span>
              <span class="lp-reviews__expand-label" data-label-expanded hidden>{{ expanded_label }}</span>
            </button>
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.before_after_disclaimer != blank -%}
        <div class="lp-reviews__disclaimer">
          {{ section.settings.before_after_disclaimer }}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

<script>
  (function () {
    var sectionEl = document.getElementById('reviews');
    if (!sectionEl) return;
    var btn = sectionEl.querySelector('[data-reviews-toggle]');
    var grid = sectionEl.querySelector('[data-reviews-grid]');
    if (!btn || !grid) return;

    var labelCollapsed = btn.querySelector('[data-label-collapsed]');
    var labelExpanded = btn.querySelector('[data-label-expanded]');

    function setExpanded(open) {
      sectionEl.classList.toggle('is-expanded', open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');

      // Reveal/hide desktop-overflow cards (cards beyond visible_count) on all viewports.
      var hidden = grid.querySelectorAll('[data-review-hidden]');
      hidden.forEach(function (el) {
        el.style.display = open ? '' : 'none';
      });

      // Mobile-secondary cards (cards 3+) are CSS-controlled via .is-expanded; nothing to toggle in JS.

      if (labelCollapsed && labelExpanded) {
        labelCollapsed.hidden = open;
        labelExpanded.hidden = !open;
      } else {
        // Fallback for pre-update markup
        btn.textContent = open ? btn.dataset.showLessText : btn.dataset.showMoreText;
      }

      if (open) {
        var firstSecondary = grid.querySelector('[data-review-secondary], [data-review-hidden]');
        if (firstSecondary) {
          firstSecondary.setAttribute('tabindex', '-1');
          try {
            firstSecondary.focus({ preventScroll: false });
          } catch (_) {
            firstSecondary.focus();
          }
        }
      }
    }

    btn.addEventListener('click', function () {
      var isOpen = sectionEl.classList.contains('is-expanded');
      setExpanded(!isOpen);
    });
  })();
</script>

<!-- SECTION: Mid-Page CTA -->
{%- assign reviews_handle = section.settings.product_url | split: '/products/' | last | split: '?' | first -%}
{%- assign reviews_product = all_products[reviews_handle] -%}
{%- assign reviews_variant = reviews_product.selected_or_first_available_variant -%}
<div class="lp-midpage-cta">
  <form
    action="{{ routes.cart_add_url }}"
    method="post"
    enctype="multipart/form-data"
    class="lp-cta-form"
    data-cta="midpage"
  >
    <input type="hidden" name="id" value="{{ reviews_variant.id }}">
    <input type="hidden" name="quantity" value="1">
    <button
      type="submit"
      class="lp-btn"
      data-product-handle="{{ reviews_handle }}"
      aria-label="{{ section.settings.midpage_cta_text | default: 'Bestill nå' }}"
    >
      {{- section.settings.midpage_cta_text | default: 'Bestill nå' -}}
    </button>
  </form>
  <p class="lp-midpage-cta__guarantees">
    ✔ 60 dagers fornøydgaranti &nbsp;·&nbsp; ✔ Gratis frakt &nbsp;·&nbsp; ✔
    {{ section.settings.midpage_klarna_text | default: 'Fra 130 kr/mnd med Klarna' }}
  </p>
</div>

<div
  class="sk-ba-lightbox"
  id="sk-ba-lightbox-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Forstørret bilde"
  aria-hidden="true"
  data-ba-lightbox
>
  <button type="button" class="sk-ba-lightbox__close" data-ba-close aria-label="Lukk forstørret bilde">×</button>
  {%- comment -%} theme-check-disable ImgWidthAndHeight, AssetUrlFilters {%- endcomment -%}
  <img class="sk-ba-lightbox__img" src="" alt="" width="900" height="1125" data-ba-lightbox-img>
  {%- comment -%} theme-check-enable ImgWidthAndHeight, AssetUrlFilters {%- endcomment -%}
</div>

<script>
  (function initSkBaLightbox() {
    var lb = document.getElementById('sk-ba-lightbox-{{ section.id }}');
    if (!lb || lb.dataset.skBaInit === '1') return;
    lb.dataset.skBaInit = '1';
    var img = lb.querySelector('[data-ba-lightbox-img]');
    var closeBtn = lb.querySelector('[data-ba-close]');
    var lastFocus = null;

    function open(src, alt) {
      lastFocus = document.activeElement;
      img.src = src;
      img.alt = alt || '';
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }
    function close() {
      lb.setAttribute('aria-hidden', 'true');
      img.src = '';
      img.alt = '';
      document.body.style.overflow = '';
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    }

    document.addEventListener('click', function (e) {
      var t = e.target.closest('[data-ba-open]');
      if (!t) return;
      e.preventDefault();
      open(t.getAttribute('data-ba-src'), t.getAttribute('data-ba-alt'));
    });
    closeBtn.addEventListener('click', close);
    lb.addEventListener('click', function (e) {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && lb.getAttribute('aria-hidden') === 'false') close();
    });
  })();
</script>

{% schema %}
{
  "name": "LP Reviews",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Det norske kvinner sier"
    },
    {
      "type": "text",
      "id": "score",
      "label": "Anmeldelsesscore (tekst)",
      "default": "4.8 av 5 – basert på 102 anmeldelser"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Score (tall)",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Antall anmeldelser (tall)",
      "default": "102"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "range",
      "id": "reviews_visible_count",
      "label": "Antall anmeldelser synlige som standard",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "show_more_text",
      "label": "\"Vis flere\" knappetekst",
      "default": "Vis flere anmeldelser"
    },
    {
      "type": "text",
      "id": "show_less_text",
      "label": "\"Vis færre\" knappetekst",
      "default": "Vis færre"
    },
    {
      "type": "richtext",
      "id": "before_after_disclaimer",
      "label": "Disclaimer for før/etter-bilder",
      "default": "<p>Bilder fra ekte verifiserte kunder, brukt med tillatelse. Ikke retusjert. Resultater kan variere fra person til person og avhenger av jevn bruk over 6–8 uker.</p>"
    },
    {
      "type": "header",
      "content": "Trustpilot embed"
    },
    {
      "type": "checkbox",
      "id": "enable_trustpilot_embed",
      "label": "Vis Trustpilot-widget over anmeldelsene",
      "default": false
    },
    {
      "type": "text",
      "id": "trustpilot_business_unit_id",
      "label": "Trustpilot Business Unit ID"
    },
    {
      "type": "header",
      "content": "Mid-page CTA"
    },
    {
      "type": "text",
      "id": "product_url",
      "label": "Produkt-URL (f.eks. /products/skinora-clear)",
      "default": "/products/skinora-clear"
    },
    {
      "type": "text",
      "id": "midpage_cta_text",
      "label": "CTA-knapptekst",
      "default": "Bestill nå"
    },
    {
      "type": "text",
      "id": "midpage_klarna_text",
      "label": "Klarna-tekst",
      "default": "Fra 130 kr/mnd med Klarna"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Anmeldelse",
      "settings": [
        {
          "type": "range",
          "id": "priority",
          "label": "Vis-prioritet (1 = vises først på mobil)",
          "info": "De to anmeldelsene med lavest tall vises som hero-par på mobil.",
          "min": 1,
          "max": 20,
          "step": 1,
          "default": 10
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Anmeldelsestekst"
        },
        {
          "type": "text",
