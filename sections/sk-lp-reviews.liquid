{%- comment -%}
  sk-lp-reviews.liquid
  Customer reviews grid for landing pages. Each review is a block.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Social Proof / Reviews -->
<div class="sk-lp">
  <section class="lp-reviews">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.score != blank -%}
        <div class="lp-reviews__score-row">
          <span class="lp-reviews__score-stars">★★★★★</span>
          <span class="lp-reviews__score-value">{{ section.settings.rating_score | default: '4.8' }}</span>
          <span class="lp-reviews__score-count"
            >· basert på {{ section.settings.review_count | default: '102' }} anmeldelser</span
          >
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="lp-reviews__grid">
          {%- for block in section.blocks -%}
            <div class="lp-review-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image -%}
                <div class="lp-review-card__avatar">
                  {{ block.settings.image | image_url: width: 96 | image_tag: loading: 'lazy', widths: '48,96' }}
                </div>
              {%- endif -%}
              <div class="lp-review-card__stars">★★★★★</div>
              {%- if block.settings.concern_tag != blank -%}
                <span class="lp-review-card__concern">
                  {{- block.settings.concern_tag -}}
                </span>
              {%- endif -%}
              <p class="lp-review-card__text">{{ block.settings.text }}</p>
              <p class="lp-review-card__author">{{ block.settings.author }}</p>
              <p class="lp-review-card__verified">Verifisert kjøper ✓</p>
              {%- if block.settings.usage_tag != blank -%}
                <span class="lp-review-card__usage">
                  {{- block.settings.usage_tag -}}
                </span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

<!-- SECTION: Mid-Page CTA -->
<div class="lp-midpage-cta" style="text-align:center;padding:32px 20px 8px;">
  <a href="#kjop" class="lp-btn lp-btn--primary" style="display:inline-block;">
    {{- section.settings.midpage_cta_text | default: 'Bestill nå' -}}
  </a>
  <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:12px;color:#5f5f5f;margin:10px 0 0;">
    ✔ 60 dagers fornøydgaranti &nbsp;·&nbsp; ✔ Gratis frakt &nbsp;·&nbsp; ✔
    {{ section.settings.midpage_klarna_text | default: 'Fra 130 kr/mnd med Klarna' }}
  </p>
</div>

{% schema %}
{
  "name": "LP Reviews",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Det norske kvinner sier"
    },
    {
      "type": "text",
      "id": "score",
      "label": "Anmeldelsesscore (tekst)",
      "default": "4.8 av 5 – basert på 102 anmeldelser"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Score (tall)",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Antall anmeldelser (tall)",
      "default": "102"
    },
    {
      "type": "header",
      "content": "Mid-page CTA"
    },
    {
      "type": "text",
      "id": "midpage_cta_text",
      "label": "CTA-knapptekst",
      "default": "Bestill nå"
    },
    {
      "type": "text",
      "id": "midpage_klarna_text",
      "label": "Klarna-tekst",
      "default": "Fra 130 kr/mnd med Klarna"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Anmeldelse",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Anmeldelsestekst"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Forfatter",
          "info": "F.eks. «Wenche S., 52, Oslo»"
        },
        {
          "type": "text",
          "id": "concern_tag",
          "label": "Hudbekymring-tagg",
          "info": "F.eks. «Pigmentflekker · Moden hud»"
        },
        {
          "type": "text",
          "id": "usage_tag",
          "label": "Bruksfrekvens-tagg",
          "info": "F.eks. «Bruker: 10 min, 4x/uke»"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Kundebilde (valgfritt)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "Etter 6 uker merker jeg virkelig forskjell på hudtonen. Huden ser friskere ut og pigmentflekkene er blitt mindre synlige. Veldig fornøyd!",
            "author": "Wenche S., 52, Oslo"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Bruker den foran TV hver kveld. Enkelt, behagelig og huden kjennes mykere. Gir ikke opp denne rutinen!",
            "author": "Kari M., 47, Stavanger"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Var skeptisk, men etter 4 uker ser jeg tydelig mer glød. Huden føles tettere og fine linjene er blitt mindre synlige.",
            "author": "Tone H., 61, Trondheim"
          }
        }
      ]
    }
  ]
}
{% endschema %}
