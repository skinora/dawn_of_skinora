      "default": "Bestill nå"
    },
    {
      "type": "text",
      "id": "midpage_klarna_text",
      "label": "Klarna-tekst",
      "default": "Fra 130 kr/mnd med Klarna"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Anmeldelse",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Anmeldelsestekst"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Forfatter",
          "info": "F.eks. «Wenche S., 52, Oslo»"
        },
        {
          "type": "text",
          "id": "concern_tag",
          "label": "Hudbekymring-tagg",
          "info": "F.eks. «Pigmentflekker · Moden hud»"
        },
        {
          "type": "text",
          "id": "usage_tag",
          "label": "Bruksfrekvens-tagg",
          "info": "F.eks. «Bruker: 10 min, 4x/uke»"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Kundebilde (valgfritt)"
        },
        {
          "type": "header",
          "content": "Før / etter-bilder (valgfritt)"
        },
        {
          "type": "image_picker",
