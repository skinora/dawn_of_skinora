{%- comment -%}
  sk-lp-problem.liquid
  "Pain-point" section with heading, intro and a dynamic checklist.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- BLOCK: Premium Proof (relocated from Hero) -->
{%- assign proof_blocks = section.blocks | where: 'type', 'proof' -%}
{%- if proof_blocks.size > 0 -%}
  <div class="sk-lp">
    <ul class="lp-proof-list" style="max-width:480px;margin:0 auto 0;">
      {%- for block in proof_blocks -%}
        <li class="lp-proof-list__item" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}

<!-- SECTION: Pain Agitation -->
<div class="sk-lp">
  <section class="lp-problem">
    <div class="lp-container--narrow">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.intro != blank -%}
        <p class="lp-section-intro">{{ section.settings.intro }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="lp-problem__list-wrap">
          <ul class="lp-problem__list">
            {%- for block in section.blocks -%}
              <li class="lp-problem__item" {{ block.shopify_attributes }}>
                <span class="lp-problem__check">✓</span>
                {{ block.settings.text }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

<!-- SECTION: Dokumentasjon & trygg bruk -->
<section class="lp-section lp-doc-section" style="padding:40px 20px;background:#f8f8f8;">
  <div style="max-width:680px;margin:0 auto;">
    <h2 style="font-family:freight-text-pro,'Playfair Display',Georgia,serif;font-size:22px;font-weight:500;color:#30273e;margin:0 0 8px;text-align:center;">
      LED-lys og dokumentasjon
    </h2>
    <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:14px;font-weight:300;color:#5f5f5f;line-height:1.7;text-align:center;margin:0 0 24px;">
      LED-lysbehandling er en veletablert metode i profesjonell hudpleie. Her er hva du bør vite om teknologien – og om
      trygg bruk hjemme.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div style="background:#fff;padding:16px 18px;border-radius:6px;">
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:600;color:#30273e;margin:0 0 6px;">
          Hva er dokumentert?
        </p>
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:300;color:#5f5f5f;line-height:1.6;margin:0;">
          LED-bølgelengder i rødt og nær-infrarødt spekter er mye brukt i hudpleie og er grundig studert som
          behandlingsmodalitet.
          <a href="/pages/kliniske-studier" style="color:#30273e;font-weight:600;">Se dokumentasjon →</a>
        </p>
      </div>
      <div style="background:#fff;padding:16px 18px;border-radius:6px;">
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:600;color:#30273e;margin:0 0 6px;">
          Resultater varierer
        </p>
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:300;color:#5f5f5f;line-height:1.6;margin:0;">
          Effekten avhenger av hudtype, alder og bruksmønster. Jevn bruk 3–5 ganger i uken gir best forutsetning for
          synlige resultater over tid.
        </p>
      </div>
      <div style="background:#fff;padding:16px 18px;border-radius:6px;">
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:600;color:#30273e;margin:0 0 6px;">
          Trygt for de fleste
        </p>
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:300;color:#5f5f5f;line-height:1.6;margin:0;">
          LED-terapi er ikke-invasiv og inneholder ingen UV-stråler. Masken leveres med øyebeskyttelse og norsk
          bruksanvisning.
        </p>
      </div>
      <div style="background:#fff;padding:16px 18px;border-radius:6px;">
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:600;color:#30273e;margin:0 0 6px;">
          Start forsiktig hvis…
        </p>
        <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-weight:300;color:#5f5f5f;line-height:1.6;margin:0;">
          Du bruker lysømfintlige medisiner, har epilepsi, nylig har gjort laser/peeling, eller er gravid. Les alltid
          bruksanvisningen.
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LP Problem",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Kjenner du igjen dette?"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "Med årene endres huden – det er helt naturlig. Men du trenger ikke bare akseptere det."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Problem-punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Huden ser mer sliten ut enn du føler deg"
        }
      ]
    },
    {
      "type": "proof",
      "name": "Proof-punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Klinisk dokumentert LED-teknologi"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Problem",
      "blocks": [
        { "type": "item", "settings": { "text": "Huden ser mer sliten ut enn du føler deg" } },
        { "type": "item", "settings": { "text": "Mindre naturlig glød og mer gusten hudtone" } },
        { "type": "item", "settings": { "text": "Ujevn hudtone eller pigmentflekker" } },
        { "type": "item", "settings": { "text": "Tørrhetslinjer og endret hudtekstur" } },
        { "type": "item", "settings": { "text": "Du vil gjøre noe aktivt – uten å oppsøke klinikk" } }
      ]
    }
  ]
}
{% endschema %}
