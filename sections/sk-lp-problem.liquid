{%- comment -%}
  sk-lp-problem.liquid
  "Pain-point" section with heading, intro and a dynamic checklist.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- BLOCK: Premium Proof (relocated from Hero) -->
{%- assign proof_blocks = section.blocks | where: 'type', 'proof' -%}
{%- if proof_blocks.size > 0 -%}
  <div class="sk-lp">
    <ul class="lp-proof-list" style="max-width:480px;margin:0 auto 24px;">
      {%- for block in proof_blocks -%}
        <li class="lp-proof-list__item" {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}

<!-- SECTION: Pain Agitation -->
<div class="sk-lp">
  <section class="lp-problem">
    <div class="lp-problem__grid {% if section.settings.image == blank %}lp-problem__grid--single{% endif %}">
      <div class="lp-problem__text-col">
        <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.intro != blank -%}
          <p class="lp-section-intro">{{ section.settings.intro }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="lp-problem__list-wrap">
            <ul class="lp-problem__list">
              {%- for block in section.blocks -%}
                <li class="lp-problem__item" {{ block.shopify_attributes }}>
                  <span class="lp-problem__check">✓</span>
                  {{ block.settings.text }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.image -%}
        <div class="lp-problem__image-col">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
            decoding="async"
            class="lp-problem__image"
          >
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

<style>
  #shopify-section-{{ section.id }} .lp-problem__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #shopify-section-{{ section.id }} .lp-problem__grid--single {
    grid-template-columns: 1fr;
    max-width: 680px;
  }
  #shopify-section-{{ section.id }} .lp-problem__image-col {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }
  #shopify-section-{{ section.id }} .lp-problem__image {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 600px;
    object-fit: cover;
    border-radius: 8px;
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .lp-problem__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    #shopify-section-{{ section.id }} .lp-problem__image-col {
      order: -1;
    }
    #shopify-section-{{ section.id }} .lp-problem__image {
      max-height: 400px;
    }
  }
</style>

{% schema %}
{
  "name": "LP Problem",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Kjenner du igjen dette?"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "Med årene endres huden – det er helt naturlig. Men du trenger ikke bare akseptere det."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bilde (valgfritt)"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Problem-punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Huden ser mer sliten ut enn du føler deg"
        }
      ]
    },
    {
      "type": "proof",
      "name": "Proof-punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Klinisk dokumentert LED-teknologi"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Problem",
      "blocks": [
        { "type": "item", "settings": { "text": "Huden ser mer sliten ut enn du føler deg" } },
        { "type": "item", "settings": { "text": "Mindre naturlig glød og mer gusten hudtone" } },
        { "type": "item", "settings": { "text": "Ujevn hudtone eller pigmentflekker" } },
        { "type": "item", "settings": { "text": "Tørrhetslinjer og endret hudtekstur" } },
        { "type": "item", "settings": { "text": "Du vil gjøre noe aktivt – uten å oppsøke klinikk" } }
      ]
    }
  ]
}
{% endschema %}
