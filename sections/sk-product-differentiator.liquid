{% comment %}
  SECTION: Skinora – Product Differentiator ("spec-ledger")

  Editorial spec-statement. NO cards, NO divider lines. Whitespace separates.
  Dramatic scale: the highlighted row is a large hero stat (big numeral +
  small italic-accent unit); the rest is a quiet register. Optional image is
  rendered NON-boxy (soft radial fade + accent glow), never a hard rectangle.

  Per-product content via metaobject:
    product.metafields.custom.differentiator_reference -> product_differentiator
      eyebrow / heading / subheading / note
      image (optional)                  <- falls back to section image setting
      rows (list -> differentiator_row)
        figure / label / standard_value (optional) / highlight (boolean)

  Accent colour + image are theme-editor settings (brand stays monochrome by
  default; merchant can dial a warm/IR accent).
{% endcomment %}

<style>
  .sk-diff--{{ section.id }} {
    background: transparent;
    padding: clamp(3.5rem, 5vw, 6rem) 0;
  }

  .sk-diff--{{ section.id }} .sk-diff__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding-inline: var(--sk-page-gutter);
    display: flex;
    flex-direction: column;
    gap: clamp(2.4rem, 3.5vw, 3.6rem);
  }

  /* With image: content + media side by side */
  .sk-diff--{{ section.id }} .sk-diff__inner--media {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
    gap: clamp(2rem, 4.5vw, 4.5rem);
    align-items: center;
  }

  .sk-diff--{{ section.id }} .sk-diff__body {
    display: flex;
    flex-direction: column;
    gap: clamp(2.4rem, 3.5vw, 3.6rem);
  }

  .sk-diff--{{ section.id }} .sk-diff__header {
    max-width: 56ch;
    display: flex;
    flex-direction: column;
    gap: var(--sk-section-header-gap);
  }

  .sk-diff--{{ section.id }} .sk-diff__eyebrow {
    margin: 0;
    font-family: var(--font-body-family);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 1.3rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.5);
  }

  .sk-diff--{{ section.id }} .sk-diff__title {
    margin: 0;
    font-size: var(--section-heading-h2);
    line-height: var(--section-heading-h2-line);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: rgb(var(--sk-color-heading-text));
  }

  .sk-diff--{{ section.id }} .sk-diff__lead {
    margin: 0;
    max-width: 52ch;
    font-size: clamp(1.6rem, 1.2vw, 2rem);
    line-height: 1.6;
    color: rgba(var(--sk-color-body-text), 0.8);
  }

  .sk-diff--{{ section.id }} .sk-diff__rows {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 2.8vw, 2.8rem);
  }

  /* ── HERO STAT (highlight) ── */
  .sk-diff--{{ section.id }} .sk-diff__hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: clamp(1.8rem, 3.5vw, 3.4rem);
    align-items: end;
    padding-bottom: clamp(0.6rem, 1.2vw, 1.4rem);
  }

  .sk-diff--{{ section.id }} .sk-diff__hero-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    font-family: var(--font-heading-family);
    color: rgb(var(--color-brand-rgb));
    line-height: 0.9;
  }

  .sk-diff--{{ section.id }} .sk-diff__hero-num {
    font-size: clamp(4.4rem, 8vw, 7rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    font-feature-settings: "tnum" 1;
  }

  /* Font accent: italic + accent colour on the unit */
  .sk-diff--{{ section.id }} .sk-diff__hero-unit {
    margin-top: 0.4rem;
    font-size: clamp(1.6rem, 1.8vw, 2.1rem);
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.01em;
    color: var(--sk-diff-accent, var(--color-brand));
  }

  .sk-diff--{{ section.id }} .sk-diff__hero-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 0.6rem;
  }

  .sk-diff--{{ section.id }} .sk-diff__hero-label {
    margin: 0;
    max-width: 38ch;
    font-size: clamp(1.8rem, 1.5vw, 2.3rem);
    line-height: 1.4;
    font-weight: 500;
    color: rgb(var(--color-foreground));
  }

  /* ── REGISTER (quiet supporting specs) ── */
  .sk-diff--{{ section.id }} .sk-diff__row {
    display: grid;
    grid-template-columns: clamp(92px, 20%, 150px) minmax(0, 1fr);
    column-gap: clamp(1.4rem, 2.5vw, 2.2rem);
    align-items: baseline;
  }

  .sk-diff--{{ section.id }} .sk-diff__figure {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: clamp(1.7rem, 1.4vw, 2.1rem);
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: rgb(var(--color-brand-rgb));
    text-wrap: balance;
  }

  .sk-diff--{{ section.id }} .sk-diff__content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sk-diff--{{ section.id }} .sk-diff__label {
    margin: 0;
    max-width: 62ch;
    font-size: clamp(1.5rem, 1vw, 1.7rem);
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.82);
  }

  .sk-diff--{{ section.id }} .sk-diff__standard {
    margin: 0;
    font-size: clamp(1.3rem, 0.9vw, 1.45rem);
    line-height: 1.5;
    letter-spacing: 0.01em;
    color: rgba(var(--color-foreground), 0.46);
  }

  .sk-diff--{{ section.id }} .sk-diff__note {
    margin: 0;
    max-width: 70ch;
    font-size: clamp(1.3rem, 0.9vw, 1.45rem);
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.46);
  }

  /* ── MEDIA — non-boxy: soft radial fade + accent glow, no hard frame ── */
  .sk-diff--{{ section.id }} .sk-diff__media {
    position: relative;
    align-self: stretch;
    min-height: clamp(300px, 34vw, 460px);
  }

  .sk-diff--{{ section.id }} .sk-diff__media::before {
    content: "";
    position: absolute;
    inset: -14%;
    z-index: 0;
    background: radial-gradient(
      60% 55% at 58% 42%,
      color-mix(in srgb, var(--sk-diff-accent, var(--color-brand)) 26%, transparent),
      transparent 72%
    );
    filter: blur(8px);
  }

  .sk-diff--{{ section.id }} .sk-diff__media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Directional fade — anchored right, dissolves sideways toward the content.
       Radial (not a hard linear edge) so top/bottom stay soft = never boxy. */
    -webkit-mask-image: radial-gradient(118% 105% at 100% 45%, #000 36%, transparent 100%);
    mask-image: radial-gradient(118% 105% at 100% 45%, #000 36%, transparent 100%);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .sk-diff--{{ section.id }} .sk-diff__inner--media {
      gap: clamp(1.6rem, 3vw, 2.6rem);
    }

    .sk-diff--{{ section.id }} .sk-diff__row {
      grid-template-columns: clamp(84px, 22%, 130px) minmax(0, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .sk-diff--{{ section.id }} {
      padding: clamp(3rem, 8vw, 4rem) 0;
    }

    .sk-diff--{{ section.id }} .sk-diff__inner {
      padding-inline: clamp(1.6rem, 5vw, 2.6rem);
    }

    /* Stack: image becomes a faded banner on top */
    .sk-diff--{{ section.id }} .sk-diff__inner--media {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 6vw, 2.8rem);
    }

    .sk-diff--{{ section.id }} .sk-diff__media {
      order: -1;
      min-height: clamp(220px, 56vw, 320px);
    }

    /* Fade downward toward the content below */
    .sk-diff--{{ section.id }} .sk-diff__media img {
      -webkit-mask-image: radial-gradient(120% 118% at 50% 0%, #000 40%, transparent 100%);
      mask-image: radial-gradient(120% 118% at 50% 0%, #000 40%, transparent 100%);
    }

    .sk-diff--{{ section.id }} .sk-diff__title {
      font-size: var(--sk-mobile-heading-size);
      line-height: var(--sk-mobile-heading-line);
    }

    .sk-diff--{{ section.id }} .sk-diff__lead {
      font-size: var(--sk-mobile-body-size);
      line-height: var(--sk-mobile-body-line);
    }

    .sk-diff--{{ section.id }} .sk-diff__hero {
      grid-template-columns: 1fr;
      row-gap: 1rem;
      align-items: start;
    }

    .sk-diff--{{ section.id }} .sk-diff__hero-num {
      font-size: clamp(3.4rem, 15vw, 4.6rem);
    }

    .sk-diff--{{ section.id }} .sk-diff__hero-content {
      padding-bottom: 0;
    }

    .sk-diff--{{ section.id }} .sk-diff__row {
      grid-template-columns: 1fr;
      row-gap: 0.4rem;
    }
  }
</style>

{%- assign diff_ref = product.metafields.custom.differentiator_reference -%}
{%- assign eyebrow = '' -%}
{%- assign heading = '' -%}
{%- assign subheading = '' -%}
{%- assign note = '' -%}
{%- assign rows = blank -%}
{%- assign media_image = section.settings.image -%}
{%- assign show_section = false -%}

{%- if diff_ref != blank and diff_ref.value != blank -%}
  {%- assign entry = diff_ref.value -%}
  {%- assign eyebrow = entry.eyebrow.value | default: '' -%}
  {%- assign heading = entry.heading.value | default: '' -%}
  {%- assign subheading = entry.subheading.value | default: '' -%}
  {%- assign note = entry.note.value | default: '' -%}
  {%- assign media_image = entry.image.value | default: section.settings.image -%}

  {%- if entry.rows != blank and entry.rows.value != blank -%}
    {%- assign rows = entry.rows.value -%}
  {%- endif -%}

  {%- if heading != blank or rows != blank -%}
    {%- assign show_section = true -%}
  {%- endif -%}
{%- endif -%}

{%- if show_section -%}
  <section
    class="sk-product-differentiator sk-diff sk-diff--{{ section.id }}"
    style="--sk-diff-accent: {{ section.settings.accent | default: '#30273e' }};"
    {%- if heading != blank %} aria-labelledby="sk-diff-title-{{ section.id }}"{% endif -%}
  >
    <div class="sk-diff__inner{% if media_image != blank %} sk-diff__inner--media{% endif %}">
      <div class="sk-diff__body">
        {% if eyebrow != blank or heading != blank or subheading != blank %}
          <header class="sk-diff__header">
            {% if eyebrow != blank %}
              <p class="sk-diff__eyebrow">{{ eyebrow | escape }}</p>
            {% endif %}
            {% if heading != blank %}
              <h2 class="sk-diff__title" id="sk-diff-title-{{ section.id }}">{{ heading | escape }}</h2>
            {% endif %}
            {% if subheading != blank %}
              <p class="sk-diff__lead">{{ subheading | escape }}</p>
            {% endif %}
          </header>
        {% endif %}

        {% if rows != blank %}
          <div class="sk-diff__rows" role="list">
            {% for row in rows %}
              {% assign figure = row.figure.value | default: '' %}
              {% assign label = row.label.value | default: '' %}
              {% assign standard_value = row.standard_value.value | default: '' %}
              {% assign is_highlight = row.highlight.value | default: false %}
              {% assign std_label = section.settings.standard_label | strip %}

              {% if figure != blank or label != blank %}
                {% if is_highlight %}
                  {%- assign fig_num = figure | split: ' ' | first -%}
                  {%- assign fig_unit = figure | remove_first: fig_num | strip -%}
                  <div class="sk-diff__hero" role="listitem">
                    <p class="sk-diff__hero-figure">
                      <span class="sk-diff__hero-num">{{ fig_num | escape }}</span>
                      {% if fig_unit != blank %}
                        <span class="sk-diff__hero-unit">{{ fig_unit | escape }}</span>
                      {% endif %}
                    </p>
                    <div class="sk-diff__hero-content">
                      {% if label != blank %}
                        <p class="sk-diff__hero-label">{{ label | escape }}</p>
                      {% endif %}
                      {% if standard_value != blank %}
                        <p class="sk-diff__standard">
                          {%- if std_label != blank %}{{ std_label | escape }}: {% endif -%}
                          {{ standard_value | escape }}
                        </p>
                      {% endif %}
                    </div>
                  </div>
                {% else %}
                  <div class="sk-diff__row" role="listitem">
                    {% if figure != blank %}
                      <p class="sk-diff__figure">{{ figure | escape }}</p>
                    {% endif %}
                    <div class="sk-diff__content">
                      {% if label != blank %}
                        <p class="sk-diff__label">{{ label | escape }}</p>
                      {% endif %}
                      {% if standard_value != blank %}
                        <p class="sk-diff__standard">
                          {%- if std_label != blank %}{{ std_label | escape }}: {% endif -%}
                          {{ standard_value | escape }}
                        </p>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% if note != blank %}
          <p class="sk-diff__note">{{ note | escape | newline_to_br }}</p>
        {% endif %}
      </div>

      {% if media_image != blank %}
        <div class="sk-diff__media">
          {{
            media_image
            | image_url: width: 1600
            | image_tag:
              widths: '420, 600, 840, 1000, 1200, 1400, 1600',
              sizes: '(min-width: 990px) 40vw, 100vw',
              loading: 'lazy',
              alt: media_image.alt | default: heading
          }}
        </div>
      {% endif %}
    </div>
  </section>
{%- elsif request.design_mode -%}
  <section class="sk-product-differentiator sk-diff sk-diff--{{ section.id }}">
    <div class="sk-diff__inner">
      <p class="sk-diff__note">
        Tom: legg til en oppføring på
        <code>product.metafields.custom.differentiator_reference</code>
        (metaobjekt <code>product_differentiator</code>) for å fylle denne seksjonen.
      </p>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "SK – Differentiator",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bilde (valgfritt)",
      "info": "Rendres mykt utfadet (ikke firkantet). Per-produkt-bilde kan settes via metaobjektets image-felt og vinner over dette."
    },
    {
      "type": "color",
      "id": "accent",
      "label": "Aksentfarge",
      "default": "#30273e",
      "info": "Brukes på enhet (kursiv) og bilde-glød. Standard er aubergine; dra mot varm/IR for mer farge."
    },
    {
      "type": "text",
      "id": "standard_label",
      "label": "Etikett for standard-/billigverdi",
      "default": "Typisk rimelig maske",
      "info": "Prefiks foran 'standard_value' når en rad har den utfylt."
    }
  ],
  "presets": [
    {
      "name": "SK – Differentiator"
    }
  ]
}
{% endschema %}
