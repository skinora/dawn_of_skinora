{%- comment -%}
  skinora-clinic-comparison.liquid
  Standalone clinic price comparison.
  Extracted from sk-lp-hero.liquid (BLOCK 2: VALUE JUSTIFICATION / ROI anchor).
{%- endcomment -%}

<style>
  .sk-clinic-compare {
    padding: clamp(2.5rem, 6vw, 4.5rem) 1rem;
    background: transparent;
  }
  .sk-clinic-compare.sk-bg-soft {
    background: #f6f2ed;
  }
  .sk-clinic-compare.sk-bg-accent {
    background: #f0ede8;
    border-top: 1px solid #e6dfd5;
    border-bottom: 1px solid #e6dfd5;
  }
  .sk-clinic-compare__container {
    max-width: 760px;
    margin: 0 auto;
  }
  .sk-clinic-compare__heading {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', Georgia, serif;
    font-size: clamp(26px, 4vw, 34px);
    font-weight: 400;
    color: #3a3448;
    letter-spacing: 0.4px;
    line-height: 1.25;
    margin: 0 0 14px;
    text-align: center;
  }
  .sk-clinic-compare__intro {
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #4a4458;
    margin: 0 0 12px;
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .sk-clinic-compare__intro p {
    margin: 0 0 6px;
  }
  .sk-clinic-compare__highlight {
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #a0522d;
    text-align: center;
    margin: 0 0 24px;
  }
  .sk-clinic-compare__table-wrap {
    margin: 0 auto 24px;
    max-width: 640px;
  }

  /* Desktop / tablet table */
  .sk-clinic-compare__table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    background: #fff;
    border: 1px solid #e6dfd5;
    border-radius: 10px;
    overflow: hidden;
  }
  .sk-clinic-compare__table th,
  .sk-clinic-compare__table td {
    padding: 12px 14px;
    text-align: center;
    border-bottom: 1px solid #ece6dc;
  }
  .sk-clinic-compare__table tr:last-child th,
  .sk-clinic-compare__table tr:last-child td {
    border-bottom: 0;
  }
  .sk-clinic-compare__table thead th {
    background: #f8f5ef;
    color: #30273e;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .sk-clinic-compare__table th[scope='row'] {
    text-align: left;
    color: #4a4458;
    font-weight: 500;
  }
  .sk-clinic-compare__table .sk-cell--brand {
    background: rgba(160, 82, 45, 0.06);
    color: #30273e;
    font-weight: 600;
  }
  .sk-clinic-compare__table .sk-cell--clinic {
    color: #6b6b6b;
  }

  /* Mobile cards */
  .sk-clinic-compare__cards {
    display: none;
  }
  .sk-clinic-compare__card {
    background: #fff;
    border: 1px solid #e6dfd5;
    border-radius: 10px;
    padding: 14px 16px;
    margin: 0 0 12px;
  }
  .sk-clinic-compare__card-label {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #4a4458;
    margin: 0 0 10px;
    letter-spacing: 0.02em;
  }
  .sk-clinic-compare__card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .sk-clinic-compare__card-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sk-clinic-compare__card-col {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(48, 39, 62, 0.55);
  }
  .sk-clinic-compare__card-val {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: #6b6b6b;
  }
  .sk-clinic-compare__card-cell--brand .sk-clinic-compare__card-val {
    color: #30273e;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .sk-clinic-compare__table-wrap .sk-clinic-compare__table {
      display: none;
    }
    .sk-clinic-compare__cards {
      display: block;
    }
  }

  .sk-clinic-compare__cta-wrap {
    text-align: center;
    margin-top: 8px;
  }
  .sk-clinic-compare__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 52px;
    padding: 14px 30px;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
    color: #fff;
    background: #30273e;
    border: 1px solid #30273e;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 180ms ease, background-color 180ms ease;
  }
  .sk-clinic-compare__cta:hover {
    background: #3a3448;
    transform: translateY(-2px);
  }
  .sk-clinic-compare__cta:focus-visible {
    outline: 2px solid #a0522d;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .sk-clinic-compare__cta {
      transition: none;
    }
    .sk-clinic-compare__cta:hover {
      transform: none;
    }
  }

  .sk-clinic-compare .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<section
  class="sk-clinic-compare sk-bg-{{ section.settings.background_style | default: 'soft' }}"
  aria-labelledby="sk-clinic-compare-heading-{{ section.id }}"
>
  <div class="sk-clinic-compare__container sk-container">
    {%- if section.settings.heading != blank -%}
      <h2 id="sk-clinic-compare-heading-{{ section.id }}" class="sk-clinic-compare__heading">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.intro_body != blank -%}
      <div class="sk-clinic-compare__intro">{{ section.settings.intro_body }}</div>
    {%- endif -%}

    {%- if section.settings.highlight_line != blank -%}
      <p class="sk-clinic-compare__highlight">→ {{ section.settings.highlight_line }}</p>
    {%- endif -%}

    {%- assign col1 = section.settings.col1_label | default: 'Klinikk' -%}
    {%- assign col2 = section.settings.col2_label | default: 'Skinora' -%}

    <div class="sk-clinic-compare__table-wrap">
      <table class="sk-clinic-compare__table">
        <caption class="visually-hidden">
          Sammenligning: klinikkbehandling vs. Skinora® Clear
        </caption>
        <thead>
          <tr>
            <th scope="col"><span class="visually-hidden">Kategori</span></th>
            <th scope="col">{{ col1 }}</th>
            <th scope="col">{{ col2 }}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">{{ section.settings.row1_label | default: 'Kostnad' }}</th>
            <td class="sk-cell--clinic">{{ section.settings.row1_col1 | default: '800–1500 kr/økt' }}</td>
            <td class="sk-cell--brand">{{ section.settings.row1_col2 | default: '4.390 kr én gang' }}</td>
          </tr>
          <tr>
            <th scope="row">{{ section.settings.row2_label | default: 'Behandlinger' }}</th>
            <td class="sk-cell--clinic">{{ section.settings.row2_col1 | default: 'Betaler hver gang' }}</td>
            <td class="sk-cell--brand">{{ section.settings.row2_col2 | default: 'Ubegrenset' }}</td>
          </tr>
          <tr>
            <th scope="row">{{ section.settings.row3_label | default: 'Bekvemmelighet' }}</th>
            <td class="sk-cell--clinic">{{ section.settings.row3_col1 | default: 'Tidsbestilling' }}</td>
            <td class="sk-cell--brand">{{ section.settings.row3_col2 | default: 'Hjemme, når du vil' }}</td>
          </tr>
        </tbody>
      </table>

      {%- comment -%} Mobile card variant — same data, semantic dl-style markup {%- endcomment -%}
      <div class="sk-clinic-compare__cards" role="presentation">
        <div class="sk-clinic-compare__card">
          <p class="sk-clinic-compare__card-label">{{ section.settings.row1_label | default: 'Kostnad' }}</p>
          <div class="sk-clinic-compare__card-grid">
            <div class="sk-clinic-compare__card-cell">
              <span class="sk-clinic-compare__card-col">{{ col1 }}</span>
              <span class="sk-clinic-compare__card-val">
                {{- section.settings.row1_col1 | default: '800–1500 kr/økt' -}}
              </span>
            </div>
            <div class="sk-clinic-compare__card-cell sk-clinic-compare__card-cell--brand">
              <span class="sk-clinic-compare__card-col">{{ col2 }}</span>
              <span class="sk-clinic-compare__card-val">
                {{- section.settings.row1_col2 | default: '4.390 kr én gang' -}}
              </span>
            </div>
          </div>
        </div>
        <div class="sk-clinic-compare__card">
          <p class="sk-clinic-compare__card-label">{{ section.settings.row2_label | default: 'Behandlinger' }}</p>
          <div class="sk-clinic-compare__card-grid">
            <div class="sk-clinic-compare__card-cell">
              <span class="sk-clinic-compare__card-col">{{ col1 }}</span>
              <span class="sk-clinic-compare__card-val">
                {{- section.settings.row2_col1 | default: 'Betaler hver gang' -}}
              </span>
            </div>
            <div class="sk-clinic-compare__card-cell sk-clinic-compare__card-cell--brand">
              <span class="sk-clinic-compare__card-col">{{ col2 }}</span>
              <span class="sk-clinic-compare__card-val">{{ section.settings.row2_col2 | default: 'Ubegrenset' }}</span>
            </div>
          </div>
        </div>
        <div class="sk-clinic-compare__card">
          <p class="sk-clinic-compare__card-label">{{ section.settings.row3_label | default: 'Bekvemmelighet' }}</p>
          <div class="sk-clinic-compare__card-grid">
            <div class="sk-clinic-compare__card-cell">
              <span class="sk-clinic-compare__card-col">{{ col1 }}</span>
              <span class="sk-clinic-compare__card-val">
                {{- section.settings.row3_col1 | default: 'Tidsbestilling' -}}
              </span>
            </div>
            <div class="sk-clinic-compare__card-cell sk-clinic-compare__card-cell--brand">
              <span class="sk-clinic-compare__card-col">{{ col2 }}</span>
              <span class="sk-clinic-compare__card-val">
                {{- section.settings.row3_col2 | default: 'Hjemme, når du vil' -}}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- if section.settings.show_cta and section.settings.cta_label != blank -%}
      <div class="sk-clinic-compare__cta-wrap">
        <a
          href="{{ section.settings.cta_link | default: '/products/skinora-clear' }}"
          class="sk-clinic-compare__cta"
          data-analytics="cta_clinic_compare"
          aria-label="{{ section.settings.cta_label | escape }}"
        >
          {{ section.settings.cta_label }} →
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Klinikksammenligning",
  "tag": "section",
  "class": "sk-clinic-compare-wrap",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Et klinikkresultat – uten klinikkpris"
    },
    {
      "type": "richtext",
      "id": "intro_body",
      "label": "Intro-tekst",
      "default": "<p>En LED-behandling i klinikk koster typisk 800–1.500 kr per økt. Skinora® Clear tilsvarer opptil 6 behandlinger – og kan brukes ubegrenset hjemme.</p>"
    },
    {
      "type": "text",
      "id": "highlight_line",
      "label": "Highlight-linje (etter pil →)",
      "default": "Investeringen betaler seg selv etter få uker."
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Bakgrunn",
      "options": [
        { "value": "default", "label": "Default (transparent)" },
        { "value": "soft", "label": "Soft" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "soft"
    },

    { "type": "header", "content": "Kolonner" },
    { "type": "text", "id": "col1_label", "label": "Kolonne 1 – etikett", "default": "Klinikk" },
    { "type": "text", "id": "col2_label", "label": "Kolonne 2 – etikett", "default": "Skinora" },

    { "type": "header", "content": "Rad 1 – Kostnad" },
    { "type": "text", "id": "row1_label", "label": "Etikett", "default": "Kostnad" },
    { "type": "text", "id": "row1_col1", "label": "Klinikk-verdi", "default": "800–1500 kr/økt" },
    { "type": "text", "id": "row1_col2", "label": "Skinora-verdi", "default": "4.390 kr én gang" },

    { "type": "header", "content": "Rad 2 – Behandlinger" },
    { "type": "text", "id": "row2_label", "label": "Etikett", "default": "Behandlinger" },
    { "type": "text", "id": "row2_col1", "label": "Klinikk-verdi", "default": "Betaler hver gang" },
    { "type": "text", "id": "row2_col2", "label": "Skinora-verdi", "default": "Ubegrenset" },

    { "type": "header", "content": "Rad 3 – Bekvemmelighet" },
    { "type": "text", "id": "row3_label", "label": "Etikett", "default": "Bekvemmelighet" },
    { "type": "text", "id": "row3_col1", "label": "Klinikk-verdi", "default": "Tidsbestilling" },
    { "type": "text", "id": "row3_col2", "label": "Skinora-verdi", "default": "Hjemme, når du vil" },

    { "type": "header", "content": "CTA" },
    { "type": "checkbox", "id": "show_cta", "label": "Vis CTA-knapp", "default": true },
    { "type": "text", "id": "cta_label", "label": "Knappetekst", "default": "Prøv risikofritt i 60 dager" },
    { "type": "url", "id": "cta_link", "label": "Knappelenke (URL)" }
  ],
  "presets": [
    {
      "name": "Klinikksammenligning",
      "category": "Skinora landing"
    }
  ]
}
{% endschema %}
