{%- comment -%}
  sk-lp-whats-in-box.liquid
  "What's in the box" section with image and dynamic item list.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign wib_handle = section.settings.product_link_url
  | split: '/products/'
  | last
  | split: '?'
  | first
  | default: 'skinora-radiance-face'
-%}
{%- assign wib_product = all_products[wib_handle] -%}
{%- assign wib_variant = wib_product.selected_or_first_available_variant -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<style>
  :root {
    --cta-bg: #30273e;
    /* --cta-bg: #C8964A; */ /* A/B test: warm gold alternative */
  }
  .lp-internal-link {
    font-family: 'sofia-pro', 'sofia-pro-fallback', Assistant, sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: #5f5f5f;
    text-align: center;
    margin: 24px auto 0;
    max-width: 600px;
    line-height: 1.6;
  }
  .lp-internal-link__anchor {
    color: #a0522d;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .lp-internal-link__anchor:hover {
    text-decoration: none;
  }
  @media (max-width: 749px) {
    .lp-internal-link {
      font-size: 14px;
      padding: 0 16px;
    }
  }
</style>

<!-- SECTION: What's in the Box -->
<div class="sk-lp">
  <section class="lp-whats-in-box">
    <div class="lp-container">
      <div class="lp-whats-in-box__grid">
        <div class="lp-whats-in-box__image-col">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
              sizes="(max-width: 991px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | default: 'Skinora Radiance Face LED-maske – produktbilde, innhold i esken' }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
              decoding="async"
            >
          {%- else -%}
            <div class="lp-whats-in-box__image-placeholder">[ Bilde: Unboxing / innhold i esken ]</div>
          {%- endif -%}
        </div>

        <div class="lp-whats-in-box__content">
          <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

          {%- if section.blocks.size > 0 -%}
            <ul class="lp-whats-in-box__list">
              {%- for block in section.blocks -%}
                <li class="lp-whats-in-box__item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="lp-whats-in-box__item-icon"
                      ><img
                        src="{{ block.settings.icon | image_url: height: 40 }}"
                        alt=""
                        role="presentation"
                        width="20"
                        height="20"
                        loading="lazy"
                    ></span>
                  {%- endif -%}
                  {{ block.settings.text }}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- if wib_variant -%}
            <div class="lp-whats-in-box__cta" style="margin-top:24px;text-align:center;">
              <form
                action="{{ routes.cart_add_url }}"
                method="post"
                enctype="multipart/form-data"
                class="lp-cta-form"
                data-cta="whats-in-box"
              >
                <input type="hidden" name="id" value="{{ wib_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="lp-btn"
                  style="background: var(--cta-bg);"
                  data-product-handle="{{ wib_handle }}"
                  aria-label="Bestill nå – risikofritt"
                >
                  Bestill nå – risikofritt
                </button>
              </form>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP What's In The Box",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva får du i esken?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Unboxing-bilde"
    },
    {
      "type": "text",
      "id": "product_link_intro",
      "label": "Lenke intro-tekst",
      "default": "Vil du se alle tekniske spesifikasjoner, variant-valg og leveringsdetaljer?"
    },
    {
      "type": "text",
      "id": "product_link_text",
      "label": "Lenke ankertekst",
      "default": "Se hele produktsiden"
    },
    {
      "type": "text",
      "id": "product_link_url",
      "label": "Lenke URL (f.eks. /products/skinora-clear)"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Innhold",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Skinora® LED-maske"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP What's In The Box",
      "blocks": [
        { "type": "item", "settings": { "text": "Skinora® Radiance Face LED-maske" } },
        { "type": "item", "settings": { "text": "USB-C ladekabel" } },
        { "type": "item", "settings": { "text": "Øyebeskyttelse" } },
        { "type": "item", "settings": { "text": "Bruksanvisning (norsk)" } },
        { "type": "item", "settings": { "text": "Premium oppbevaringspose" } }
      ]
    }
  ]
}
{% endschema %}
