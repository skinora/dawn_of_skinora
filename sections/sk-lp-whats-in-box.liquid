{%- comment -%}
  sk-lp-whats-in-box.liquid
  "What's in the box" section with image and dynamic item list.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- SECTION: What's in the Box -->
<div class="sk-lp">
  <section class="lp-whats-in-box">
    <div class="lp-container">
      <div class="lp-whats-in-box__grid">
        <div class="lp-whats-in-box__image-col">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
              sizes="(max-width: 991px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | default: 'Hva du får i esken' }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="lp-whats-in-box__image-placeholder">[ Bilde: Unboxing / innhold i esken ]</div>
          {%- endif -%}
        </div>

        <div class="lp-whats-in-box__content">
          <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

          {%- if section.blocks.size > 0 -%}
            <ul class="lp-whats-in-box__list">
              {%- for block in section.blocks -%}
                <li class="lp-whats-in-box__item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="lp-whats-in-box__item-icon"
                      ><img
                        src="{{ block.settings.icon | image_url: height: 40 }}"
                        alt=""
                        width="20"
                        height="20"
                        loading="lazy"
                    ></span>
                  {%- endif -%}
                  {{ block.settings.text }}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP What's In The Box",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva får du i esken?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Unboxing-bilde"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Innhold",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Skinora® LED-maske"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP What's In The Box",
      "blocks": [
        { "type": "item", "settings": { "text": "Skinora® Radiance Face LED-maske" } },
        { "type": "item", "settings": { "text": "USB-C ladekabel" } },
        { "type": "item", "settings": { "text": "Øyebeskyttelse" } },
        { "type": "item", "settings": { "text": "Bruksanvisning (norsk)" } },
        { "type": "item", "settings": { "text": "Premium oppbevaringspose" } }
      ]
    }
  ]
}
{% endschema %}
