{%- comment -%}
  sk-lp-sticky-buy-bar.liquid
  Persistent mobile-only bottom buy-bar for landing pages.
  Shows after user scrolls past hero CTA, hides near final CTA.
  Direct-to-checkout flow on Add-to-Cart.
{%- endcomment -%}

{%- if section.settings.enabled -%}
  {%- assign sbb_product = section.settings.product -%}
  {%- assign sbb_variant = sbb_product.selected_or_first_available_variant -%}

  <aside
    class="sk-sticky-bar"
    id="sk-sticky-bar"
    role="region"
    aria-label="Kjøp {{ sbb_product.title | default: 'Skinora Clear' }}"
    aria-hidden="true"
    inert
  >
    <div class="sk-sticky-bar__inner">
      <div class="sk-sticky-bar__price-block">
        <span class="sk-sticky-bar__price">{{ section.settings.price }}</span>
        <span class="sk-sticky-bar__subprice">{{ section.settings.subprice }}</span>
      </div>
      <div class="sk-sticky-bar__cta-block">
        <form
          action="{{ routes.cart_add_url }}"
          method="post"
          enctype="multipart/form-data"
          class="sk-sticky-bar__form"
          id="sk-sticky-bar-form"
        >
          <input type="hidden" name="id" value="{{ sbb_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button
            type="submit"
            class="sk-sticky-bar__btn"
            aria-label="Legg {{ sbb_product.title | default: 'Skinora Clear' }} i handlekurven – {{ section.settings.price }}"
          >
            {{ section.settings.cta_label }}
          </button>
        </form>
      </div>
    </div>
    <div class="sk-sticky-bar__error" id="sk-sticky-bar-error" role="alert" aria-live="assertive"></div>
  </aside>

  <style>
    /* Sticky bar must escape its Shopify section's content-visibility containing block */
    .shopify-section.sk-lp-sticky-buy-bar-wrapper,
    .sk-lp-sticky-buy-bar-wrapper {
      content-visibility: visible !important;
      contain: none !important;
    }

    /* ── Sticky buy-bar — scoped under .sk-sticky-bar ── */
    .sk-sticky-bar {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 90;
      background: #fff;
      border-top: 1px solid #ececec;
      box-shadow: 0 -4px 14px rgba(0, 0, 0, 0.08);
      padding: 10px 16px;
      padding-bottom: max(12px, env(safe-area-inset-bottom));
      transform: translateY(100%);
      opacity: 0;
      transition: transform 200ms ease-out, opacity 200ms ease-out;
      pointer-events: none;
    }

    .sk-sticky-bar.is-visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    /* Hide the hero's own sticky CTA when this bar is present */
    .lp-hero__sticky-cta {
      display: none !important;
    }

    .sk-sticky-bar__inner {
      display: flex;
      align-items: center;
      gap: 12px;
      max-width: 480px;
      margin: 0 auto;
    }

    .sk-sticky-bar__price-block {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .sk-sticky-bar__price {
      font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: #30273e;
      line-height: 1.2;
      white-space: nowrap;
    }

    .sk-sticky-bar__subprice {
      font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #6b6b6b;
      line-height: 1.3;
      white-space: nowrap;
    }

    .sk-sticky-bar__cta-block {
      flex: 1 1 auto;
      min-width: 0;
    }

    .sk-sticky-bar__form {
      display: contents;
    }

    .sk-sticky-bar__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      width: 100%;
      padding: 14px 24px;
      font-family: inherit;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1;
      color: var(--lp-cta-fg, #fff);
      background: var(--lp-cta-bg, #30273e);
      border: 1px solid var(--lp-cta-bg, #30273e);
      border-radius: var(--lp-cta-radius, 12px);
      box-shadow: var(--lp-cta-shadow, 0 6px 18px rgba(48, 39, 62, 0.28)),
        var(--lp-cta-inset, inset 0 1px 0 rgba(255, 255, 255, 0.12));
      cursor: pointer;
      transition: transform 180ms cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 180ms cubic-bezier(0.2, 0.7, 0.2, 1),
        background-color 180ms ease;
      -webkit-appearance: none;
    }

    .sk-sticky-bar__btn:hover,
    .sk-sticky-bar__btn:focus-visible {
      background: var(--lp-cta-bg-hover, #3d3450);
      box-shadow: var(--lp-cta-shadow-hover, 0 12px 28px rgba(48, 39, 62, 0.36)),
        var(--lp-cta-inset, inset 0 1px 0 rgba(255, 255, 255, 0.12));
      transform: translateY(-2px);
    }

    .sk-sticky-bar__btn:active {
      background: var(--lp-cta-bg-active, #221a2e);
      transform: translateY(0);
    }

    .sk-sticky-bar__btn:focus-visible {
      outline: 3px solid var(--lp-cta-focus, #e8d7b5);
      outline-offset: 3px;
    }

    .sk-sticky-bar__btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .sk-sticky-bar__error {
      font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
      font-size: 12px;
      color: #c0392b;
      text-align: center;
      padding: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 200ms ease, padding 200ms ease;
    }

    .sk-sticky-bar__error.has-error {
      max-height: 40px;
      padding: 6px 16px 0;
    }

    /* Bottom offset for page content when bar is visible */
    .sk-sticky-bar.is-visible ~ main,
    body:has(.sk-sticky-bar.is-visible) {
      --lp-sticky-offset: 72px;
    }

    /* ── Desktop: constrain inner width, add breathing room ── */
    @media (min-width: 769px) {
      .sk-sticky-bar {
        padding-top: 14px;
        padding-bottom: 14px;
      }
      .sk-sticky-bar__inner {
        max-width: 1200px;
        padding: 0 24px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .sk-sticky-bar {
        transition: none;
      }
      .sk-sticky-bar__btn {
        transition: none;
      }
      .sk-sticky-bar__btn:hover {
        transform: none;
      }
      .sk-sticky-bar__error {
        transition: none;
      }
    }
  </style>

  <script>
    /* ── Sticky bar visibility controller ── */
    (function initSkStickyBar() {
      var bar = document.getElementById('sk-sticky-bar');
      if (!bar) return;

      var triggerSelector = {{ section.settings.trigger_selector | json }};
      var hideSelector = {{ section.settings.hide_selector | json }};

      var heroCta = triggerSelector ? document.querySelector(triggerSelector) : null;
      var ctaFinal = hideSelector ? document.querySelector(hideSelector) : null;

      function showBar() {
        bar.classList.add('is-visible');
        bar.removeAttribute('aria-hidden');
        bar.removeAttribute('inert');
        document.documentElement.classList.add('sk-sticky-bar-visible');
      }

      function hideBar() {
        bar.classList.remove('is-visible');
        bar.setAttribute('aria-hidden', 'true');
        bar.setAttribute('inert', '');
        document.documentElement.classList.remove('sk-sticky-bar-visible');
      }

      /* ── Hero observer: show bar after user scrolls PAST it ── */
      if (heroCta) {
        var heroObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              hideBar();
            } else {
              /* Show only when hero is above viewport (scrolled past),
                 not when it's below viewport (page just loaded). */
              if (entry.boundingClientRect.top < 0) {
                showBar();
              } else {
                hideBar();
              }
            }
          });
        }, { threshold: 0, rootMargin: '0px' });
        heroObs.observe(heroCta);
      } else {
        /* Fallback: show after 600px scroll */
        window.addEventListener('scroll', function () {
          if (window.scrollY > 600) { showBar(); } else { hideBar(); }
        }, { passive: true });
      }

      /* ── Final CTA observer: hide bar when near bottom CTA ── */
      if (ctaFinal) {
        var ctaObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) hideBar();
          });
        }, { rootMargin: '120px 0px 0px 0px', threshold: 0 });
        ctaObs.observe(ctaFinal);
      }

      /* Expose for debugging */
      window.skStickyBar = { show: showBar, hide: hideBar, bar: bar };
    })();

    /* ── Sticky bar form handler ── */
    (function initSkStickyBarForm() {
      var form = document.getElementById('sk-sticky-bar-form');
      var errorEl = document.getElementById('sk-sticky-bar-error');
      if (!form) return;

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Legger til\u2026';
        if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: new FormData(form)
        })
        .then(function (r) { if (!r.ok) throw new Error('ATC failed'); return r.json(); })
        .then(function () {
          btn.textContent = 'Lagt til \u2713';
          /* Refresh and open cart drawer */
          var cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            cartDrawer.classList.remove('is-empty');
            var drawerItems = cartDrawer.querySelector('cart-drawer-items');
            if (drawerItems) drawerItems.classList.remove('is-empty');
            fetch('/cart?sections=cart-drawer,cart-icon-bubble')
              .then(function (r) { return r.json(); })
              .then(function (sections) {
                cartDrawer.renderContents({ sections: sections });
              });
          } else {
            window.location.href = '/cart';
            return;
          }
          setTimeout(function () { btn.textContent = originalText; btn.disabled = false; }, 1500);
        })
        .catch(function () {
          btn.textContent = originalText;
          btn.disabled = false;
          if (errorEl) {
            errorEl.textContent = 'Noe gikk galt. Pr\u00f8v igjen.';
            errorEl.style.display = 'block';
          } else {
            form.submit();
          }
        });
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "LP Sticky Buy Bar",
  "tag": "div",
  "class": "sk-lp-sticky-buy-bar-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Vis sticky buy-bar (mobil)",
      "default": true
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produkt"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Pris",
      "default": "4 390 kr"
    },
    {
      "type": "text",
      "id": "subprice",
      "label": "Underpris",
      "default": "eller fra 122 kr/mnd med Klarna"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-tekst",
      "default": "Prøv risikofritt →"
    },
    {
      "type": "text",
      "id": "trigger_selector",
      "label": "Vis etter element (CSS-selektor)",
      "default": ".lp-hero__actions"
    },
    {
      "type": "text",
      "id": "hide_selector",
      "label": "Skjul ved element (CSS-selektor)",
      "default": ".lp-cta-final"
    }
  ],
  "presets": [
    {
      "name": "LP Sticky Buy Bar"
    }
  ],
  "enabled_on": {
    "templates": ["page"]
  }
}
{% endschema %}
