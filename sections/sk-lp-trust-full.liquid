{%- comment -%}
  sk-lp-trust-full.liquid
  Full trust / guarantee cards section for landing pages.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-trust-full.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Trust -->
<div class="sk-lp">
  <section class="lp-trust-full">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

      {%- if section.blocks.size > 0 -%}
        <div class="lp-trust-full__grid">
          {%- for block in section.blocks -%}
            <div class="lp-trust-full__card" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="lp-trust-full__icon">
                  <img
                    src="{{ block.settings.icon | image_url: height: 56 }}"
                    alt=""
                    role="presentation"
                    width="28"
                    height="28"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}
              <h3 class="lp-trust-full__title">{{ block.settings.title }}</h3>
              <div class="lp-trust-full__text">{{ block.settings.text }}</div>
              {%- if block.settings.show_free_return_shipping -%}
                <p class="lp-trust-full__bullet">
                  ✔ {{ block.settings.free_return_shipping_text | default: 'Vi betaler returfrakten' }}
                </p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Trust Full",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "info": "Tips: variér overskriften per instans på siden, f.eks. \"Prøv hjemme i 30 dager – helt risikofritt\", \"30 dagers hudgaranti – send tilbake hvis du ikke ser forskjell\", \"Ingen risiko. 30 dager til å bestemme deg.\"",
      "default": "Trygg handel – alltid"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Garantikort",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "30 dagers fornøydgaranti"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Tekst",
          "default": "<p>Ikke fornøyd? Du får pengene tilbake – ingen spørsmål.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_free_return_shipping",
          "label": "Vis \"Vi betaler returfrakten\"-bullet",
          "default": false
        },
        {
          "type": "text",
          "id": "free_return_shipping_text",
          "label": "Returfrakt-tekst",
          "default": "Vi betaler returfrakten"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Trust Full",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "30 dagers fornøydgaranti",
            "text": "<p>Ikke fornøyd? Du får pengene tilbake – ingen spørsmål.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Gratis frakt",
            "text": "<p>Sendes fra norsk lager. Levering 2–4 virkedager.</p>"
          }
        },
        {
          "type": "card",
          "settings": { "title": "Norsk kundeservice", "text": "<p>Spørsmål? Vi er her. hello@skinora.no</p>" }
        },
        {
          "type": "card",
          "settings": { "title": "Sikker betaling", "text": "<p>Vipps, Klarna, Visa og Mastercard.</p>" }
        },
        {
          "type": "card",
          "settings": {
            "title": "2 års reklamasjonsrett",
            "text": "<p>Full reklamasjonsrett i henhold til norsk lov.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
