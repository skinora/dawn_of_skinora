{%- comment -%}
  Section: lp-results
  Two independent before/after comparison sliders, side by side on desktop.
{%- endcomment -%}

<style>
  /* ── Base ── */
  #lp-results-timeline {
    --sk-brand: #30273e;
    --sk-text: #333333;
    --sk-muted: #5f5f5f;
    --sk-hairline: rgba(48, 39, 62, 0.12);
    --sk-surface: #ffffff;

    background: #f8f8f8;
    padding: 64px 0;
    font-family: 'sofia-pro', 'sofia-pro-fallback', 'Assistant', sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    color: var(--sk-text);
  }

  #lp-results-timeline *,
  #lp-results-timeline *::before,
  #lp-results-timeline *::after {
    box-sizing: border-box;
  }

  #lp-results-timeline img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  #lp-results-timeline p {
    margin: 0;
  }

  #lp-results-timeline .lp-results__container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: clamp(16px, 2vw, 32px);
    padding-right: clamp(16px, 2vw, 32px);
  }

  #lp-results-timeline .lp-results__heading {
    text-align: center;
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: 34px;
    font-weight: 400;
    letter-spacing: 0.6px;
    color: #3a3448;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  #lp-results-timeline .lp-results__intro {
    text-align: center;
    font-size: 18px;
    font-weight: 300;
    color: var(--sk-muted);
    margin: 0 0 16px;
    line-height: 1.75;
  }

  #lp-results-timeline .lp-results__disclaimer {
    text-align: center;
    font-size: 14px;
    font-style: italic;
    color: var(--sk-muted);
    max-width: 700px;
    margin: 0 auto 48px;
    line-height: 1.6;
    font-weight: 300;
  }

  /* ── Result cards row ── */
  #lp-results-timeline .lp-results__cards {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0;
    margin: 0 0 32px;
  }

  #lp-results-timeline .lp-results__card-wrapper {
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 320px;
  }

  #lp-results-timeline .lp-results__card {
    background: var(--sk-surface);
    border-radius: 8px;
    box-shadow: 0 1px 3px rgba(48, 39, 62, 0.04);
    padding: 32px 24px 28px;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  @media (hover: hover) {
    #lp-results-timeline .lp-results__card:hover {
      box-shadow: 0 4px 12px rgba(48, 39, 62, 0.08);
      transform: translateY(-2px);
    }
  }

  #lp-results-timeline .lp-results__number {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: var(--sk-brand);
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px 0 0;
    margin: 0 0 16px;
    flex-shrink: 0;
  }

  #lp-results-timeline .lp-results__time {
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sk-muted);
    margin: 0 0 8px;
    font-weight: 600;
  }

  #lp-results-timeline .lp-results__desc {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: 17px;
    font-weight: 500;
    color: #3a3448;
    line-height: 1.3;
    margin: 0;
  }

  #lp-results-timeline .lp-results__arrow {
    font-size: 20px;
    padding: 0 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    user-select: none;
    color: #80748e;
  }

  /* ── Dual-slider grid ── */
  #lp-results-timeline .lp-results__sliders {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  /* ── Slider card (wrapper around slider + caption) ── */
  #lp-results-timeline .lp-slider-card {
    display: flex;
    flex-direction: column;
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
  }

  #lp-results-timeline .lp-slider-card__caption {
    text-align: center;
    padding: 16px 12px 0;
  }

  #lp-results-timeline .lp-slider-card__timeline {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sk-muted);
    font-weight: 600;
    margin: 0 0 6px;
  }

  #lp-results-timeline .lp-slider-card__customer {
    font-family: 'sofia-pro', 'sofia-pro-fallback', 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #3a3448;
    margin: 0 0 4px;
  }

  #lp-results-timeline .lp-slider-card__concern {
    font-family: 'sofia-pro', 'sofia-pro-fallback', 'Assistant', sans-serif;
    font-size: 13px;
    font-weight: 300;
    font-style: italic;
    color: var(--sk-muted);
    margin: 0;
  }

  /* ── Slider ── */
  #lp-results-timeline .lp-slider {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(48, 39, 62, 0.1);
    cursor: col-resize;
    aspect-ratio: 3 / 4;
    width: 100%;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
  }

  @media (min-width: 768px) {
    #lp-results-timeline .lp-slider {
      aspect-ratio: 4 / 5;
    }
  }

  #lp-results-timeline .lp-slider__after,
  #lp-results-timeline .lp-slider__before {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  #lp-results-timeline .lp-slider__after img,
  #lp-results-timeline .lp-slider__before img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 30%;
    max-width: none;
  }

  #lp-results-timeline .lp-slider__after {
    z-index: 1;
  }

  #lp-results-timeline .lp-slider__before {
    z-index: 2;
    clip-path: inset(0 0 0 0);
  }

  /* ── Divider + handle ── */
  #lp-results-timeline .lp-slider__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #ffffff;
    z-index: 3;
    pointer-events: none;
    transform: translateX(-50%);
  }

  #lp-results-timeline .lp-slider__handle {
    position: absolute;
    top: 50%;
    z-index: 4;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: col-resize;
    outline: none;
    border: none;
    padding: 0;
  }

  #lp-results-timeline .lp-slider__handle:focus-visible {
    outline: 2px solid var(--sk-brand);
    outline-offset: 2px;
  }

  #lp-results-timeline .lp-slider__handle svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: var(--sk-brand);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Pills ── */
  #lp-results-timeline .lp-slider__pill {
    position: absolute;
    bottom: 12px;
    z-index: 5;
    background: rgba(0, 0, 0, 0.55);
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 4px;
    pointer-events: none;
  }

  #lp-results-timeline .lp-slider__pill--before {
    left: 12px;
  }

  #lp-results-timeline .lp-slider__pill--after {
    right: 12px;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    #lp-results-timeline {
      padding: 48px 0;
    }

    #lp-results-timeline .lp-results__heading {
      font-size: 28px;
    }

    #lp-results-timeline .lp-results__intro {
      margin-bottom: 12px;
    }

    #lp-results-timeline .lp-results__disclaimer {
      margin-bottom: 36px;
    }

    #lp-results-timeline .lp-results__cards {
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    #lp-results-timeline .lp-results__card-wrapper {
      max-width: 100%;
      width: 100%;
    }

    #lp-results-timeline .lp-results__arrow {
      display: none;
    }

    #lp-results-timeline .lp-results__sliders {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    #lp-results-timeline .lp-slider-card {
      max-width: 420px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    #lp-results-timeline .lp-slider__divider,
    #lp-results-timeline .lp-slider__handle,
    #lp-results-timeline .lp-slider__before {
      transition: none !important;
    }
  }
</style>

<section id="lp-results-timeline" class="lp-results-timeline">
  <div class="lp-results__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="lp-results__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <p class="lp-results__intro">{{ section.settings.intro_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.disclaimer != blank -%}
      <p class="lp-results__disclaimer">{{ section.settings.disclaimer | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="lp-results__cards">
        {%- for block in section.blocks -%}
          {%- if forloop.index > 1 -%}
            <span class="lp-results__arrow" aria-hidden="true">→</span>
          {%- endif -%}
          <div class="lp-results__card-wrapper" {{ block.shopify_attributes }}>
            <div class="lp-results__card">
              <div class="lp-results__number">{{ forloop.index }}</div>
              {%- if block.settings.time_period != blank -%}
                <p class="lp-results__time">{{ block.settings.time_period | escape }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="lp-results__desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Dual before/after sliders {%- endcomment -%}
    <div class="lp-results__sliders">
      {%- comment -%} ── Slider A ── {%- endcomment -%}
      {%- if section.settings.slider_a_before_image != blank and section.settings.slider_a_after_image != blank -%}
        <div class="lp-slider-card">
          <div class="lp-slider" data-lp-slider>
            <div class="lp-slider__after">
              {{
                section.settings.slider_a_after_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  decoding: 'async',
                  widths: '600, 900, 1200',
                  sizes: '(max-width: 767px) 100vw, 480px'
              }}
            </div>
            <div class="lp-slider__before" data-lp-before>
              {{
                section.settings.slider_a_before_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  decoding: 'async',
                  widths: '600, 900, 1200',
                  sizes: '(max-width: 767px) 100vw, 480px'
              }}
            </div>
            <div class="lp-slider__divider" data-lp-divider></div>
            <button
              class="lp-slider__handle"
              data-lp-handle
              type="button"
              role="slider"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="50"
              aria-label="Sammenlign før og etter"
              tabindex="0"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <polyline points="7,4 3,10 7,16"></polyline>
                <polyline points="13,4 17,10 13,16"></polyline>
              </svg>
            </button>
            <span class="lp-slider__pill lp-slider__pill--before">
              {{ section.settings.before_label | default: 'UKE 0' | escape }}
            </span>
            <span class="lp-slider__pill lp-slider__pill--after">
              {{ section.settings.after_label | default: 'UKE 8+' | escape }}
            </span>
          </div>
          <div class="lp-slider-card__caption">
            <p class="lp-slider-card__timeline">
              {{ section.settings.before_label | default: 'UKE 0' | escape }} →
              {{ section.settings.after_label | default: 'UKE 8+' | escape }}
            </p>
            {%- if section.settings.slider_a_customer != blank -%}
              <p class="lp-slider-card__customer">{{ section.settings.slider_a_customer | escape }}</p>
            {%- endif -%}
            {%- if section.settings.slider_a_concern != blank -%}
              <p class="lp-slider-card__concern">{{ section.settings.slider_a_concern | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ── Slider B ── {%- endcomment -%}
      {%- if section.settings.slider_b_before_image != blank and section.settings.slider_b_after_image != blank -%}
        <div class="lp-slider-card">
          <div class="lp-slider" data-lp-slider>
            <div class="lp-slider__after">
              {{
                section.settings.slider_b_after_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  decoding: 'async',
                  widths: '600, 900, 1200',
                  sizes: '(max-width: 767px) 100vw, 480px'
              }}
            </div>
            <div class="lp-slider__before" data-lp-before>
              {{
                section.settings.slider_b_before_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  decoding: 'async',
                  widths: '600, 900, 1200',
                  sizes: '(max-width: 767px) 100vw, 480px'
              }}
            </div>
            <div class="lp-slider__divider" data-lp-divider></div>
            <button
              class="lp-slider__handle"
              data-lp-handle
              type="button"
              role="slider"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="50"
              aria-label="Sammenlign før og etter"
              tabindex="0"
            >
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <polyline points="7,4 3,10 7,16"></polyline>
                <polyline points="13,4 17,10 13,16"></polyline>
              </svg>
            </button>
            <span class="lp-slider__pill lp-slider__pill--before">
              {{ section.settings.before_label | default: 'UKE 0' | escape }}
            </span>
            <span class="lp-slider__pill lp-slider__pill--after">
              {{ section.settings.after_label | default: 'UKE 8+' | escape }}
            </span>
          </div>
          <div class="lp-slider-card__caption">
            <p class="lp-slider-card__timeline">
              {{ section.settings.before_label | default: 'UKE 0' | escape }} →
              {{ section.settings.after_label | default: 'UKE 8+' | escape }}
            </p>
            {%- if section.settings.slider_b_customer != blank -%}
              <p class="lp-slider-card__customer">{{ section.settings.slider_b_customer | escape }}</p>
            {%- endif -%}
            {%- if section.settings.slider_b_concern != blank -%}
              <p class="lp-slider-card__concern">{{ section.settings.slider_b_concern | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('lp-results-timeline');
    if (!root) return;

    function initSlider(slider) {
      var before = slider.querySelector('[data-lp-before]');
      var divider = slider.querySelector('[data-lp-divider]');
      var handle = slider.querySelector('[data-lp-handle]');
      var pos = 50;

      function setPos(p) {
        pos = Math.max(0, Math.min(100, p));
        before.style.clipPath = 'inset(0 ' + (100 - pos) + '% 0 0)';
        divider.style.left = pos + '%';
        handle.style.left = pos + '%';
        handle.setAttribute('aria-valuenow', Math.round(pos));
      }

      function pctFromEvent(e) {
        var r = slider.getBoundingClientRect();
        var x = (e.touches ? e.touches[0].clientX : e.clientX) - r.left;
        return (x / r.width) * 100;
      }

      var dragging = false;

      function onDown(e) {
        dragging = true;
        setPos(pctFromEvent(e));
        e.preventDefault();
      }
      function onMove(e) {
        if (!dragging) return;
        setPos(pctFromEvent(e));
      }
      function onUp() {
        dragging = false;
      }

      slider.addEventListener('mousedown', onDown);
      slider.addEventListener('touchstart', onDown, { passive: false });

      // Scoped move/up: attach to document but guard per-slider
      document.addEventListener('mousemove', onMove);
      document.addEventListener('touchmove', onMove, { passive: true });
      document.addEventListener('mouseup', onUp);
      document.addEventListener('touchend', onUp);

      slider.addEventListener('click', function (e) {
        setPos(pctFromEvent(e));
      });

      handle.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft' || e.key === 'Left') setPos(pos - 1);
        else if (e.key === 'ArrowRight' || e.key === 'Right') setPos(pos + 1);
        else if (e.key === 'Home') setPos(0);
        else if (e.key === 'End') setPos(100);
        else return;
        e.preventDefault();
      });

      setPos(50);

      // Hint animation — scoped per slider
      if ('IntersectionObserver' in window) {
        var animated = false;
        var obs = new IntersectionObserver(
          function (entries) {
            if (entries[0].isIntersecting && !animated) {
              animated = true;
              obs.disconnect();
              if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
              var dur = 600;
              var start = null;
              function sweep(ts) {
                if (!start) start = ts;
                var elapsed = ts - start;
                if (elapsed < dur) {
                  setPos(50 + 25 * (elapsed / dur));
                } else if (elapsed < dur * 2) {
                  setPos(75 - 25 * ((elapsed - dur) / dur));
                } else {
                  setPos(50);
                  return;
                }
                requestAnimationFrame(sweep);
              }
              requestAnimationFrame(sweep);
            }
          },
          { threshold: 0.4 }
        );
        obs.observe(slider);
      }
    }

    // Init each slider independently
    root.querySelectorAll('[data-lp-slider]').forEach(initSlider);
  })();
</script>

{% schema %}
{
  "name": "LP Results Timeline",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Realistiske resultater fra ekte brukere"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan."
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "UKE 0"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "UKE 8+"
    },
    {
      "type": "header",
      "content": "Slider A"
    },
    {
      "type": "image_picker",
      "id": "slider_a_before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "slider_a_after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "slider_a_customer",
      "label": "Customer name",
      "default": "Maria, 48 \u2013 Oslo"
    },
    {
      "type": "text",
      "id": "slider_a_concern",
      "label": "Skin concern",
      "default": "Fine linjer og tr\u00f8tt hud"
    },
    {
      "type": "header",
      "content": "Slider B"
    },
    {
      "type": "image_picker",
      "id": "slider_b_before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "slider_b_after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "slider_b_customer",
      "label": "Customer name",
      "default": "Ingrid, 42 \u2013 Bergen"
    },
    {
      "type": "text",
      "id": "slider_b_concern",
      "label": "Skin concern",
      "default": "R\u00f8dhet og ujevn hudtone"
    }
  ],
  "blocks": [
    {
      "type": "result_card",
      "name": "Result card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "time_period",
          "label": "Time period",
          "default": "Etter 2\u20134 uker"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "F\u00e6rre nye utbrudd og roligere hud"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Results Timeline",
      "blocks": [
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 2\u20134 uker",
            "description": "F\u00e6rre nye utbrudd og roligere hud"
          }
        },
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 6\u20138 uker",
            "description": "Synlig jevnere hudtone og tekstur"
          }
        },
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 12 uker",
            "description": "Klarere, sterkere og mer motstandsdyktig hud"
          }
        }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
