{%- comment -%}
  Section: lp-results
  Landing page results timeline with numbered step cards,
  disclaimer, and 3-image progress row.
{%- endcomment -%}

<style>
  .lp-results {
    background: #f9f8f6;
    padding: 60px 20px;
  }

  .lp-results__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .lp-results__heading {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .lp-results__intro {
    text-align: center;
    font-size: 16px;
    color: #7a7a7a;
    margin: 0 0 40px;
    line-height: 1.5;
  }

  /* ── Result cards row ── */
  .lp-results__cards {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0;
    margin: 0 0 32px;
  }

  .lp-results__card-wrapper {
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 320px;
  }

  .lp-results__card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    padding: 32px 24px 28px;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lp-results__number {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #ffffff;
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 18px;
    flex-shrink: 0;
  }

  .lp-results__time {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999999;
    margin: 0 0 8px;
    font-weight: 600;
  }

  .lp-results__desc {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    margin: 0;
  }

  .lp-results__arrow {
    font-size: 24px;
    color: #cccccc;
    padding: 0 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    user-select: none;
  }

  .lp-results__disclaimer {
    text-align: center;
    font-size: 13px;
    font-style: italic;
    color: #999999;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ── Progress images row ── */
  .lp-results__progress {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .lp-results__progress-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .lp-results__progress-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lp-results__progress-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0) 100%);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: #ffffff;
  }

  .lp-results__progress-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 4px;
    opacity: 0.85;
    font-weight: 600;
  }

  .lp-results__progress-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .lp-results__progress-desc {
    font-size: 14px;
    font-style: italic;
    margin: 0;
    line-height: 1.4;
    opacity: 0.85;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .lp-results {
      padding: 40px 16px;
    }

    .lp-results__heading {
      font-size: 24px;
    }

    .lp-results__cards {
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    .lp-results__card-wrapper {
      max-width: 100%;
      width: 100%;
    }

    .lp-results__arrow {
      display: none;
    }

    .lp-results__progress {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>

<section class="lp-results">
  <div class="lp-results__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="lp-results__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <p class="lp-results__intro">{{ section.settings.intro_text | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="lp-results__cards">
        {%- for block in section.blocks -%}
          {%- if forloop.index > 1 -%}
            <span class="lp-results__arrow" aria-hidden="true">→</span>
          {%- endif -%}
          <div class="lp-results__card-wrapper" {{ block.shopify_attributes }}>
            <div class="lp-results__card">
              <div class="lp-results__number">{{ forloop.index }}</div>
              {%- if block.settings.time_period != blank -%}
                <p class="lp-results__time">{{ block.settings.time_period | escape }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="lp-results__desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.disclaimer != blank -%}
      <p class="lp-results__disclaimer">{{ section.settings.disclaimer | escape }}</p>
    {%- endif -%}

    {%- assign has_progress = false -%}
    {%- if section.settings.image_1 != blank
      or section.settings.image_2 != blank
      or section.settings.image_3 != blank
    -%}
      {%- assign has_progress = true -%}
    {%- endif -%}

    {%- if has_progress -%}
      <div class="lp-results__progress">
        {%- for i in (1..3) -%}
          {%- assign img_key = 'image_' | append: i -%}
          {%- assign label_key = 'image_' | append: i | append: '_label' -%}
          {%- assign title_key = 'image_' | append: i | append: '_title' -%}
          {%- assign desc_key = 'image_' | append: i | append: '_description' -%}
          {%- assign img = section.settings[img_key] -%}
          {%- if img != blank -%}
            <div class="lp-results__progress-item">
              {{
                img
                | image_url: width: 800
                | image_tag:
                  class: 'lp-results__progress-img',
                  loading: 'lazy',
                  widths: '375, 560, 800',
                  sizes: '(max-width: 768px) 100vw, 33vw'
              }}
              <div class="lp-results__progress-overlay">
                {%- assign label_val = section.settings[label_key] -%}
                {%- assign title_val = section.settings[title_key] -%}
                {%- assign desc_val = section.settings[desc_key] -%}
                {%- if label_val != blank -%}
                  <p class="lp-results__progress-label">{{ label_val | escape }}</p>
                {%- endif -%}
                {%- if title_val != blank -%}
                  <p class="lp-results__progress-title">{{ title_val | escape }}</p>
                {%- endif -%}
                {%- if desc_val != blank -%}
                  <p class="lp-results__progress-desc">{{ desc_val | escape }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Results Timeline",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Realistiske resultater fra ekte brukere"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan."
    },
    {
      "type": "header",
      "content": "Progress image 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_1_label",
      "label": "Label",
      "default": "UKE 0"
    },
    {
      "type": "text",
      "id": "image_1_title",
      "label": "Title",
      "default": "Trøtt og livløs hud"
    },
    {
      "type": "text",
      "id": "image_1_description",
      "label": "Description",
      "default": "Mørke ringer, matt hud, fine linjer"
    },
    {
      "type": "header",
      "content": "Progress image 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_2_label",
      "label": "Label",
      "default": "UKE 4"
    },
    {
      "type": "text",
      "id": "image_2_title",
      "label": "Title",
      "default": "Merkbar forbedring"
    },
    {
      "type": "text",
      "id": "image_2_description",
      "label": "Description",
      "default": "Redusert rødhet, litt mer glød og fuktighet"
    },
    {
      "type": "header",
      "content": "Progress image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_3_label",
      "label": "Label",
      "default": "UKE 8+"
    },
    {
      "type": "text",
      "id": "image_3_title",
      "label": "Title",
      "default": "Glødende og jevn"
    },
    {
      "type": "text",
      "id": "image_3_description",
      "label": "Description",
      "default": "Jevn hudtone, stram og frisk kompleksjon"
    }
  ],
  "blocks": [
    {
      "type": "result_card",
      "name": "Result card",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "time_period",
          "label": "Time period",
          "default": "Etter 2–4 uker"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Færre nye utbrudd og roligere hud"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Results Timeline",
      "blocks": [
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 2–4 uker",
            "description": "Færre nye utbrudd og roligere hud"
          }
        },
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 6–8 uker",
            "description": "Synlig jevnere hudtone og tekstur"
          }
        },
        {
          "type": "result_card",
          "settings": {
            "time_period": "Etter 12 uker",
            "description": "Klarere, sterkere og mer motstandsdyktig hud"
          }
        }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
