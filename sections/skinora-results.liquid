{%- comment -%}
  sections/skinora-results.liquid
  Typographic 3-step results timeline. No images, no card chrome —
  large italic numerals + thin SVG connector between cards on desktop.
  Connector hidden on mobile where cards stack vertically.
{%- endcomment -%}

{{ 'skinora-results.css' | asset_url | stylesheet_tag }}

<section class="skinora-results lp-results-timeline" aria-labelledby="skinora-results-heading-{{ section.id }}">
  <div class="skinora-results__inner">
    <header class="skinora-results__header">
      <h2 id="skinora-results-heading-{{ section.id }}" class="skinora-results__h2">
        {{ section.settings.headline | default: 'Hva kan du forvente?' }}
      </h2>
      {%- if section.settings.eyebrow != blank -%}
        <p class="skinora-results__subhead">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <div class="skinora-results__note">{{ section.settings.subtext }}</div>
      {%- endif -%}
    </header>

    <ol class="skinora-results__grid lp-results__grid">
      {%- for block in section.blocks -%}
        {%- if block.type != 'step' -%}{%- continue -%}{%- endif -%}
        {%- assign main_text = block.settings.title | default: block.settings.body -%}

        <li class="skinora-results__card lp-results__card" {{ block.shopify_attributes }}>
          <span class="skinora-results__num lp-results__number">{{ forloop.index }}</span>
          {%- if block.settings.label != blank -%}
            <p class="skinora-results__label lp-results__eyebrow">{{ block.settings.label }}</p>
          {%- endif -%}
          {%- if main_text != blank -%}
            <div class="skinora-results__body lp-results__body">{{ main_text }}</div>
          {%- endif -%}
        </li>

        {%- unless forloop.last -%}
          <li class="skinora-results__connector lp-results__connector" aria-hidden="true">
            <svg viewBox="0 0 80 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="6" x2="68" y2="6" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
              <polyline points="62,1 72,6 62,11" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </li>
        {%- endunless -%}
      {%- endfor -%}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "Skinora Results",
  "tag": "section",
  "class": "sk-lp-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Innhold"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Overskrift",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Underoverskrift",
      "default": "Realistiske resultater fra ekte brukere"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Mikrotekst",
      "default": "<p>Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan.</p>"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Steg",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tidsmerkelapp",
          "default": "ETTER 2–4 UKER"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Brødtekst",
          "default": "<p>Færre nye utbrudd og roligere hud.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skinora Results",
      "category": "Skinora",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "label": "ETTER 2–4 UKER",
            "title": "<p>Færre nye utbrudd og roligere hud.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "ETTER 6–8 UKER",
            "title": "<p>Jevnere hudtone og redusert rødhet.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "OVER TID",
            "title": "<p>Klarere hud og bedre hudbalanse.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
