{%- comment -%}
  sk-lp-why-choose.liquid
  "Why choose us" feature cards for landing pages.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Why Skinora is Different -->
<div class="sk-lp">
  <section class="lp-why-radiance">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
      <p class="lp-section-intro">&nbsp;</p>

      {%- if section.blocks.size > 0 -%}
        <div class="lp-why-radiance__grid">
          {%- for block in section.blocks -%}
            <div class="lp-why-radiance__card" {{ block.shopify_attributes }}>
              <div class="lp-why-radiance__card-row">
                {%- if block.settings.icon != blank -%}
                  <div class="lp-why-radiance__icon">
                    <img
                      src="{{ block.settings.icon | image_url: height: 96 }}"
                      alt=""
                      width="32"
                      height="32"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
                <div class="lp-why-radiance__card-body">
                  <h3 class="lp-why-radiance__title">{{ block.settings.title }}</h3>
                  <div class="lp-why-radiance__text">{{ block.settings.text }}</div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Why Choose",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hvorfor Radiance er annerledes"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Kort",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Ikon" },
        { "type": "text", "id": "title", "label": "Tittel", "default": "Klinisk dokumentert teknologi" },
        {
          "type": "richtext",
          "id": "text",
          "label": "Tekst",
          "default": "<p>LED-bølgelengder som stimulerer hudens naturlige kollagen- og elastinproduksjon.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Why Choose",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Klinisk dokumentert teknologi",
            "text": "<p>LED-bølgelengder som stimulerer hudens naturlige kollagen- og elastinproduksjon.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Komfortabel passform",
            "text": "<p>Utviklet for daglig hjemmebruk – myk, lett og enkel å ha på.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Enkel å bruke",
            "text": "<p>Få knapper, ingen komplisert rutine. På – og slapp av.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Premium kvalitet og garanti",
            "text": "<p>Norsk kundeservice og 60 dagers fornøydgaranti.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
