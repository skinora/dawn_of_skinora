{%- comment -%}
  sk-lp-why-choose.liquid
  Premium "why choose us" – 2×2 benefit cards with micro-proof,
  optional image column on desktop, CTA row at bottom.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<div class="sk-lp">
  <section class="lp-why-radiance">
    <div class="lp-container">
      <div class="lp-why-radiance__layout">
        <div class="lp-why-radiance__content">
          <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>

          {%- if section.settings.intro != blank -%}
            <p class="lp-why-radiance__intro">{{ section.settings.intro }}</p>
          {%- endif -%}

          {%- if section.blocks.size > 0 -%}
            <div class="lp-why-radiance__grid">
              {%- for block in section.blocks -%}
                <div class="lp-why-radiance__card" {{ block.shopify_attributes }}>
                  <div class="lp-why-radiance__card-head">
                    <h3 class="lp-why-radiance__title">{{ block.settings.title }}</h3>
                  </div>
                  <div class="lp-why-radiance__card-row">
                    {%- if block.settings.icon != blank -%}
                      <div class="lp-why-radiance__icon">
                        <img
                          src="{{ block.settings.icon | image_url: height: 64 }}"
                          alt=""
                          width="32"
                          height="32"
                          loading="lazy"
                        >
                      </div>
                    {%- else -%}
                      <div class="lp-why-radiance__icon">
                        {%- case forloop.index -%}
                          {%- when 1 -%}
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M9 3h6M10 3v6.5L4 20h16L14 9.5V3"/><circle cx="12" cy="16" r="2"/>
                            </svg>
                          {%- when 2 -%}
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                          {%- when 3 -%}
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M18.36 6.64A9 9 0 1 1 5.64 6.64"/><line x1="12" y1="2" x2="12" y2="12"/>
                            </svg>
                          {%- when 4 -%}
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
                            </svg>
                        {%- endcase -%}
                      </div>
                    {%- endif -%}
                    <div class="lp-why-radiance__card-body">
                      <p class="lp-why-radiance__text">{{ block.settings.text }}</p>
                      {%- if block.settings.proof != blank -%}
                        <p class="lp-why-radiance__proof">{{ block.settings.proof }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
            <div class="lp-why-radiance__cta-row">
              <a href="{{ section.settings.cta_link }}" class="lp-btn lp-why-radiance__cta-btn">
                {{- section.settings.cta_label -}}
              </a>
              <p class="lp-why-radiance__cta-note">60 dager fornøydgaranti</p>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_image and section.settings.image != blank -%}
          <div class="lp-why-radiance__image">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 800 }} 800w"
              sizes="(min-width: 990px) 50vw, 0px"
              alt="{{ section.settings.image.alt | escape }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
            >
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Why Choose",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hvorfor Radiance er annerledes"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "Fire detaljer som gjør masken enkel å bruke – og god å leve med."
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Vis bilde (høyre kolonne på desktop)",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bilde"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-tekst",
      "default": "Se produktet"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA-lenke"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Kort",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Klinisk dokumentert teknologi"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Tekst",
          "default": "LED-bølgelengder som stimulerer hudens naturlige kollagen- og elastinproduksjon."
        },
        {
          "type": "text",
          "id": "proof",
          "label": "Mikro-bevis",
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Why Choose",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Klinisk dokumentert teknologi",
            "text": "LED-bølgelengder valgt for å støtte hudens naturlige prosesser over tid.",
            "proof": "Rød og nær-IR er mye brukt i LED-lysbehandling."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Komfortabel passform",
            "text": "Utviklet for daglig hjemmebruk – myk, lett og enkel å ha på.",
            "proof": "Myk silikon + justerbar stropp."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Enkel å bruke",
            "text": "Få knapper, ingen komplisert rutine. På – og slapp av.",
            "proof": "10 minutter. 1 knapp."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Premium kvalitet og garanti",
            "text": "Norsk kundeservice og 60 dagers fornøydgaranti.",
            "proof": "Rask levering fra Norge."
          }
        }
      ]
    }
  ]
}
{% endschema %}
