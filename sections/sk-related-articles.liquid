{{ 'section-sk-related-articles.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Relaterte artikler — automatisk intern lenking (temaklynge).
  Viser inntil 3 andre innlegg fra samme blogg, ekskludert den nåværende
  artikkelen. Ankertekst = artikkelens tittel.

  Pilarstruktur: settingen `pillar_article` (komplett-guiden) vises alltid
  først når den er satt og ikke er artikkelen man står på — slik lenker alle
  undertema-artikler til pilarsiden, og pilarsiden lenker ut til de mer
  spesifikke artiklene via de automatiske kortene.
{%- endcomment -%}

{%- assign max_posts = 3 -%}
{%- assign pillar = section.settings.pillar_article -%}
{%- assign show_pillar = false -%}
{%- if pillar != blank and pillar.handle != article.handle -%}
  {%- assign show_pillar = true -%}
  {%- assign max_posts = max_posts | minus: 1 -%}
{%- endif -%}

{%- assign other_count = blog.articles_count | minus: 1 -%}
{%- if show_pillar or other_count > 0 -%}
  <section
    class="sk-related-articles section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
    aria-labelledby="sk-related-articles-heading-{{ section.id }}"
  >
    <div class="page-width">
      <h2 id="sk-related-articles-heading-{{ section.id }}" class="sk-related-articles__heading">
        {{ section.settings.heading | default: 'Relaterte artikler' | escape }}
      </h2>

      <div class="sk-related-articles__grid">
        {%- if show_pillar -%}
          {%- render 'sk-related-article-card', related: pillar -%}
        {%- endif -%}

        {%- assign shown = 0 -%}
        {%- for related in blog.articles -%}
          {%- if shown >= max_posts -%}{%- break -%}{%- endif -%}
          {%- if related.handle == article.handle -%}{%- continue -%}{%- endif -%}
          {%- if show_pillar and related.handle == pillar.handle -%}{%- continue -%}{%- endif -%}
          {%- render 'sk-related-article-card', related: related -%}
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Relaterte artikler",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["article"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Relaterte artikler"
    },
    {
      "type": "article",
      "id": "pillar_article",
      "label": "Pilarartikkel",
      "info": "Vises alltid først (f.eks. komplett-guiden). La stå tom for kun automatiske forslag."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Relaterte artikler"
    }
  ]
}
{% endschema %}
