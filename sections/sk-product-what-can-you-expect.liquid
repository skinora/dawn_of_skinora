{{ 'section-sk-product-what-can-you-expect.css' | asset_url | stylesheet_tag }}
{{ 'component-before-after.css' | asset_url | stylesheet_tag }}
<script src="{{ 'component-before-after.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign sk_result_entry = null
  if product and product.metafields.custom.result_section_reference != blank
    assign sk_result_entry = product.metafields.custom.result_section_reference.value
  endif

  assign result_eyebrow = section.settings.eyebrow
  if sk_result_entry and sk_result_entry.eyebrow != blank
    assign result_eyebrow = sk_result_entry.eyebrow
  endif

  assign result_kicker2 = section.settings.kicker_secondary

  assign result_heading = section.settings.heading
  if sk_result_entry and sk_result_entry.heading != blank
    assign result_heading = sk_result_entry.heading
  endif

  assign result_intro = section.settings.bullet_intro_text
  if sk_result_entry and sk_result_entry.bullet_intro != blank
    assign result_intro = sk_result_entry.bullet_intro
  endif

  assign result_intro_markup = ''
  if result_intro != blank
    if result_intro.value != blank
      assign result_intro_markup = result_intro | metafield_tag
    else
      assign result_intro_markup = result_intro
    endif
  endif

  assign result_bullets = section.settings.rich_bullet_content
  if sk_result_entry and sk_result_entry.bullet_points != blank
    assign result_bullets = sk_result_entry.bullet_points
  endif

  assign result_bullets_markup = ''
  if result_bullets != blank
    if result_bullets.value != blank
      assign result_bullets_markup = result_bullets | metafield_tag
    else
      assign result_bullets_markup = result_bullets
    endif
  endif

  assign result_note = section.settings.note_text
  if sk_result_entry and sk_result_entry.note != blank
    assign result_note = sk_result_entry.note
  endif

  assign result_image = section.settings.result_image
  if sk_result_entry and sk_result_entry.hero_image != blank
    assign result_image = sk_result_entry.hero_image
  endif

  assign result_image_alt = section.settings.result_image_alt
  if result_image and result_image.alt != blank
    assign result_image_alt = result_image.alt
  endif
  if sk_result_entry and sk_result_entry.hero_image_alt != blank
    assign result_image_alt = sk_result_entry.hero_image_alt
  endif

  assign result_before_image = null
  if sk_result_entry and sk_result_entry.before_image != blank
    assign result_before_image = sk_result_entry.before_image
  endif

  assign result_after_image = null
  if sk_result_entry and sk_result_entry.after_image != blank
    assign result_after_image = sk_result_entry.after_image
  endif

  # CTA — tom tekst => "Handle {produktnavn}", tom URL => produktsiden
  assign result_cta_text = section.settings.cta_text
  if result_cta_text == blank and product
    assign result_cta_text = 'Handle ' | append: product.title
  endif
  assign result_cta_url = section.settings.cta_url
  if result_cta_url == blank and product
    assign result_cta_url = product.url
  endif

  assign result_variant = null
  if product
    assign result_variant = product.selected_or_first_available_variant
  endif
%}

<section class="sk-results section" id="sk-results-{{ section.id }}">
  <div class="page-width">
    <div class="sk-results__card">
      <div class="sk-results__inner">

        <div class="sk-results__media">
          {% if result_before_image != blank and result_after_image != blank %}
            <div
              class="before-after"
              data-before-after
              data-initial="50"
              aria-label="Dra for å se før og etter"
            >
              <div class="before-after__image before-after__image--before">
                <img
                  src="{{ result_before_image | image_url: width: 1200 }}"
                  alt="{{ result_before_image.alt | escape | default: 'Før' }}"
                  loading="lazy"
                  width="{{ result_before_image.width | default: 1200 }}"
                  height="{{ result_before_image.height | default: 1440 }}"
                >
                <span class="visually-hidden">Før-bilde</span>
              </div>
              <div class="before-after__image before-after__image--after">
                <img
                  src="{{ result_after_image | image_url: width: 1200 }}"
                  alt="{{ result_after_image.alt | escape | default: 'Etter' }}"
                  loading="lazy"
                  width="{{ result_after_image.width | default: 1200 }}"
                  height="{{ result_after_image.height | default: 1440 }}"
                >
                <span class="visually-hidden">Etter-bilde</span>
              </div>
              <div
                class="before-after__slider"
                role="slider"
                aria-label="Dra for å se før og etter"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="50"
                tabindex="0"
                data-ba-slider
              >
                <span class="before-after__line" aria-hidden="true"></span>
                <span class="before-after__handle" aria-hidden="true"></span>
              </div>
            </div>
          {% elsif result_image != blank %}
            <div class="sk-results__single">
              <img
                src="{{ result_image | image_url: width: 1200 }}"
                alt="{{ result_image_alt | default: product.title | escape }}"
                loading="lazy"
                width="{{ result_image.width | default: 1200 }}"
                height="{{ result_image.height | default: 1440 }}"
              >
            </div>
          {% endif %}
        </div>

        <div class="sk-results__content">
          {% if result_eyebrow != blank or result_kicker2 != blank %}
            <div class="sk-results__kickers">
              {% if result_eyebrow != blank %}
                <span class="sk-results__pill">{{ result_eyebrow }}</span>
              {% endif %}
              {% if result_kicker2 != blank %}
                <span class="sk-results__kicker2">{{ result_kicker2 }}</span>
              {% endif %}
            </div>
          {% endif %}

          {% if result_heading != blank %}
            <h2 class="sk-results__title">{{ result_heading }}</h2>
          {% endif %}

          {% if result_intro_markup != blank %}
            <div class="sk-results__intro">{{ result_intro_markup }}</div>
          {% endif %}

          {% if result_bullets_markup != blank %}
            <div class="sk-results__grid">{{ result_bullets_markup }}</div>
          {% endif %}

          {% if result_cta_text != blank %}
            {% if product and result_variant %}
              <form
                action="{{ routes.cart_add_url }}"
                method="post"
                enctype="multipart/form-data"
                class="lp-cta-form sk-results__cta-form"
              >
                <input type="hidden" name="id" value="{{ result_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button
                  type="submit"
                  class="sk-btn sk-btn--primary"
                  data-product-handle="{{ product.handle }}"
                >
                  {{ result_cta_text }}
                  <span class="sk-btn__icon" aria-hidden="true">→</span>
                </button>
              </form>
            {% else %}
              <a class="sk-btn sk-btn--primary sk-results__cta" href="{{ result_cta_url }}">
                {{ result_cta_text }}
                <span class="sk-btn__icon" aria-hidden="true">→</span>
              </a>
            {% endif %}
          {% endif %}

          {% if result_note != blank %}
            <p class="sk-results__note">{{ result_note }}</p>
          {% endif %}
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SK Result Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Kicker (pill)",
      "default": "Resultater"
    },
    {
      "type": "text",
      "id": "kicker_secondary",
      "label": "Kicker 2 (dempet)",
      "default": "Klinisk utviklet"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "richtext",
      "id": "bullet_intro_text",
      "label": "Introtekst",
      "default": "<p>Del en kort introduksjon her.</p>"
    },
    {
      "type": "richtext",
      "id": "rich_bullet_content",
      "label": "Resultater (4 punkter → 2×2-rutenett)",
      "info": "Bruk en punktliste med 4 korte punkter for best layout.",
      "default": "<ul><li>Fastere hud på hals og kjevelinje</li><li>Jevnere hudstruktur</li><li>Mer spenst og fylde</li><li>Et mer definert uttrykk</li></ul>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA-tekst",
      "info": "Tom = «Handle [produktnavn]»."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-lenke",
      "info": "Tom = produktsiden."
    },
    {
      "type": "textarea",
      "id": "note_text",
      "label": "Ansvarsfraskrivelse",
      "default": "* Resultater varierer fra person til person og påvirkes av hudtype og regelmessig bruk."
    },
    {
      "type": "image_picker",
      "id": "result_image",
      "label": "Støttebilde (brukes hvis før/etter mangler)"
    },
    {
      "type": "text",
      "id": "result_image_alt",
      "label": "Alternativ tekst",
      "default": "Resultatbilde"
    }
  ],
  "presets": [
    {
      "name": "SK Resultater",
      "category": "Custom"
    }
  ]
}
{% endschema %}
