{%- comment -%}
  sk-lp-faq.liquid
  FAQ accordion for landing pages. Each Q&A pair is a block.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- SECTION: FAQ -->
<div class="sk-lp">
  <section class="lp-faq">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
      <p class="lp-section-intro">&nbsp;</p>

      {%- if section.blocks.size > 0 -%}
        <div class="lp-faq__list" data-lp-faq>
          {%- for block in section.blocks -%}
            <div class="lp-faq__item" {{ block.shopify_attributes }}>
              <button class="lp-faq__question" type="button" aria-expanded="false">
                {{ block.settings.question }}
                <span class="lp-faq__icon">+</span>
              </button>
              <div class="lp-faq__answer">
                <div class="lp-faq__answer-inner">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {%- endfor -%}

          {%- comment -%} Usage frequency FAQ — hardcoded for conversion {%- endcomment -%}
          <div class="lp-faq__item">
            <button class="lp-faq__question" type="button" aria-expanded="false">
              Hvor ofte må jeg bruke den for at det skal være verdt det?
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__answer">
              <div class="lp-faq__answer-inner">
                <p>
                  Vi anbefaler 3–5 ganger i uken, 10 minutter per økt. Det tilsvarer én sesong med favorittserien din i
                  uken. Mange merker de første resultatene etter 2–4 uker med jevn bruk. Og fordi du betaler én gang og
                  bruker den ubegrenset, blir prisen per behandling lavere jo mer du bruker den.
                </p>
              </div>
            </div>
          </div>

          {%- comment -%} No-results guarantee FAQ — hardcoded for conversion {%- endcomment -%}
          <div class="lp-faq__item">
            <button class="lp-faq__question" type="button" aria-expanded="false">
              Hva om jeg ikke ser noen forskjell?
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__answer">
              <div class="lp-faq__answer-inner">
                <p>
                  Da vil vi at du skal sende den tilbake – og du får pengene tilbake, uten spørsmål. Det er hele poenget
                  med vår 60 dagers fornøydgaranti. Vi er trygge på at jevn bruk gir resultater, men vi vet at hud er
                  individuell. Har du ikke sett endring innen 60 dager, kontakter du oss på hello@skinora.no – og vi
                  ordner resten.
                </p>
              </div>
            </div>
          </div>

          {%- comment -%} Price justification FAQ — hardcoded for conversion {%- endcomment -%}
          <div class="lp-faq__item">
            <button class="lp-faq__question" type="button" aria-expanded="false">
              Er 4.690 kr mye å betale for en LED-maske?
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__answer">
              <div class="lp-faq__answer-inner">
                <p>
                  Sammenlignet med klinikk er det faktisk det motsatte. Én LED-behandling hos hudterapeut koster typisk
                  800–1.500 kr. Med Skinora® Radiance Face betaler du én gang og kan bruke masken ubegrenset hjemme.
                  Etter bare 3–6 behandlinger har produktet betalt seg selv – resten er ren gevinst. Du kan også dele
                  opp betalingen med Klarna fra 130 kr/mnd.
                </p>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

<script>
  (function initLpFaqAccordion() {
    var lists = document.querySelectorAll('[data-lp-faq]');
    lists.forEach(function (list) {
      var items = list.querySelectorAll('.lp-faq__item');
      items.forEach(function (item) {
        var btn = item.querySelector('.lp-faq__question');
        btn.addEventListener('click', function () {
          var isOpen = item.classList.contains('is-open');
          items.forEach(function (i) {
            i.classList.remove('is-open');
            i.querySelector('.lp-faq__question').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('is-open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "LP FAQ",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Ofte stilte spørsmål"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ-spørsmål",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Spørsmål"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Svar"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Hvor ofte bør jeg bruke masken?",
            "answer": "Vi anbefaler 3–5 økter i uken, à 10 minutter. Du kan bruke den morgen eller kveld – det som passer best for deg."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Når kan jeg forvente å se resultater?",
            "answer": "De fleste merker forbedring i glød og hudtone etter 2–4 uker. For mer synlige resultater som jevnere tekstur og reduserte pigmentflekker, anbefaler vi minst 6–8 uker med jevnlig bruk."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Er LED-lys trygt for huden?",
            "answer": "Ja. LED-terapi er en ikke-invasiv teknologi som er grundig testet og brukes av hudterapeuter verden over. Den inneholder ingen UV-stråler og er skånsom mot alle hudtyper."
          }
        }
      ]
    }
  ]
}
{% endschema %}
