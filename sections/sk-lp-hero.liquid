{%- comment -%}
  sk-lp-hero.liquid
  Canonical LP hero — used by both Clear and Radiance landing pages.
  Above-the-fold content only: media + eyebrow + H1 + subline + rating + CTA + ≤3 pills.
  Trust, pricing, risk-reversal, and sticky CTA live in dedicated sections below.
{%- endcomment -%}

{%- comment -%} LCP preload — browser discovers image before CSS blocks {%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 800 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
    imagesizes="(max-width: 991px) 100vw, 50vw"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-hero.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign sk_lp_variant = sk_lp_product.selected_or_first_available_variant -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Hero -->
<div class="sk-lp">
  <section class="lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h1 class="lp-hero__title">{{ section.settings.title }}</h1>

        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}

        {%- if section.settings.rating_score != blank -%}
          <div class="lp-hero__rating">
            <span class="lp-hero__rating-stars" aria-hidden="true">★★★★★</span>
            <span class="lp-hero__rating-score">{{ section.settings.rating_score }}/5</span>
            <span class="lp-hero__rating-sep" aria-hidden="true">·</span>
            <span class="lp-hero__rating-count">
              {{- section.settings.review_count | default: '0' }} verifiserte kunder</span
            >
          </div>
        {%- endif -%}

        <div class="lp-hero__actions">
          <form
            action="{{ routes.cart_add_url }}"
            method="post"
            enctype="multipart/form-data"
            class="lp-cta-form"
            data-cta="hero"
          >
            <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="lp-btn lp-btn--hero"
              data-product-handle="{{ sk_lp_handle }}"
              aria-label="{{ section.settings.cta_text }}"
            >
              {{ section.settings.cta_text }}
            </button>
          </form>
          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Trust pills under the CTA — keep to 3 for one-row mobile fit {%- endcomment -%}
        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills lp-hero__pills--under-cta">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      <div class="lp-hero__image">
        {%- comment -%} Hero media: video file > video URL > image fallback {%- endcomment -%}
        {%- assign hero_video = section.settings.hero_video_file -%}
        {%- assign hero_video_url = section.settings.hero_video_url -%}
        {%- assign hero_poster = section.settings.hero_video_poster | default: section.settings.image -%}
        {%- if hero_video != blank -%}
          {%- assign hero_mp4 = hero_video.sources | where: 'format', 'mp4' | first -%}
          <div
            class="lp-hero__media-wrap"
            style="position:relative;width:100%;aspect-ratio:{% if section.settings.image %}{{ section.settings.image.width }} / {{ section.settings.image.height }}{% else %}4 / 5{% endif %};overflow:hidden;border-radius:6px;"
          >
            <video
              class="lp-hero__video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label="Skinora Clear LED-maske i bruk"
              {% if hero_poster != blank %}
                poster="{{ hero_poster | image_url: width: 1200 }}"
              {% endif %}
              style="width:100%;height:100%;object-fit:cover;display:block;"
              data-hero-video
            >
              {%- if hero_mp4 -%}
                <source src="{{ hero_mp4.url }}" type="video/mp4">
              {%- else -%}
                {%- for source in hero_video.sources -%}
                  <source src="{{ source.url }}" type="video/{{ source.format }}">
                {%- endfor -%}
              {%- endif -%}
            </video>
          </div>
          <script>
            (function () {
              if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                document.querySelectorAll('[data-hero-video]').forEach(function (v) {
                  v.removeAttribute('autoplay');
                  try {
                    v.pause();
                  } catch (e) {}
                });
              }
            })();
          </script>
        {%- elsif hero_video_url != blank -%}
          {%- assign yt_id = '' -%}
          {%- assign vimeo_id = '' -%}
          {%- if hero_video_url contains 'youtube' or hero_video_url contains 'youtu.be' -%}
            {%- assign yt_id = hero_video_url | split: 'v=' | last | split: '&' | first | split: '/' | last -%}
          {%- elsif hero_video_url contains 'vimeo' -%}
            {%- assign vimeo_id = hero_video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
          {%- endif -%}
          <div
            class="lp-hero__media-wrap"
            style="position:relative;width:100%;aspect-ratio:16 / 9;overflow:hidden;border-radius:6px;"
          >
            {%- if yt_id != '' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&modestbranding=1&playsinline=1"
                title="Skinora Clear LED-maske i bruk"
                aria-label="Skinora Clear LED-maske i bruk"
                frameborder="0"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
              ></iframe>
            {%- elsif vimeo_id != '' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
                title="Skinora Clear LED-maske i bruk"
                aria-label="Skinora Clear LED-maske i bruk"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
              ></iframe>
            {%- endif -%}
          </div>
        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 991px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.title }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            fetchpriority="high"
            decoding="async"
          >
        {%- else -%}
          <div class="lp-hero__image-placeholder">[ Produktbilde ]</div>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Hero",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-bilde"
    },
    {
      "type": "header",
      "content": "Hero video"
    },
    {
      "type": "video",
      "id": "hero_video_file",
      "label": "Hero-video (fil)",
      "info": "Hvis satt, vises som autoplay/muted/loop i stedet for hero-bildet."
    },
    {
      "type": "video_url",
      "id": "hero_video_url",
      "label": "Hero-video (URL — YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "Brukes hvis ingen videofil er satt."
    },
    {
      "type": "image_picker",
      "id": "hero_video_poster",
      "label": "Video-poster (fallback hero-bilde)"
    },
    {
      "type": "header",
      "content": "Legal & citations"
    },
    {
      "type": "checkbox",
      "id": "show_authority_citation",
      "label": "Vis kilde-lenke (¹) etter \"Klinisk dokumentert…\"",
      "default": true
    },
    {
      "type": "text",
      "id": "authority_citation_marker",
      "label": "Kildemerke",
      "default": "¹"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-tekst",
      "default": "Skinora® Radiance Face"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Tittel",
      "info": "Hold tittelen til 4–7 ord. Støtter inline HTML: <em>, <strong>, <a>, <br>.",
      "default": "Klarere hud — uten sterke midler."
    },
    {
      "type": "header",
      "content": "Undertekst"
    },
    {
      "type": "text",
      "id": "text_line_1",
      "label": "Undertekst",
      "info": "Én linje. Hold den kort — heroen skal puste.",
      "default": "Klinisk dokumentert LED. 10 minutter, hjemme."
    },
    {
      "type": "text",
      "id": "text_line_2",
      "label": "Undertekst linje 2 (deprecated — vises ikke lenger)",
      "info": "Heroen rendrer nå kun én undertekst. Denne feltet er bevart for bakoverkompatibilitet.",
      "default": ""
    },
    {
      "type": "header",
      "content": "Kulepunkter"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Kulepunkt 1 (HTML tillatt)",
      "default": "<strong>Rødt + dNIR (1072 nm)</strong> · 10 minutter, 3-5x/uke. Resultater du kan se."
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Kulepunkt 2 (HTML tillatt)",
      "default": "Ny generasjon <strong>dNIR:</strong> 1072 nm"
    },
    {
      "type": "text",
      "id": "bullet_disclaimer",
      "label": "Disclaimer under kulepunkt 2",
      "default": "Teknisk spesifikasjon. Resultater varierer."
    },
    {
      "type": "header",
      "content": "Stjerne- og tillitselementer"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating-tekst (etter stjernene)",
      "default": "<strong>4.8/5</strong> – basert på 102 anmeldelser"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating-score (tall)",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Antall anmeldelser (tall)",
      "default": "102"
    },
    {
      "type": "header",
      "content": "Testimonial-sitat"
    },
    {
      "type": "textarea",
      "id": "testimonial_quote",
      "label": "Sitat-tekst",
      "default": "Etter 6 uker merker jeg virkelig forskjell på hudtonen – huden ser friskere ut."
    },
    {
      "type": "text",
      "id": "testimonial_author",
      "label": "Forfatter",
      "default": "Wenche S., 52, Oslo · Verifisert kjøper"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA-knapptekst",
      "default": "Prøv risikofritt i 60 dager"
    },
    {
      "type": "text",
      "id": "sticky_cta_text",
      "label": "Mobil sticky CTA-tekst (kort)",
      "default": "Prøv risikofritt →"
    },
    {
      "type": "header",
      "content": "Urgency / knapphet"
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Vis urgency-tekst under CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "urgency_text",
      "label": "Urgency-tekst",
      "default": "⚡ Populær vare – begrenset antall igjen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-lenke"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Vis sekundærlenke",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Sekundærlenke tekst",
      "default": "Se hvordan den brukes (60 sek) ↓"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Sekundærlenke URL"
    },
    {
      "type": "header",
      "content": "Verdiboks"
    },
    {
      "type": "text",
      "id": "value_title",
      "label": "Tittel (navn + pris)",
      "default": "Skinora® Clear — 4 390 kr"
    },
    {
      "type": "text",
      "id": "value_tag",
      "label": "Tag-linje (uppercase)",
      "default": "ENGANGSKJØP · INGEN ABONNEMENT"
    },
    {
      "type": "text",
      "id": "value_sub_text",
      "label": "Undertekst (italic)",
      "default": "Profesjonell klinikkteknologi – hjemme, på dine premisser"
    },
    {
      "type": "text",
      "id": "value_roi_line",
      "label": "ROI-linje (bold)",
      "default": "✓ Tilsvarer ca. 8 klinikkøkter"
    },
    {
      "type": "text",
      "id": "value_roi_sub",
      "label": "ROI-undertekst (italic)",
      "default": "Etter det er klinikkbehandlingen i praksis gratis"
    },
    {
      "type": "checkbox",
      "id": "show_value_icon",
      "label": "Vis ✓ ikon i tittel",
      "default": true
    },
    {
      "type": "header",
      "content": "Verdi-bullets"
    },
    {
      "type": "text",
      "id": "value_bullet_1",
      "label": "Bullet 1",
      "default": "Klinisk dokumentert LED-teknologi"
    },
    {
      "type": "text",
      "id": "value_bullet_2",
      "label": "Bullet 2",
      "default": "60 dagers fornøydgaranti"
    },
    {
      "type": "text",
      "id": "value_bullet_3",
      "label": "Bullet 3",
      "default": "2 års reklamasjonsrett"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Pill-tekst",
          "default": "Gratis frakt"
        }
      ]
    },
    {
      "type": "trustbar_item",
      "name": "Trust-element",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Gratis frakt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Hero",
      "blocks": [
        { "type": "pill", "settings": { "text": "CE-sertifisert" } },
        { "type": "pill", "settings": { "text": "60 dagers fornøydgaranti" } },
        { "type": "pill", "settings": { "text": "Dermatologisk testet" } }
      ]
    }
  ]
}
{% endschema %}
