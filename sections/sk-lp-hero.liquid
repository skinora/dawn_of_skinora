{%- comment -%}
  sk-lp-hero.liquid
  Full-bleed hero — image (or video) as background, content overlaid on
  a soft dark gradient. One unified visual band, mobile 100dvh.

  Renders: media-bg + overlay + (eyebrow + H1 + subline + rating + CTA
  cluster + ≤3 trust pills).
{%- endcomment -%}

{%- comment -%}
  LCP preload — browser discovers image before CSS blocks.
  Two preload links with media attributes so each viewport only
  fetches the image it needs (no double-download).
{%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 1600 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w, {{ section.settings.image | image_url: width: 2000 }} 2000w"
    imagesizes="100vw"
    media="(min-width: 769px)"
    fetchpriority="high"
  >
{%- endif -%}
{%- if section.settings.image_mobile != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image_mobile | image_url: width: 1200 }}"
    imagesrcset="{{ section.settings.image_mobile | image_url: width: 600 }} 600w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w, {{ section.settings.image_mobile | image_url: width: 1200 }} 1200w"
    imagesizes="100vw"
    media="(max-width: 768px)"
    fetchpriority="high"
  >
{%- elsif section.settings.image != blank -%}
  {%- comment -%} Fall back to desktop image on mobile if no mobile-specific image is set {%- endcomment -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 1200 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
    imagesizes="100vw"
    media="(max-width: 768px)"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-hero.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign sk_lp_variant = sk_lp_product.selected_or_first_available_variant -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Hero — full-bleed image with overlaid content -->
<div class="sk-lp">
  <section class="lp-hero lp-hero--overlay">

    {%- comment -%}
      Hero media: full-bleed background.
      Resolution order:
        1. Video file(s) — desktop and/or mobile MP4 from Shopify
        2. Video URL — single YouTube/Vimeo embed shared across viewports
        3. Image(s) — desktop and/or mobile, picked via <picture> + media queries
        4. Placeholder
    {%- endcomment -%}
    {%- assign desktop_video = section.settings.hero_video_file -%}
    {%- assign mobile_video = section.settings.hero_video_file_mobile -%}
    {%- assign hero_video_url = section.settings.hero_video_url -%}
    {%- assign desktop_image = section.settings.image -%}
    {%- assign mobile_image = section.settings.image_mobile -%}
    {%- assign hero_poster = section.settings.hero_video_poster | default: desktop_image | default: mobile_image -%}

    <div class="lp-hero__media" aria-hidden="true">
      {%- if desktop_video != blank or mobile_video != blank -%}
        {%- assign desktop_mp4 = desktop_video.sources | where: 'format', 'mp4' | first -%}
        {%- assign mobile_mp4 = mobile_video.sources | where: 'format', 'mp4' | first -%}
        <video
          class="lp-hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          {% if hero_poster != blank %}poster="{{ hero_poster | image_url: width: 1600 }}"{% endif %}
          data-hero-video
        >
          {%- if mobile_mp4 -%}
            <source src="{{ mobile_mp4.url }}" type="video/mp4" media="(max-width: 768px)">
          {%- endif -%}
          {%- if desktop_mp4 -%}
            <source src="{{ desktop_mp4.url }}" type="video/mp4" media="(min-width: 769px)">
          {%- endif -%}
          {%- comment -%}
            Fallback source for browsers that ignore the media attribute on <source>
            (some older mobile WebKit builds). Prefer desktop, fall back to mobile.
          {%- endcomment -%}
          {%- if desktop_mp4 -%}
            <source src="{{ desktop_mp4.url }}" type="video/mp4">
          {%- elsif mobile_mp4 -%}
            <source src="{{ mobile_mp4.url }}" type="video/mp4">
          {%- endif -%}
        </video>
        <script>
          (function () {
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              document.querySelectorAll('[data-hero-video]').forEach(function (v) {
                v.removeAttribute('autoplay');
                try { v.pause(); } catch (e) {}
              });
            }
          })();
        </script>
      {%- elsif hero_video_url != blank -%}
        {%- assign yt_id = '' -%}
        {%- assign vimeo_id = '' -%}
        {%- if hero_video_url contains 'youtube' or hero_video_url contains 'youtu.be' -%}
          {%- assign yt_id = hero_video_url | split: 'v=' | last | split: '&' | first | split: '/' | last -%}
        {%- elsif hero_video_url contains 'vimeo' -%}
          {%- assign vimeo_id = hero_video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
        {%- endif -%}
        {%- if yt_id != '' -%}
          <iframe
            class="lp-hero__iframe"
            src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&modestbranding=1&playsinline=1"
            title="Skinora hero video"
            frameborder="0"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {%- elsif vimeo_id != '' -%}
          <iframe
            class="lp-hero__iframe"
            src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
            title="Skinora hero video"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        {%- endif -%}
      {%- elsif desktop_image != blank or mobile_image != blank -%}
        {%- comment -%}
          <picture> lets the browser pick exactly one source — no double-fetch.
          Each <source> uses its viewport's srcset for responsive resolution.
          The <img> is the final fallback for browsers that don't understand
          <picture> (essentially none in 2026, but kept for safety).
        {%- endcomment -%}
        {%- assign fallback_image = desktop_image | default: mobile_image -%}
        <picture>
          {%- if mobile_image != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ mobile_image | image_url: width: 600 }} 600w, {{ mobile_image | image_url: width: 900 }} 900w, {{ mobile_image | image_url: width: 1200 }} 1200w"
              sizes="100vw"
            >
          {%- endif -%}
          {%- if desktop_image != blank -%}
            <source
              media="(min-width: 769px)"
              srcset="{{ desktop_image | image_url: width: 1200 }} 1200w, {{ desktop_image | image_url: width: 1600 }} 1600w, {{ desktop_image | image_url: width: 2000 }} 2000w"
              sizes="100vw"
            >
          {%- endif -%}
          <img
            src="{{ fallback_image | image_url: width: 1600 }}"
            alt="{{ fallback_image.alt | default: section.settings.title }}"
            width="{{ fallback_image.width }}"
            height="{{ fallback_image.height }}"
            fetchpriority="high"
            decoding="async"
          >
        </picture>
      {%- else -%}
        <div class="lp-hero__placeholder">[ Produktbilde ]</div>
      {%- endif -%}
    </div>

    <div class="lp-hero__overlay" aria-hidden="true"></div>

    <div class="lp-hero__inner">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h1 class="lp-hero__title">{{ section.settings.title }}</h1>

        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}

        {%- if section.settings.rating_score != blank -%}
          <div class="lp-hero__rating">
            <span class="lp-hero__rating-stars" aria-hidden="true">★★★★★</span>
            <span class="lp-hero__rating-score">{{ section.settings.rating_score }}/5</span>
            <span class="lp-hero__rating-sep" aria-hidden="true">·</span>
            <span class="lp-hero__rating-count">
              fra {{ section.settings.review_count | default: '0' }}
              {{ section.settings.audience_label | default: 'verifiserte kunder' }}</span
            >
          </div>
        {%- endif -%}

        <div class="lp-hero__actions">
          <form
            action="{{ routes.cart_add_url }}"
            method="post"
            enctype="multipart/form-data"
            class="lp-cta-form"
            data-cta="hero"
          >
            <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="lp-btn lp-btn--hero"
              data-product-handle="{{ sk_lp_handle }}"
              aria-label="{{ section.settings.cta_text }}"
            >
              {{ section.settings.cta_text }}
            </button>
          </form>

          {%- if section.settings.price_display != blank or section.settings.klarna_text != blank -%}
            <p class="lp-hero__cta-meta">
              {%- if section.settings.price_display != blank -%}
                <span class="lp-hero__cta-price">{{ section.settings.price_display }}</span>
              {%- endif -%}
              {%- if section.settings.price_display != blank and section.settings.klarna_text != blank -%}
                <span class="lp-hero__cta-meta-sep" aria-hidden="true">·</span>
              {%- endif -%}
              {%- if section.settings.klarna_text != blank -%}
                <span class="lp-hero__cta-klarna">{{ section.settings.klarna_text }}</span>
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  </section>
</div>

{% schema %}
{
  "name": "LP Hero",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero-medier — Desktop"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-bilde (desktop)",
      "info": "Vises på skjermer ≥769px. Anbefalt 1600×860 eller bredere (21:9 cinematic landscape)."
    },
    {
      "type": "video",
      "id": "hero_video_file",
      "label": "Hero-video (desktop)",
      "info": "Hvis satt, vises som autoplay/muted/loop i stedet for desktop-bildet."
    },
    {
      "type": "header",
      "content": "Hero-medier — Mobil"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero-bilde (mobil)",
      "info": "Vises på skjermer ≤768px. Anbefalt 1080×1920 (9:16 vertikal portrett). Hvis tom, brukes desktop-bildet på mobil."
    },
    {
      "type": "video",
      "id": "hero_video_file_mobile",
      "label": "Hero-video (mobil)",
      "info": "Hvis satt, vises som autoplay/muted/loop i stedet for mobil-bildet. Hvis tom, brukes desktop-videoen på mobil."
    },
    {
      "type": "header",
      "content": "Hero-video (URL)"
    },
    {
      "type": "video_url",
      "id": "hero_video_url",
      "label": "Hero-video (URL — YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "Brukes hvis ingen video-fil er satt. Samme video på desktop og mobil."
    },
    {
      "type": "image_picker",
      "id": "hero_video_poster",
      "label": "Video-poster (fallback)",
      "info": "Vises før videoen laster, eller ved redusert bevegelse-preferanse."
    },
    {
      "type": "header",
      "content": "Innhold"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-tekst",
      "default": "Skinora® Radiance Face"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Tittel",
      "info": "Hold tittelen til 4–7 ord. Støtter inline HTML: <em>, <strong>, <a>, <br>.",
      "default": "Klarere hud — uten sterke midler."
    },
    {
      "type": "text",
      "id": "text_line_1",
      "label": "Undertekst",
      "info": "Én linje, editorial italic serif. Hold den kort — heroen skal puste.",
      "default": "Klinisk dokumentert LED. 10 minutter, hjemme."
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating-score (tall)",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Antall anmeldelser (tall)",
      "default": "102"
    },
    {
      "type": "text",
      "id": "audience_label",
      "label": "Målgruppe-etikett (vises etter antall)",
      "info": "F.eks. «kvinner over 40» eller «kunder med problemhud». Speiler målgruppen for siden — bruk noe konkret som kjøperen kjenner seg igjen i. Unngå dømmende ord som «uren hud».",
      "default": "verifiserte kunder"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA-knapptekst",
      "default": "Prøv risikofritt i 60 dager"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-lenke"
    },
    {
      "type": "header",
      "content": "Pris under CTA"
    },
    {
      "type": "text",
      "id": "price_display",
      "label": "Pris (vises som serif under CTA)",
      "info": "La stå tom for å skjule pris-linjen.",
      "default": "4 690 kr"
    },
    {
      "type": "text",
      "id": "klarna_text",
      "label": "Klarna-tekst (vises etter pris)",
      "info": "Vises ved siden av prisen. La stå tom for å skjule.",
      "default": "fra 130 kr/mnd med Klarna"
    },
    {
      "type": "header",
      "content": "Sekundærlenke"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Vis sekundærlenke under CTA",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Sekundærlenke tekst",
      "default": "Se hvordan den brukes (60 sek) ↓"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Sekundærlenke URL"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Pill-tekst",
          "default": "Gratis frakt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Hero",
      "blocks": [
        { "type": "pill", "settings": { "text": "CE-sertifisert" } },
        { "type": "pill", "settings": { "text": "60 dagers fornøydgaranti" } },
        { "type": "pill", "settings": { "text": "Dermatologisk testet" } }
      ]
    }
  ]
}
{% endschema %}
