{%- comment -%}
  sk-lp-hero.liquid
  Hero section with image, title, copy, pills and CTA for landing pages.
  Pills are dynamic blocks so each LP can customise them.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign monthly_price = sk_lp_product.price | divided_by: 100 | divided_by: 36 | round -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<div class="sk-lp">
  <section class="lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 2 — Headline {%- endcomment -%}
        <h2 class="lp-hero__title">{{ section.settings.title }}</h2>

        {%- comment -%} CHANGE 3 — Split subtext {%- endcomment -%}
        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}
        {%- if section.settings.text_line_2 != blank -%}
          <p class="lp-hero__text lp-hero__text--warm">{{ section.settings.text_line_2 }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 5 — Trust pills above CTA {%- endcomment -%}
        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} CHANGE 4 — Star rating {%- endcomment -%}
        {%- if section.settings.rating_text != blank -%}
          <p class="lp-hero__rating">
            <span class="lp-hero__rating-stars">⭐⭐⭐⭐⭐</span>
            {{ section.settings.rating_text }}
          </p>
        {%- endif -%}

        {%- comment -%} CHANGE 6 — CTA button {%- endcomment -%}
        <div class="lp-hero__actions">
          <button type="button" class="lp-btn lp-btn--hero" data-product-handle="{{ sk_lp_handle }}">
            {{ section.settings.cta_text }}
          </button>
          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- assign lp_allowed_payment_types = 'visa,klarna' | split: ',' -%}
        <div class="lp-payment-icons">
          <ul class="lp-payment-icons__list">
            {%- for type in shop.enabled_payment_types -%}
              {%- if lp_allowed_payment_types contains type -%}
                <li class="lp-payment-icons__item">{{ type | payment_type_svg_tag }}</li>
              {%- endif -%}
            {%- endfor -%}
            {%- if settings.show_vipps_payment_icon -%}
              <li class="lp-payment-icons__item">
                <img src="{{ 'icon-vipps.svg' | asset_url }}" alt="Vipps" height="22" width="">
              </li>
            {%- endif -%}
          </ul>
        </div>

        {%- comment -%} CHANGE 7 — Price meta + Klarna monthly {%- endcomment -%}
        {%- if sk_lp_product != blank -%}
          <div class="lp-hero__meta">
            <span class="lp-hero__price">
              {{- sk_lp_product.price | money_without_trailing_zeros -}}
            </span>
            <span class="lp-hero__divider" aria-hidden="true">·</span>
            <span class="lp-hero__delivery">Leveringstid 2-4 dager</span>
            <p class="lp-hero__klarna">
              Eller <strong>{{ monthly_price }} kr/mnd</strong> med Klarna
            </p>
          </div>
        {%- endif -%}

        {%- comment -%} CHANGE 8 — Value Box {%- endcomment -%}
        {%- if section.settings.value_title != blank -%}
          <div class="lp-value-box">
            <div class="lp-value-box__inner">
              <p class="lp-value-box__title">
                {%- if section.settings.show_value_icon -%}
                  <span class="lp-value-box__check" aria-hidden="true">✓</span>
                {%- endif -%}
                {{- section.settings.value_title -}}
              </p>

              {%- if section.settings.value_tag != blank -%}
                <p class="lp-value-box__tag">{{ section.settings.value_tag }}</p>
              {%- endif -%}

              <p class="lp-value-box__klarna">Eller {{ monthly_price }} kr/mnd med Klarna – ingen renter</p>

              {%- if section.settings.value_sub_text != blank -%}
                <p class="lp-value-box__sub">{{ section.settings.value_sub_text }}</p>
              {%- endif -%}

              <hr class="lp-value-box__divider">

              {%- if section.settings.value_roi_line != blank -%}
                <p class="lp-value-box__roi">{{ section.settings.value_roi_line }}</p>
              {%- endif -%}

              {%- if section.settings.value_roi_sub != blank -%}
                <p class="lp-value-box__note">{{ section.settings.value_roi_sub }}</p>
              {%- endif -%}
            </div>
          </div>

          {%- comment -%} CHANGE 9 — Bottom value bullets {%- endcomment -%}
          {%- if section.settings.value_bullet_1 != blank
            or section.settings.value_bullet_2 != blank
            or section.settings.value_bullet_3 != blank
          -%}
            <div class="lp-hero__pills lp-hero__pills--value">
              {%- if section.settings.value_bullet_1 != blank -%}
                <span class="lp-hero__pill"
                  ><span class="lp-hero__pill-check">✓</span> {{ section.settings.value_bullet_1 -}}
                </span>
              {%- endif -%}
              {%- if section.settings.value_bullet_2 != blank -%}
                <span class="lp-hero__pill"
                  ><span class="lp-hero__pill-check">✓</span> {{ section.settings.value_bullet_2 -}}
                </span>
              {%- endif -%}
              {%- if section.settings.value_bullet_3 != blank -%}
                <span class="lp-hero__pill"
                  ><span class="lp-hero__pill-check">✓</span> {{ section.settings.value_bullet_3 -}}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} CHANGE 10 — Mobile sticky CTA {%- endcomment -%}
        <div class="lp-hero__sticky-cta">
          <button type="button" class="lp-btn lp-btn--sticky" data-product-handle="{{ sk_lp_handle }}">
            {{ section.settings.cta_text }}
          </button>
        </div>
      </div>

      <div class="lp-hero__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1600 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w, {{ section.settings.image | image_url: width: 2000 }} 2000w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
            sizes="(max-width: 991px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.eyebrow }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
          >
        {%- else -%}
          <div class="lp-hero__image-placeholder">[ Produktbilde ]</div>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{%- comment -%} ── Inline styles for new hero elements ── {%- endcomment -%}
<style>
  /* CHANGE 3 — warm subtext */
  .lp-hero__text--warm {
    color: #8a6a5a;
    font-style: italic;
  }

  /* CHANGE 4 — star rating */
  .lp-hero__rating {
    font-family: 'sofia-pro', Assistant, sans-serif;
    font-size: 0.85rem;
    color: #666;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .lp-hero__rating-stars {
    letter-spacing: 1px;
  }

  /* CHANGE 6 — hero CTA size bump */
  .lp-btn--hero {
    padding: 18px 36px;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
  }

  /* CHANGE 7 — Klarna monthly in meta */
  .lp-hero__klarna {
    font-family: 'sofia-pro', Assistant, sans-serif;
    font-size: 0.8rem;
    color: #888;
    margin: 4px 0 0;
    display: block;
    width: 100%;
  }

  /* CHANGE 8 — Klarna line in value box */
  .lp-value-box__klarna {
    font-family: 'sofia-pro', Assistant, sans-serif;
    font-size: 0.78rem;
    color: #999;
    margin: 4px 0 8px;
    font-style: italic;
  }

  /* CHANGE 10 — Mobile sticky CTA */
  .lp-hero__sticky-cta {
    display: none;
  }

  @media (max-width: 768px) {
    .lp-hero {
      padding-bottom: 80px;
    }
    .lp-hero__sticky-cta {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: #fff;
      padding: 12px 16px;
      box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
      justify-content: center;
    }
    .lp-btn--sticky {
      width: 100%;
      max-width: 480px;
      padding: 16px;
      font-size: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "LP Hero",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-bilde"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-tekst",
      "default": "Skinora® Radiance Face"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Tittel",
      "default": "Få klinikkresultater hjemme – på bare 10 minutter om dagen"
    },
    {
      "type": "header",
      "content": "Undertekst"
    },
    {
      "type": "text",
      "id": "text_line_1",
      "label": "Undertekst linje 1",
      "default": "Klinisk dokumentert LED-teknologi – brukt av hudterapeuter verden over."
    },
    {
      "type": "text",
      "id": "text_line_2",
      "label": "Undertekst linje 2 (varm/italic)",
      "default": "10 minutter, 3–5 ganger i uken. Resultater du kan se."
    },
    {
      "type": "header",
      "content": "Kulepunkter"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Kulepunkt 1 (HTML tillatt)",
      "default": "<strong>Rødt + dNIR (1072 nm)</strong> · 10 minutter, 3-5x/uke. Resultater du kan se."
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Kulepunkt 2 (HTML tillatt)",
      "default": "Ny generasjon <strong>dNIR:</strong> 1072 nm"
    },
    {
      "type": "text",
      "id": "bullet_disclaimer",
      "label": "Disclaimer under kulepunkt 2",
      "default": "Teknisk spesifikasjon. Resultater varierer."
    },
    {
      "type": "header",
      "content": "Stjerne- og tillitselementer"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating-tekst (etter stjernene)",
      "default": "<strong>4.8/5</strong> – basert på 102 anmeldelser"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA-knapptekst",
      "default": "Få synlige resultater hjemme →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-lenke"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Vis sekundærlenke",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Sekundærlenke tekst",
      "default": "Se hvordan den brukes (60 sek) ↓"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Sekundærlenke URL"
    },
    {
      "type": "header",
      "content": "Verdiboks"
    },
    {
      "type": "text",
      "id": "value_title",
      "label": "Tittel (navn + pris)",
      "default": "Skinora® Clear — 4 390 kr"
    },
    {
      "type": "text",
      "id": "value_tag",
      "label": "Tag-linje (uppercase)",
      "default": "ENGANGSKJØP · INGEN ABONNEMENT"
    },
    {
      "type": "text",
      "id": "value_sub_text",
      "label": "Undertekst (italic)",
      "default": "Profesjonell klinikkteknologi – hjemme, på dine premisser"
    },
    {
      "type": "text",
      "id": "value_roi_line",
      "label": "ROI-linje (bold)",
      "default": "✓ Tilsvarer ca. 8 klinikkøkter"
    },
    {
      "type": "text",
      "id": "value_roi_sub",
      "label": "ROI-undertekst (italic)",
      "default": "Etter det er klinikkbehandlingen i praksis gratis"
    },
    {
      "type": "checkbox",
      "id": "show_value_icon",
      "label": "Vis ✓ ikon i tittel",
      "default": true
    },
    {
      "type": "header",
      "content": "Verdi-bullets"
    },
    {
      "type": "text",
      "id": "value_bullet_1",
      "label": "Bullet 1",
      "default": "Klinisk dokumentert LED-teknologi"
    },
    {
      "type": "text",
      "id": "value_bullet_2",
      "label": "Bullet 2",
      "default": "60 dagers fornøydgaranti"
    },
    {
      "type": "text",
      "id": "value_bullet_3",
      "label": "Bullet 3",
      "default": "2 års reklamasjonsrett"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Pill-tekst",
          "default": "Gratis frakt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Hero",
      "blocks": [
        { "type": "pill", "settings": { "text": "CE-sertifisert" } },
        { "type": "pill", "settings": { "text": "60 dagers fornøydgaranti" } },
        { "type": "pill", "settings": { "text": "Dermatologisk testet" } }
      ]
    }
  ]
}
{% endschema %}
