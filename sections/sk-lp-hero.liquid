{%- comment -%}
  sk-lp-hero.liquid
  Hero section with image, title, copy, pills and CTA for landing pages.
  Pills are dynamic blocks so each LP can customise them.
{%- endcomment -%}

{%- comment -%} LCP preload — browser discovers image before CSS blocks {%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 800 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
    imagesizes="(max-width: 991px) 100vw, 50vw"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign monthly_price = sk_lp_product.price | divided_by: 100 | divided_by: 36 | round -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Hero -->
<div class="sk-lp">
  <section class="lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 2 — Headline {%- endcomment -%}
        <h1 class="lp-hero__title">{{ section.settings.title }}</h1>

        {%- comment -%} CHANGE 3 — Split subtext {%- endcomment -%}
        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}
        {%- if section.settings.text_line_2 != blank -%}
          <p class="lp-hero__text lp-hero__text--warm">{{ section.settings.text_line_2 }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 5 — Trust pills above CTA {%- endcomment -%}
        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} CHANGE 4 — Star rating {%- endcomment -%}
        {%- if section.settings.rating_text != blank -%}
          <div class="lp-hero__rating">
            <span class="lp-hero__rating-stars">★★★★★</span>
            <span class="lp-hero__rating-score">4.8/5</span>
            <span class="lp-hero__rating-count">– 102 anmeldelser</span>
          </div>
        {%- endif -%}

        <p class="lp-hero__testimonial-snippet" style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-style:italic;color:#5f5f5f;margin:0 0 14px;max-width:420px;">
          "Etter 6 uker merker jeg virkelig forskjell på hudtonen – huden ser friskere ut."
          <strong style="font-style:normal;color:#30273e;">— Wenche S., 52, Oslo · Verifisert kjøper</strong>
        </p>

        {%- comment -%} CHANGE 6 — CTA button {%- endcomment -%}
        <div class="lp-hero__actions">
          <button type="button" class="lp-btn lp-btn--hero" data-product-handle="{{ sk_lp_handle }}">
            {{ section.settings.cta_text }}
          </button>
          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} ═══ BLOCK 1: PAYMENT CLARITY ═══ {%- endcomment -%}
        <div class="lp-purchase-meta">
          <div class="lp-purchase-meta__price-row">
            <span class="lp-purchase-meta__price">{{ sk_lp_product.price | money_without_trailing_zeros }}</span>
            <span class="lp-purchase-meta__klarna"
              >eller fra <strong>{{ monthly_price }} kr/mnd</strong> med Klarna</span
            >
          </div>

          <div class="lp-purchase-meta__icons">
            {%- assign lp_allowed = 'visa,master,klarna' | split: ',' -%}
            {%- for type in shop.enabled_payment_types -%}
              {%- if lp_allowed contains type -%}
                <li class="lp-payment-icons__item">{{ type | payment_type_svg_tag }}</li>
              {%- endif -%}
            {%- endfor -%}
            {%- if settings.show_vipps_payment_icon -%}
              <li class="lp-payment-icons__item">
                <img src="{{ 'icon-vipps.svg' | asset_url }}" alt="Vipps" height="22" width="55">
              </li>
            {%- endif -%}
          </div>

          <ul class="lp-purchase-meta__safety">
            <li>✔ Rentefri delbetaling</li>
            <li>✔ 60 dagers fornøydgaranti</li>
            <li>✔ Gratis frakt · 2–4 virkedager</li>
          </ul>
        </div>

        {%- comment -%} ═══ BLOCK 2: VALUE JUSTIFICATION (ROI anchor) ═══ {%- endcomment -%}
        <div class="lp-value-justify">
          <p class="lp-value-justify__headline">Et klinikkresultat – uten klinikkpris</p>
          <p class="lp-value-justify__body">
            En LED-behandling i klinikk koster typisk 800–1.500 kr per økt.<br>
            Skinora® Radiance Face tilsvarer opptil 6 behandlinger – og kan brukes ubegrenset hjemme.
          </p>
          <p class="lp-value-justify__payoff">→ Investeringen betaler seg selv etter få uker.</p>
          <table class="lp-value-table" style="width:100%;border-collapse:collapse;margin-top:12px;font-family:sofia-pro,Assistant,sans-serif;font-size:13px;">
            <thead>
              <tr>
                <th style="text-align:left;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;"></th>
                <th style="text-align:center;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;">Klinikk</th>
                <th style="text-align:center;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;">Skinora</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="padding:6px 8px;color:#5f5f5f;">Kostnad</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">800–1500 kr/økt</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">4.690 kr én gang</td>
              </tr>
              <tr style="background:#f0ede8;">
                <td style="padding:6px 8px;color:#5f5f5f;">Behandlinger</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">Betaler hver gang</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">Ubegrenset</td>
              </tr>
              <tr>
                <td style="padding:6px 8px;color:#5f5f5f;">Bekvemmelighet</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">Tidsbestilling</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">Hjemme, når du vil</td>
              </tr>
            </tbody>
          </table>
        </div>

        {%- comment -%} ═══ BLOCK 3: PREMIUM PROOF (clinical authority checklist) ═══ {%- endcomment -%}
        <ul class="lp-proof-list">
          <li class="lp-proof-list__item">Klinisk dokumentert LED-teknologi</li>
          <li class="lp-proof-list__item">3 målrettede bølgelengder - ingen unødvendige lysfarger</li>
          <li class="lp-proof-list__item">1072 nm dypt nær-infrarødt lys (dNIR)</li>
          <li class="lp-proof-list__item">Optimalisert for hudens kollagenproduksjon</li>
          <li class="lp-proof-list__item">Brukt av profesjonelle hudterapeuter</li>
        </ul>

        {%- comment -%} ═══ BLOCK 4: RISK REVERSAL (guarantee) ═══ {%- endcomment -%}
        <div class="lp-risk-reversal">
          <p class="lp-risk-reversal__headline">Prøv hjemme i 60 dager – helt risikofritt</p>
          <p class="lp-risk-reversal__body">
            Bruk masken 3–5 ganger i uken. Ser du ikke forbedring, får du pengene tilbake. Ingen spørsmål. Ingen risiko.
          </p>
        </div>

        {%- comment -%} ═══ BLOCK 5: TRUST PILLS ═══ {%- endcomment -%}
        <ul class="lp-trust-pills">
          <li class="lp-trust-pills__item">✔ Gratis frakt i Norge</li>
          <li class="lp-trust-pills__item">✔ 2 års reklamasjonsrett</li>
          <li class="lp-trust-pills__item">✔ Sikker betaling</li>
          <li class="lp-trust-pills__item">✔ Norsk kundeservice</li>
        </ul>

        {%- comment -%} ═══ MERGED: Mini Trust Bar (formerly standalone section) ═══ {%- endcomment -%}
        {%- assign trustbar_items = section.blocks | where: 'type', 'trustbar_item' -%}
        {%- if trustbar_items.size > 0 -%}
          <section class="lp-trustbar">
            <div class="lp-container">
              <div class="lp-trustbar__grid">
                {%- for block in trustbar_items -%}
                  <div class="lp-trustbar__item" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <span class="lp-trustbar__icon"
                        ><img
                          src="{{ block.settings.icon | image_url: height: 96 }}"
                          alt=""
                          width="48"
                          height="48"
                          loading="lazy"
                      ></span>
                    {%- endif -%}
                    <span class="lp-trustbar__text">{{ block.settings.text }}</span>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </section>
        {%- endif -%}

        {%- comment -%} CHANGE 10 — Mobile sticky CTA {%- endcomment -%}
        <div class="lp-hero__sticky-cta">
          <button type="button" class="lp-btn lp-btn--sticky" data-product-handle="{{ sk_lp_handle }}">
            {{ section.settings.cta_text }}
          </button>
          <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:11px;color:#5f5f5f;margin:4px 0 0;text-align:center;">
            Fra 130 kr/mnd med Klarna · 60 dagers garanti
          </p>
        </div>
      </div>

      <div class="lp-hero__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 991px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.eyebrow }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <div class="lp-hero__image-placeholder">[ Produktbilde ]</div>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{%- comment -%} ── Inline styles for new hero elements ── {%- endcomment -%}
<style>
  /* CHANGE 3 — warm subtext */
  .lp-hero__text--warm {
    color: #8a6a5a;
    font-style: italic;
  }

  /* FIX 1 — Star rating */
  .lp-hero__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 14px;
    flex-wrap: wrap;
  }
  .lp-hero__rating-stars {
    font-size: 18px;
    color: #d4a843;
    letter-spacing: 2px;
    line-height: 1;
  }
  .lp-hero__rating-score {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #30273e;
  }
  .lp-hero__rating-count {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #5f5f5f;
  }

  /* CHANGE 6 — hero CTA size bump */
  .lp-btn--hero {
    padding: 18px 36px;
    font-size: 17px;
    letter-spacing: 0.04em;
  }

  /* ─── BLOCK 1: Payment Clarity ─── */
  .lp-purchase-meta {
    margin-top: 16px;
    padding: 16px 20px;
    background: #f8f8f8;
    border-radius: 6px;
    max-width: 480px;
  }

  .lp-purchase-meta__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .lp-purchase-meta__price {
    font-family: freight-text-pro, freight-text-pro-fallback, 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #30273e;
  }

  .lp-purchase-meta__klarna {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #5f5f5f;
  }

  .lp-purchase-meta__klarna strong {
    font-weight: 600;
    color: #30273e;
  }

  .lp-purchase-meta__icons {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .lp-purchase-meta__safety {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }

  .lp-purchase-meta__safety li {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #30273e;
  }

  /* ─── BLOCK 2: Value Justification ─── */
  .lp-value-justify {
    margin-top: 20px;
    padding: 18px 20px;
    border-left: 4px solid #30273e;
    background: #f8f8f8;
    max-width: 480px;
  }

  .lp-value-justify__headline {
    font-family: freight-text-pro, freight-text-pro-fallback, 'Playfair Display', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: #3a3448;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .lp-value-justify__body {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #5f5f5f;
    line-height: 1.6;
    margin: 0 0 8px;
  }

  .lp-value-justify__payoff {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #30273e;
    margin: 0;
  }

  /* ─── BLOCK 3: Premium Proof ─── */
  .lp-proof-list {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lp-proof-list__item {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #333;
    padding-left: 20px;
    position: relative;
  }

  .lp-proof-list__item::before {
    content: '✔';
    position: absolute;
    left: 0;
    color: #30273e;
    font-weight: 700;
  }

  /* ─── BLOCK 4: Risk Reversal ─── */
  .lp-risk-reversal {
    margin-top: 20px;
    padding: 14px 20px;
    background: #f0ede8;
    border-radius: 4px;
    max-width: 480px;
  }

  .lp-risk-reversal__headline {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #30273e;
    margin: 0 0 4px;
  }

  .lp-risk-reversal__body {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #5f5f5f;
    line-height: 1.5;
    margin: 0;
  }

  /* ─── BLOCK 5: Trust Pills ─── */
  .lp-trust-pills {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    max-width: 480px;
  }

  .lp-trust-pills__item {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #5f5f5f;
  }

  /* CHANGE 10 — Mobile sticky CTA */
  .lp-hero__sticky-cta {
    display: none;
  }

  /* ─── P2: Defer off-screen content rendering on mobile ─── */
  @media (max-width: 991px) {
    .lp-value-justify,
    .lp-proof-list,
    .lp-risk-reversal,
    .lp-trust-pills {
      content-visibility: auto;
      contain-intrinsic-size: auto 120px;
    }
  }

  @media (max-width: 768px) {
    .lp-hero {
      padding-bottom: 80px;
    }
    .lp-hero__sticky-cta {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: #fff;
      padding: 12px 16px;
      box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
      justify-content: center;
    }
    .lp-btn--sticky {
      width: 100%;
      max-width: 480px;
      padding: 16px;
      font-size: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "LP Hero",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-bilde"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-tekst",
      "default": "Skinora® Radiance Face"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Tittel",
      "default": "Få klinikkresultater hjemme – på bare 10 minutter om dagen"
    },
    {
      "type": "header",
      "content": "Undertekst"
    },
    {
      "type": "text",
      "id": "text_line_1",
      "label": "Undertekst linje 1",
      "default": "Klinisk dokumentert LED-teknologi – brukt av hudterapeuter verden over."
    },
    {
      "type": "text",
      "id": "text_line_2",
      "label": "Undertekst linje 2 (varm/italic)",
      "default": "10 minutter, 3–5 ganger i uken. Resultater du kan se."
    },
    {
      "type": "header",
      "content": "Kulepunkter"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Kulepunkt 1 (HTML tillatt)",
      "default": "<strong>Rødt + dNIR (1072 nm)</strong> · 10 minutter, 3-5x/uke. Resultater du kan se."
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Kulepunkt 2 (HTML tillatt)",
      "default": "Ny generasjon <strong>dNIR:</strong> 1072 nm"
    },
    {
      "type": "text",
      "id": "bullet_disclaimer",
      "label": "Disclaimer under kulepunkt 2",
      "default": "Teknisk spesifikasjon. Resultater varierer."
    },
    {
      "type": "header",
      "content": "Stjerne- og tillitselementer"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating-tekst (etter stjernene)",
      "default": "<strong>4.8/5</strong> – basert på 102 anmeldelser"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA-knapptekst",
      "default": "Få synlige resultater hjemme →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-lenke"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Vis sekundærlenke",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Sekundærlenke tekst",
      "default": "Se hvordan den brukes (60 sek) ↓"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Sekundærlenke URL"
    },
    {
      "type": "header",
      "content": "Verdiboks"
    },
    {
      "type": "text",
      "id": "value_title",
      "label": "Tittel (navn + pris)",
      "default": "Skinora® Clear — 4 390 kr"
    },
    {
      "type": "text",
      "id": "value_tag",
      "label": "Tag-linje (uppercase)",
      "default": "ENGANGSKJØP · INGEN ABONNEMENT"
    },
    {
      "type": "text",
      "id": "value_sub_text",
      "label": "Undertekst (italic)",
      "default": "Profesjonell klinikkteknologi – hjemme, på dine premisser"
    },
    {
      "type": "text",
      "id": "value_roi_line",
      "label": "ROI-linje (bold)",
      "default": "✓ Tilsvarer ca. 8 klinikkøkter"
    },
    {
      "type": "text",
      "id": "value_roi_sub",
      "label": "ROI-undertekst (italic)",
      "default": "Etter det er klinikkbehandlingen i praksis gratis"
    },
    {
      "type": "checkbox",
      "id": "show_value_icon",
      "label": "Vis ✓ ikon i tittel",
      "default": true
    },
    {
      "type": "header",
      "content": "Verdi-bullets"
    },
    {
      "type": "text",
      "id": "value_bullet_1",
      "label": "Bullet 1",
      "default": "Klinisk dokumentert LED-teknologi"
    },
    {
      "type": "text",
      "id": "value_bullet_2",
      "label": "Bullet 2",
      "default": "60 dagers fornøydgaranti"
    },
    {
      "type": "text",
      "id": "value_bullet_3",
      "label": "Bullet 3",
      "default": "2 års reklamasjonsrett"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Pill-tekst",
