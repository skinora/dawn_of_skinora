{%- comment -%}
  sk-lp-hero.liquid
  Hero section with image, title, copy, pills and CTA for landing pages.
  Pills are dynamic blocks so each LP can customise them.
{%- endcomment -%}

{%- comment -%} LCP preload — browser discovers image before CSS blocks {%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 800 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
    imagesizes="(max-width: 991px) 100vw, 50vw"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign sk_lp_variant = sk_lp_product.selected_or_first_available_variant -%}
{%- assign monthly_price = sk_lp_product.price | plus: 0.0 | divided_by: 100.0 | divided_by: 36.0 | round -%}
{%- assign cost_per_treatment = sk_lp_product.price | plus: 0.0 | divided_by: 100.0 | divided_by: 156.0 | round -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Hero -->
<div class="sk-lp">
  <section class="lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 2 — Headline (max 2 linjer) {%- endcomment -%}
        <h1 class="lp-hero__title">{{ section.settings.title }}</h1>

        {%- comment -%} Trust line — clinical credibility {%- endcomment -%}
        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}

        {%- comment -%} Aspirational line — warm italic serif {%- endcomment -%}
        {%- if section.settings.text_line_2 != blank -%}
          <p class="lp-hero__text lp-hero__text--warm">{{ section.settings.text_line_2 }}</p>
        {%- endif -%}

        {%- comment -%} Star rating — between aspirational line and emotional quote {%- endcomment -%}
        {%- if section.settings.rating_text != blank -%}
          <div class="lp-hero__rating">
            <span class="lp-hero__rating-stars" aria-hidden="true">★★★★★</span>
            <span class="lp-hero__rating-score">{{ section.settings.rating_score | default: '4.7' }}/5</span>
            <span class="lp-hero__rating-sep" aria-hidden="true">·</span>
            <span class="lp-hero__rating-count">
              {{- section.settings.review_count | default: '89' }} verifiserte kunder</span
            >
          </div>
        {%- endif -%}

        {%- if section.settings.testimonial_quote != blank -%}
          <p class="lp-hero__testimonial-snippet">
            “{{ section.settings.testimonial_quote }}”
            <strong>— {{ section.settings.testimonial_author }}</strong>
          </p>
        {%- endif -%}

        {%- comment -%} CHANGE 6 — CTA button (now directly after the emotional quote) {%- endcomment -%}
        <div class="lp-hero__actions">
          <form
            action="{{ routes.cart_add_url }}"
            method="post"
            enctype="multipart/form-data"
            class="lp-cta-form"
            data-cta="hero"
          >
            <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="lp-btn lp-btn--hero"
              data-product-handle="{{ sk_lp_handle }}"
              aria-label="{{ section.settings.cta_text }}"
            >
              {{ section.settings.cta_text }}
            </button>
          </form>
          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Urgency indicator {%- endcomment -%}
        {%- if section.settings.show_urgency and section.settings.urgency_text != blank -%}
          <p class="lp-urgency-hero">
            {{ section.settings.urgency_text }}
          </p>
        {%- endif -%}

        {%- comment -%} Trust pills directly under the CTA — the only above-fold price reference lives here {%- endcomment -%}
        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills lp-hero__pills--under-cta">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} ═══ BLOCK 1: PAYMENT CLARITY (Klarna-led, full price deferred) ═══ {%- endcomment -%}
        <div class="lp-purchase-meta">
          <div class="lp-purchase-meta__price-row">
            <span class="lp-purchase-meta__price"
              >Fra <strong>{{ monthly_price }} kr/mnd</strong> med Klarna</span
            >
            <span class="lp-purchase-meta__klarna">Delbetaling tilgjengelig ved kassen</span>
          </div>
          <div class="lp-purchase-meta__per-treatment">
            <p class="lp-purchase-meta__per-treatment-main">
              Brukt 3x/uke i 1 år = kun
              <span class="lp-purchase-meta__per-treatment-value">{{ cost_per_treatment }} kr</span> per behandling
            </p>
            <p class="lp-purchase-meta__per-treatment-sub">Én gang betalt – ubegrenset bruk</p>
          </div>

          <div class="lp-purchase-meta__icons">
            {%- assign lp_allowed = 'visa,master,klarna' | split: ',' -%}
            {%- for type in shop.enabled_payment_types -%}
              {%- if lp_allowed contains type -%}
                <li class="lp-payment-icons__item">{{ type | payment_type_svg_tag }}</li>
              {%- endif -%}
            {%- endfor -%}
            {%- if settings.show_vipps_payment_icon -%}
              <li class="lp-payment-icons__item">
                <img src="{{ 'icon-vipps.svg' | asset_url }}" alt="Vipps" height="22" width="55" fetchpriority="low">
              </li>
            {%- endif -%}
          </div>

          <ul class="lp-purchase-meta__safety">
            <li>✔ 60 dagers fornøydgaranti</li>
            <li>✔ Gratis frakt · 2–4 virkedager</li>
            <li>✔ Norsk kundeservice</li>
          </ul>
        </div>

        {%- comment -%} BLOCK 2 (clinic price comparison) extracted to sections/skinora-clinic-comparison.liquid {%- endcomment -%}

        {%- comment -%}
          BLOCK 3b (engangspris-boks på 4 390 kr) FJERNET fra above-fold per hierarki-fix.
          Engangsprisen vises nå utelukkende i klinikk-sammenligningen lenger ned på siden,
          der konteksten gjør den til en gevinst, ikke en barriere.
        {%- endcomment -%}

        {%- comment -%} ═══ BLOCK 3: PREMIUM PROOF — relocated before Pain section ═══ {%- endcomment -%}

        {%- comment -%} ═══ BLOCK 4: RISK REVERSAL (guarantee) ═══ {%- endcomment -%}
        <div class="lp-risk-reversal">
          <p class="lp-risk-reversal__headline">Prøv hjemme i 60 dager – helt risikofritt</p>
          <p class="lp-risk-reversal__body">
            Bruk masken 3–5 ganger i uken. Ser du ikke forbedring, får du pengene tilbake. Ingen spørsmål. Ingen risiko.
          </p>
        </div>

        {%- comment -%} ═══ BLOCK 5: TRUST PILLS ═══ {%- endcomment -%}
        <ul class="lp-trust-pills">
          <li class="lp-trust-pills__item">✔ Gratis frakt i Norge</li>
          <li class="lp-trust-pills__item">✔ 2 års reklamasjonsrett</li>
          <li class="lp-trust-pills__item">✔ Sikker betaling</li>
          <li class="lp-trust-pills__item">✔ Norsk kundeservice</li>
        </ul>

        {%- comment -%} ═══ MERGED: Mini Trust Bar (formerly standalone section) ═══ {%- endcomment -%}
        {%- assign trustbar_items = section.blocks | where: 'type', 'trustbar_item' -%}
        {%- if trustbar_items.size > 0 -%}
          <section class="lp-trustbar">
            <div class="lp-container">
              <div class="lp-trustbar__grid">
                {%- for block in trustbar_items -%}
                  <div class="lp-trustbar__item" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <span class="lp-trustbar__icon"
                        ><img
                          src="{{ block.settings.icon | image_url: height: 96 }}"
                          alt=""
                          role="presentation"
                          width="48"
                          height="48"
                          loading="lazy"
                      ></span>
                    {%- endif -%}
                    <span class="lp-trustbar__text">{{ block.settings.text }}</span>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </section>
        {%- endif -%}
      </div>

      <div class="lp-hero__image">
        {%- comment -%} Hero media: video file > video URL > image fallback {%- endcomment -%}
        {%- assign hero_video = section.settings.hero_video_file -%}
        {%- assign hero_video_url = section.settings.hero_video_url -%}
        {%- assign hero_poster = section.settings.hero_video_poster | default: section.settings.image -%}
        {%- if hero_video != blank -%}
          {%- assign hero_mp4 = hero_video.sources | where: 'format', 'mp4' | first -%}
          <div
            class="lp-hero__media-wrap"
            style="position:relative;width:100%;aspect-ratio:{% if section.settings.image %}{{ section.settings.image.width }} / {{ section.settings.image.height }}{% else %}4 / 5{% endif %};overflow:hidden;border-radius:6px;"
          >
            <video
              class="lp-hero__video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label="Skinora Clear LED-maske i bruk"
              {% if hero_poster != blank %}
                poster="{{ hero_poster | image_url: width: 1200 }}"
              {% endif %}
              style="width:100%;height:100%;object-fit:cover;display:block;"
              data-hero-video
            >
              {%- if hero_mp4 -%}
                <source src="{{ hero_mp4.url }}" type="video/mp4">
              {%- else -%}
                {%- for source in hero_video.sources -%}
                  <source src="{{ source.url }}" type="video/{{ source.format }}">
                {%- endfor -%}
              {%- endif -%}
            </video>
          </div>
          <script>
            (function () {
              if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                document.querySelectorAll('[data-hero-video]').forEach(function (v) {
                  v.removeAttribute('autoplay');
                  try {
                    v.pause();
                  } catch (e) {}
                });
              }
            })();
          </script>
        {%- elsif hero_video_url != blank -%}
          {%- assign yt_id = '' -%}
          {%- assign vimeo_id = '' -%}
          {%- if hero_video_url contains 'youtube' or hero_video_url contains 'youtu.be' -%}
            {%- assign yt_id = hero_video_url | split: 'v=' | last | split: '&' | first | split: '/' | last -%}
          {%- elsif hero_video_url contains 'vimeo' -%}
            {%- assign vimeo_id = hero_video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
          {%- endif -%}
          <div
            class="lp-hero__media-wrap"
            style="position:relative;width:100%;aspect-ratio:16 / 9;overflow:hidden;border-radius:6px;"
          >
            {%- if yt_id != '' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&modestbranding=1&playsinline=1"
                title="Skinora Clear LED-maske i bruk"
                aria-label="Skinora Clear LED-maske i bruk"
                frameborder="0"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
              ></iframe>
            {%- elsif vimeo_id != '' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1"
                title="Skinora Clear LED-maske i bruk"
                aria-label="Skinora Clear LED-maske i bruk"
                frameborder="0"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
              ></iframe>
            {%- endif -%}
          </div>
        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 991px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.title }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            fetchpriority="high"
            decoding="async"
          >
        {%- else -%}
          <div class="lp-hero__image-placeholder">[ Produktbilde ]</div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Mobile sticky CTA — outside grid for proper fixed positioning {%- endcomment -%}
    <div class="lp-hero__sticky-cta" id="lp-sticky-cta" aria-hidden="true">
      <form
        action="{{ routes.cart_add_url }}"
        method="post"
        enctype="multipart/form-data"
        class="lp-cta-form"
        data-cta="sticky"
      >
        <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button
          type="submit"
          class="lp-btn lp-btn--sticky"
          data-product-handle="{{ sk_lp_handle }}"
          aria-label="{{ section.settings.sticky_cta_text | default: section.settings.cta_text }}"
        >
          {{ section.settings.sticky_cta_text | default: section.settings.cta_text }}
        </button>
      </form>
      <p class="lp-hero__sticky-cta-meta">
        Fra {{ monthly_price }} kr/mnd med Klarna · 60 dagers garanti
      </p>
    </div>
  </section>
</div>

<script>
  (function initStickyCtaScroll() {
    var sticky = document.getElementById('lp-sticky-cta');
    if (!sticky) return;
    var hero = document.querySelector('.lp-hero__actions');
    if (!hero) return;
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            sticky.classList.remove('lp-hero__sticky-cta--visible');
            sticky.setAttribute('aria-hidden', 'true');
          } else {
            sticky.classList.add('lp-hero__sticky-cta--visible');
            sticky.setAttribute('aria-hidden', 'false');
          }
        });
      },
      { threshold: 0 }
    );
    observer.observe(hero);
  })();
</script>

{%- comment -%} ── Inline styles for new hero elements ── {%- endcomment -%}
<style>
  /* ============================================================
     PHASE 4 — Rating row (stars + score + count)
     ============================================================ */
  .lp-hero__rating {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .lp-hero__rating-stars {
    font-size: 18px;
    line-height: 1;
    letter-spacing: 2px;
    color: var(--accent-gold);
  }
  .lp-hero__rating-score {
    font-family: var(--ff-serif);
    font-size: var(--fs-lg);
    font-weight: var(--fw-medium);
    line-height: 1;
    color: var(--ink-900);
    letter-spacing: var(--tracking-tight);
  }
  .lp-hero__rating-count {
    font-family: var(--ff-sans);
    font-size: var(--fs-sm);
    font-weight: var(--fw-regular);
    color: var(--ink-500);
  }
  .lp-hero__rating-sep {
    color: var(--ink-300);
    font-weight: var(--fw-semibold);
    margin: 0 2px;
  }

  /* ============================================================
     PHASE 4 — CTA full-width on mobile, pills inline-flex
     ============================================================ */
  .lp-hero__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    width: 100%;
  }
  .lp-btn--hero {
    display: inline-flex;
    width: 100%;
    max-width: 420px;
    min-height: 60px;
    padding: 18px 44px;
    font-size: 18px;
    letter-spacing: 0.04em;
  }

  .lp-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);                /* 16 between pills */
    align-items: center;
  }
  .lp-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;                            /* check → label */
    /* No background, no border — clean inline marks */
  }

  /* ============================================================
     PHASE 6 — Testimonial snippet (editorial pull-quote)
     ============================================================ */
  .lp-hero__testimonial-snippet {
    font-family: var(--ff-serif);
    font-size: var(--fs-md);
    font-weight: var(--fw-regular);
    font-style: italic;
    line-height: 1.55;
    color: var(--ink-700);
    padding-left: var(--space-3);
    border-left: 2px solid var(--accent-clay);
  }
  .lp-hero__testimonial-snippet strong {
    display: block;
    margin-top: var(--space-2);
    font-family: var(--ff-sans);
    font-style: normal;
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--ink-700);
  }

  /* ============================================================
     PHASE 7 — Urgency + purchase meta (flattened to match copy edge)
     ============================================================ */
  .lp-urgency-hero {
    font-family: var(--ff-sans);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    line-height: 1.4;
    letter-spacing: 0;
    color: var(--accent-clay);
  }

  /* Container — stripped of box, sits flush on copy edge */
  .lp-purchase-meta {
    margin: 0;
    padding: 0;
    background: none;
    border-radius: 0;
  }

  .lp-purchase-meta__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
  }

  .lp-purchase-meta__price {
    font-family: var(--ff-serif);
    font-size: var(--fs-xl);
    font-weight: var(--fw-medium);
    line-height: 1.3;
    color: var(--ink-900);
    letter-spacing: var(--tracking-normal);
  }
  .lp-purchase-meta__price strong {
    font-family: var(--ff-serif);
    font-weight: var(--fw-semibold);
    color: var(--ink-900);
  }

  .lp-purchase-meta__klarna {
    font-family: var(--ff-sans);
    font-size: var(--fs-sm);
    font-weight: var(--fw-regular);
    color: var(--ink-500);
  }
  .lp-purchase-meta__klarna strong {
    font-weight: var(--fw-semibold);
    color: var(--ink-700);
  }

  /* Per-treatment callout — vertical padding only, no horizontal indent */
  .lp-purchase-meta__per-treatment {
    padding: var(--space-3) 0;
    background: none;
    border-left: none;
