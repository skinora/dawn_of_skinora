  }
  .lp-risk-reversal__body {
    font-family: var(--ff-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-regular);
    color: var(--ink-500);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── BLOCK 5: Trust Pills ─── */
  .lp-trust-pills {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    max-width: 480px;
  }
  .lp-trust-pills__item {
    font-family: var(--ff-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-regular);
    color: var(--ink-500);
  }

  /* ============================================================
     PHASE 3 — Vertical rhythm (4 values only: 8, 16, 24, 48)
     All elements use margin-bottom only. No top margins.
     ============================================================ */
  .lp-eyebrow                              { margin: 0 0 var(--space-2); }
  .lp-hero__title                          { margin: 0 0 var(--space-5); }
  .lp-hero__text                           { margin: 0 0 var(--space-3); }
  .lp-hero__text--warm                     { margin: 0 0 var(--space-5); }
  .lp-hero__rating                         { margin: 0 0 var(--space-4); }
  .lp-hero__testimonial-snippet            { margin: 0 0 var(--space-6); }
  .lp-hero__actions                        { margin: 0 0 var(--space-3); }
  .lp-urgency-hero                         { margin: 0 0 var(--space-5); }
  .lp-hero__pills                          { margin: 0 0 var(--space-6); }
  .lp-purchase-meta__price-row             { margin: 0 0 var(--space-2); }
  .lp-purchase-meta__klarna                { margin: 0 0 var(--space-5); }
  .lp-purchase-meta__per-treatment         { margin: 0 0 var(--space-5); }
  .lp-purchase-meta__icons                 { margin: 0 0 var(--space-3); }
  .lp-purchase-meta__safety                { margin: 0; }

  /* ============================================================
     PHASE 5 — Image → copy transition on mobile
     ============================================================ */
  @media (max-width: 768px) {
    .lp-hero__image,
    .lp-hero__media-wrap {
      margin: 0;
      display: block;
    }
  }

  /* ============================================================
     PHASE 6 — Reading measures (ch-based)
     Title measure handled by external CSS (14ch mobile / 22ch desktop via .lp-hero__title rule).
     ============================================================ */
  .lp-hero__text,
  .lp-hero__text--warm                     { max-width: 52ch; }
  .lp-hero__testimonial-snippet            { max-width: 48ch; }
  .lp-urgency-hero,
  .lp-purchase-meta__klarna,
  .lp-purchase-meta__safety                { max-width: 52ch; }

  /* ─── Mobile sticky CTA (scroll-triggered) ─── */
  .lp-hero__sticky-cta {
    display: none;
  }
  .lp-hero__sticky-cta-meta {
    font-family: var(--ff-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-regular);
    color: var(--ink-500);
    margin: 4px 0 0;
    text-align: center;
  }

  /* ─── P2: Defer off-screen content rendering on mobile ─── */
  @media (max-width: 991px) {
    .lp-proof-list,
    .lp-risk-reversal,
    .lp-trust-pills {
      content-visibility: auto;
      contain-intrinsic-size: auto 120px;
    }
  }

  @media (max-width: 768px) {
    .lp-hero {
      padding-bottom: 80px;
    }
    .lp-hero__sticky-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: #fff;
      padding: 12px 16px;
      box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
      flex-direction: column;
      align-items: center;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }
    .lp-hero__sticky-cta--visible {
      display: flex;
      transform: translateY(0);
    }
    .lp-btn--sticky {
      width: 100%;
      max-width: 480px;
      padding: 16px;
      font-size: 16px;
      min-height: 52px;
    }
  }
</style>

