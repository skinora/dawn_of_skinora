{%- comment -%}
  sk-lp-hero.liquid
  Hero section with image, title, copy, pills and CTA for landing pages.
  Pills are dynamic blocks so each LP can customise them.
{%- endcomment -%}

{%- comment -%} LCP preload — browser discovers image before CSS blocks {%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 800 }}"
    imagesrcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
    imagesizes="(max-width: 991px) 100vw, 50vw"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.cta_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign sk_lp_variant = sk_lp_product.selected_or_first_available_variant -%}
{%- assign monthly_price = sk_lp_product.price | divided_by: 100 | divided_by: 36 | round -%}
{%- assign cost_per_treatment = sk_lp_product.price | divided_by: 100 | divided_by: 156 | round -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Hero -->
<div class="sk-lp">
  <section class="lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 2 — Headline {%- endcomment -%}
        <h1 class="lp-hero__title">{{ section.settings.title }}</h1>

        {%- comment -%} CHANGE 3 — Split subtext {%- endcomment -%}
        {%- if section.settings.text_line_1 != blank -%}
          <p class="lp-hero__text">{{ section.settings.text_line_1 }}</p>
        {%- endif -%}
        {%- if section.settings.text_line_2 != blank -%}
          <p class="lp-hero__text lp-hero__text--warm">{{ section.settings.text_line_2 }}</p>
        {%- endif -%}

        {%- comment -%} CHANGE 5 — Trust pills above CTA {%- endcomment -%}
        {%- assign pills = section.blocks | where: 'type', 'pill' -%}
        {%- if pills.size > 0 -%}
          <div class="lp-hero__pills">
            {%- for block in pills -%}
              <span class="lp-hero__pill" {{ block.shopify_attributes }}>
                <span class="lp-hero__pill-check">✓</span> {{ block.settings.text }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} CHANGE 4 — Star rating {%- endcomment -%}
        {%- if section.settings.rating_text != blank -%}
          <div class="lp-hero__rating">
            <span class="lp-hero__rating-stars">★★★★★</span>
            <span class="lp-hero__rating-score">{{ section.settings.rating_score | default: '4.8' }}/5</span>
            <span class="lp-hero__rating-count"
              >– {{ section.settings.review_count | default: '102' }} anmeldelser</span
            >
          </div>
        {%- endif -%}

        {%- if section.settings.testimonial_quote != blank -%}
          <p
            class="lp-hero__testimonial-snippet"
            style="font-family:sofia-pro,Assistant,sans-serif;font-size:13px;font-style:italic;color:#5f5f5f;margin:0 0 14px;max-width:420px;"
          >
            "{{ section.settings.testimonial_quote }}"
            <strong style="font-style:normal;color:#30273e;">— {{ section.settings.testimonial_author }}</strong>
          </p>
        {%- endif -%}

        {%- comment -%} CHANGE 6 — CTA button {%- endcomment -%}
        <div class="lp-hero__actions">
          <form
            action="{{ routes.cart_add_url }}"
            method="post"
            enctype="multipart/form-data"
            class="lp-cta-form"
            data-cta="hero"
          >
            <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="lp-btn lp-btn--hero"
              data-product-handle="{{ sk_lp_handle }}"
              aria-label="{{ section.settings.cta_text }}"
            >
              {{ section.settings.cta_text }}
            </button>
          </form>
          {%- if section.settings.show_link and section.settings.link_text != blank -%}
            <a href="{{ section.settings.link_url | default: '#' }}" class="lp-hero__link">
              {{- section.settings.link_text -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Urgency indicator {%- endcomment -%}
        {%- if section.settings.show_urgency and section.settings.urgency_text != blank -%}
          {%- assign sk_qty = sk_lp_variant.inventory_quantity -%}
          {%- if sk_qty != blank and sk_qty > 0 and sk_qty < 50 -%}
            <p class="lp-urgency-hero">⚡ Sendes innen 24 timer · {{ sk_qty }} stk på lager</p>
          {%- elsif sk_qty == blank or sk_qty >= 50 -%}
            <p class="lp-urgency-hero">
              {{ section.settings.urgency_text }}
            </p>
          {%- else -%}
            <p class="lp-urgency-hero">
              {{ section.settings.urgency_text }}
            </p>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} ═══ BLOCK 1: PAYMENT CLARITY ═══ {%- endcomment -%}
        <div class="lp-purchase-meta">
          <div class="lp-purchase-meta__price-row">
            <span class="lp-purchase-meta__price">{{ sk_lp_product.price | money_without_trailing_zeros }}</span>
            <span class="lp-purchase-meta__klarna"
              >eller fra <strong>{{ monthly_price }} kr/mnd</strong> med Klarna</span
            >
          </div>
          <div class="lp-purchase-meta__per-treatment">
            <p class="lp-purchase-meta__per-treatment-main">
              Brukt 3x/uke i 1 år = kun
              <span class="lp-purchase-meta__per-treatment-value">{{ cost_per_treatment }} kr</span> per behandling
            </p>
            <p class="lp-purchase-meta__per-treatment-sub">Én gang betalt – ubegrenset bruk</p>
          </div>

          <div class="lp-purchase-meta__icons">
            {%- assign lp_allowed = 'visa,master,klarna' | split: ',' -%}
            {%- for type in shop.enabled_payment_types -%}
              {%- if lp_allowed contains type -%}
                <li class="lp-payment-icons__item">{{ type | payment_type_svg_tag }}</li>
              {%- endif -%}
            {%- endfor -%}
            {%- if settings.show_vipps_payment_icon -%}
              <li class="lp-payment-icons__item">
                <img src="{{ 'icon-vipps.svg' | asset_url }}" alt="Vipps" height="22" width="55">
              </li>
            {%- endif -%}
          </div>

          <ul class="lp-purchase-meta__safety">
            <li>✔ 60 dagers fornøydgaranti</li>
            <li>✔ Gratis frakt · 2–4 virkedager</li>
            <li>✔ Norsk kundeservice</li>
          </ul>
        </div>

        {%- comment -%} ═══ BLOCK 2: VALUE JUSTIFICATION (ROI anchor) ═══ {%- endcomment -%}
        <div class="lp-value-justify">
          <p class="lp-value-justify__headline">Et klinikkresultat – uten klinikkpris</p>
          <p class="lp-value-justify__body">
            En LED-behandling i klinikk koster typisk 800–1.500 kr per økt.<br>
            {{ section.settings.eyebrow | default: 'Skinora®' }} tilsvarer opptil 6 behandlinger – og kan brukes
            ubegrenset hjemme.
          </p>
          <p class="lp-value-justify__payoff">→ Investeringen betaler seg selv etter få uker.</p>
          <table
            class="lp-value-table"
            style="width:100%;border-collapse:collapse;margin-top:12px;font-family:sofia-pro,Assistant,sans-serif;font-size:13px;"
          >
            <thead>
              <tr>
                <th
                  style="text-align:left;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;"
                ></th>
                <th style="text-align:center;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;">
                  Klinikk
                </th>
                <th style="text-align:center;padding:6px 8px;border-bottom:1px solid #d9d3cc;color:#30273e;font-weight:600;">
                  Skinora
                </th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="padding:6px 8px;color:#5f5f5f;">Kostnad</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">800–1500 kr/økt</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">
                  {{ sk_lp_product.price | money_without_trailing_zeros }} én gang
                </td>
              </tr>
              <tr style="background:#f0ede8;">
                <td style="padding:6px 8px;color:#5f5f5f;">Behandlinger</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">Betaler hver gang</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">Ubegrenset</td>
              </tr>
              <tr>
                <td style="padding:6px 8px;color:#5f5f5f;">Bekvemmelighet</td>
                <td style="text-align:center;padding:6px 8px;color:#5f5f5f;">Tidsbestilling</td>
                <td style="text-align:center;padding:6px 8px;font-weight:600;color:#30273e;">Hjemme, når du vil</td>
              </tr>
            </tbody>
          </table>
        </div>

        {%- comment -%} ═══ BLOCK 3: PREMIUM PROOF — relocated before Pain section ═══ {%- endcomment -%}

        {%- comment -%} ═══ BLOCK 4: RISK REVERSAL (guarantee) ═══ {%- endcomment -%}
        <div class="lp-risk-reversal">
          <p class="lp-risk-reversal__headline">Prøv hjemme i 60 dager – helt risikofritt</p>
          <p class="lp-risk-reversal__body">
            Bruk masken 3–5 ganger i uken. Ser du ikke forbedring, får du pengene tilbake. Ingen spørsmål. Ingen risiko.
          </p>
        </div>

        {%- comment -%} ═══ BLOCK 5: TRUST PILLS ═══ {%- endcomment -%}
        <ul class="lp-trust-pills">
          <li class="lp-trust-pills__item">✔ Gratis frakt i Norge</li>
          <li class="lp-trust-pills__item">✔ 2 års reklamasjonsrett</li>
          <li class="lp-trust-pills__item">✔ Sikker betaling</li>
          <li class="lp-trust-pills__item">✔ Norsk kundeservice</li>
        </ul>

        {%- comment -%} ═══ MERGED: Mini Trust Bar (formerly standalone section) ═══ {%- endcomment -%}
        {%- assign trustbar_items = section.blocks | where: 'type', 'trustbar_item' -%}
        {%- if trustbar_items.size > 0 -%}
          <section class="lp-trustbar">
            <div class="lp-container">
              <div class="lp-trustbar__grid">
                {%- for block in trustbar_items -%}
                  <div class="lp-trustbar__item" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <span class="lp-trustbar__icon"
                        ><img
                          src="{{ block.settings.icon | image_url: height: 96 }}"
                          alt=""
                          role="presentation"
                          width="48"
                          height="48"
                          loading="lazy"
                      ></span>
                    {%- endif -%}
                    <span class="lp-trustbar__text">{{ block.settings.text }}</span>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </section>
        {%- endif -%}
      </div>

      <div class="lp-hero__image">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 991px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: 'Kvinne bruker Skinora Radiance Face LED-maske hjemme' }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          >
        {%- else -%}
          <div class="lp-hero__image-placeholder">[ Produktbilde ]</div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Mobile sticky CTA — outside grid for proper fixed positioning {%- endcomment -%}
    <div class="lp-hero__sticky-cta" id="lp-sticky-cta" aria-hidden="true">
      <form
        action="{{ routes.cart_add_url }}"
        method="post"
        enctype="multipart/form-data"
        class="lp-cta-form"
        data-cta="sticky"
      >
        <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button
          type="submit"
          class="lp-btn lp-btn--sticky"
          data-product-handle="{{ sk_lp_handle }}"
          aria-label="{{ section.settings.sticky_cta_text | default: section.settings.cta_text }}"
        >
          {{ section.settings.sticky_cta_text | default: section.settings.cta_text }}
        </button>
      </form>
      <p style="font-family:sofia-pro,Assistant,sans-serif;font-size:11px;color:#5f5f5f;margin:4px 0 0;text-align:center;">
        Fra {{ monthly_price }} kr/mnd med Klarna · 60 dagers garanti
      </p>
    </div>
  </section>
</div>

<script>
  (function initStickyCtaScroll() {
    var sticky = document.getElementById('lp-sticky-cta');
    if (!sticky) return;
    var hero = document.querySelector('.lp-hero__actions');
    if (!hero) return;
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            sticky.classList.remove('lp-hero__sticky-cta--visible');
            sticky.setAttribute('aria-hidden', 'true');
          } else {
            sticky.classList.add('lp-hero__sticky-cta--visible');
            sticky.setAttribute('aria-hidden', 'false');
          }
        });
      },
      { threshold: 0 }
    );
    observer.observe(hero);
  })();
</script>

{%- comment -%} ── Inline styles for new hero elements ── {%- endcomment -%}
<style>
  /* CHANGE 3 — warm subtext */
  .lp-hero__text--warm {
    color: #8a6a5a;
    font-style: italic;
  }

  /* FIX 1 — Star rating */
  .lp-hero__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 14px;
    flex-wrap: wrap;
  }
  .lp-hero__rating-stars {
    font-size: 18px;
    color: #d4a843;
    letter-spacing: 2px;
    line-height: 1;
  }
  .lp-hero__rating-score {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: #30273e;
  }
  .lp-hero__rating-count {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #5f5f5f;
  }

  /* CHANGE 6 — hero CTA size bump */
  .lp-btn--hero {
    min-height: 60px;
    padding: 18px 44px;
    font-size: 18px;
    letter-spacing: 0.04em;
  }

  /* ─── BLOCK 1: Payment Clarity ─── */
  .lp-purchase-meta {
    margin-top: 16px;
    padding: 16px 20px;
    background: #f8f8f8;
    border-radius: 6px;
    max-width: 480px;
  }

  .lp-purchase-meta__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .lp-purchase-meta__price {
    font-family: freight-text-pro, freight-text-pro-fallback, 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #30273e;
  }

  .lp-purchase-meta__klarna {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #5f5f5f;
  }

  .lp-purchase-meta__klarna strong {
    font-weight: 600;
    color: #30273e;
  }

  .lp-purchase-meta__icons {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .lp-purchase-meta__safety {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }

  .lp-purchase-meta__safety li {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #30273e;
  }

  /* ─── BLOCK 2: Value Justification ─── */
  .lp-value-justify {
    margin-top: 20px;
    padding: 18px 20px;
    /* Action accent on value justification border */
    border-left: 4px solid #a0522d;
    background: #f8f8f8;
    max-width: 480px;
  }

  .lp-value-justify__headline {
    font-family: freight-text-pro, freight-text-pro-fallback, 'Playfair Display', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: #3a3448;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .lp-value-justify__body {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #5f5f5f;
    line-height: 1.6;
    margin: 0 0 8px;
  }

  /* Arrow/payoff line — accent color */
  .lp-value-justify__payoff {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #a0522d;
    margin: 0;
  }

  /* ─── BLOCK 3: Premium Proof ─── */
  .lp-proof-list {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lp-proof-list__item {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #333;
    padding-left: 20px;
    position: relative;
  }

  /* Checkmark accent color */
  .lp-proof-list__item::before {
    content: '✔';
    position: absolute;
    left: 0;
    color: #a0522d;
    font-weight: 700;
  }

  /* ─── BLOCK 4: Risk Reversal ─── */
  .lp-risk-reversal {
    margin-top: 20px;
    padding: 14px 20px;
    background: #f0ede8;
    border-radius: 4px;
    max-width: 480px;
  }

  .lp-risk-reversal__headline {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #30273e;
    margin: 0 0 4px;
  }

  .lp-risk-reversal__body {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #5f5f5f;
    line-height: 1.5;
    margin: 0;
  }

  /* ─── BLOCK 5: Trust Pills ─── */
  .lp-trust-pills {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    max-width: 480px;
  }

  .lp-trust-pills__item {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #5f5f5f;
  }

  /* ─── Urgency indicator ─── */
  .lp-urgency-hero {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #a0522d;
    margin: 8px 0 0;
    max-width: 480px;
  }

  /* ─── Cost per treatment (highlighted callout) ─── */
  .lp-purchase-meta__per-treatment {
    margin: 4px 0 14px;
    padding: 12px 16px;
    background: #f0ede8;
    /* Action accent on per-treatment callout border */
    border-left: 4px solid #a0522d;
    border-radius: 0 4px 4px 0;
  }

  .lp-purchase-meta__per-treatment-main {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #30273e;
    margin: 0;
    line-height: 1.4;
  }

  /* Per-treatment price highlight — accent color */
  .lp-purchase-meta__per-treatment-value {
    font-family: freight-text-pro, freight-text-pro-fallback, 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #a0522d;
  }

  .lp-purchase-meta__per-treatment-sub {
    font-family: sofia-pro, sofia-pro-fallback, Assistant, sans-serif;
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    color: #5f5f5f;
    margin: 4px 0 0;
    line-height: 1.3;
  }

  /* ─── Mobile sticky CTA (scroll-triggered) ─── */
  .lp-hero__sticky-cta {
    display: none;
  }

  /* ─── P2: Defer off-screen content rendering on mobile ─── */
  @media (max-width: 991px) {
    .lp-value-justify,
    .lp-proof-list,
    .lp-risk-reversal,
    .lp-trust-pills {
      content-visibility: auto;
      contain-intrinsic-size: auto 120px;
    }
  }

  @media (max-width: 768px) {
    .lp-hero {
      padding-bottom: 80px;
    }
    .lp-hero__sticky-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: #fff;
      padding: 12px 16px;
      box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
      flex-direction: column;
      align-items: center;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }
    .lp-hero__sticky-cta--visible {
      display: flex;
      transform: translateY(0);
    }
    .lp-btn--sticky {
      width: 100%;
      max-width: 480px;
      padding: 16px;
      font-size: 16px;
      min-height: 52px;
    }
  }
</style>

{% schema %}
{
  "name": "LP Hero",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero-bilde"
    },
