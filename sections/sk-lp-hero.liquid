    font-family: var(--ff-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-regular);
    color: var(--ink-700);
  }

  /* BLOCK 2 (.lp-value-justify*) extracted to sections/skinora-clinic-comparison.liquid */

  /* ─── BLOCK 3: Premium Proof ─── */
  .lp-proof-list {
    list-style: none;
    margin: 20px 0 0;
    padding: 0;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .lp-proof-list__item {
    font-family: var(--ff-sans);
    font-size: var(--fs-xs);
    font-weight: var(--fw-regular);
    color: var(--ink-700);
    padding-left: 20px;
    position: relative;
  }
  .lp-proof-list__item::before {
    content: '✔';
    position: absolute;
    left: 0;
    color: var(--accent-clay);
    font-weight: var(--fw-semibold);
  }

  /* ─── BLOCK 4: Risk Reversal ─── */
  .lp-risk-reversal {
    margin-top: 20px;
