{%- comment -%}
  sk-lp-results-timeline.liquid
  Canonical "results" section for both Clear and Radiance LPs.
  Renders 1–4 before/after comparison sliders with customer attribution.

  Each comparison block:
    - before_image / after_image
    - before_label / after_label (e.g. "UKE 0" / "UKE 8")
    - customer_name, concern_tag, usage_tag (social proof + relevance match)

  Replaces the legacy skinora-results.liquid (Clear) and
  lp-results.liquid (Radiance) — both content models converged on
  the slider pattern because evidence beats description for visual
  outcomes (CurrentBody, Foreo, Solawave all use this).
{%- endcomment -%}

{{ 'section-sk-lp-results-timeline.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-sk-lp-results-timeline.js' | asset_url }}" defer></script>

<div class="sk-lp">
  <section class="lp-results-timeline" aria-labelledby="lp-results-timeline-h-{{ section.id }}">
    <div class="lp-results-timeline__inner">
      <header class="lp-results-timeline__header">
        <h2 id="lp-results-timeline-h-{{ section.id }}" class="lp-section-heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.intro != blank -%}
          <p class="lp-section-intro">{{ section.settings.intro }}</p>
        {%- endif -%}
      </header>

      {%- assign comparisons = section.blocks | where: 'type', 'comparison' -%}
      {%- if comparisons.size > 0 -%}
        <div
          class="lp-results-timeline__grid lp-results-timeline__grid--count-{{ comparisons.size }}"
        >
          {%- for block in comparisons -%}
            {%- assign before_alt = block.settings.before_alt
              | default: block.settings.customer_name
              | default: 'Før'
            -%}
            {%- assign after_alt = block.settings.after_alt
              | default: block.settings.customer_name
              | default: 'Etter'
            -%}
            <article class="lp-comparison" {{ block.shopify_attributes }}>
              <div
                class="lp-comparison__slider"
                data-ba-slider
                role="group"
                aria-label="Sammenligning før og etter — {{ block.settings.customer_name | default: 'kunde' | escape }}"
              >
                {%- if block.settings.after_image != blank -%}
                  <div class="lp-comparison__after">
                    {{
                      block.settings.after_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        decoding: 'async',
                        alt: after_alt,
                        widths: '400, 600, 800, 1200',
                        sizes: '(max-width: 768px) 92vw, 480px'
                    }}
                  </div>
                {%- endif -%}

                {%- if block.settings.before_image != blank -%}
                  <div class="lp-comparison__before" data-ba-before>
                    {{
                      block.settings.before_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        decoding: 'async',
                        alt: before_alt,
                        widths: '400, 600, 800, 1200',
                        sizes: '(max-width: 768px) 92vw, 480px'
                    }}
                  </div>
                {%- endif -%}

                <div class="lp-comparison__divider" data-ba-divider aria-hidden="true"></div>

                <button
                  class="lp-comparison__handle"
                  data-ba-handle
                  type="button"
                  role="slider"
                  aria-orientation="horizontal"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="50"
                  aria-label="Dra for å sammenligne før og etter"
                  tabindex="0"
                >
                  <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                    <polyline points="7,4 3,10 7,16"></polyline>
                    <polyline points="13,4 17,10 13,16"></polyline>
                  </svg>
                </button>

                <span class="lp-comparison__label lp-comparison__label--before">
                  {{- block.settings.before_label | default: 'FØR' | escape -}}
                </span>
                <span class="lp-comparison__label lp-comparison__label--after">
                  {{- block.settings.after_label | default: 'ETTER' | escape -}}
                </span>
              </div>

              <div class="lp-comparison__caption">
                {%- if block.settings.customer_name != blank -%}
                  <p class="lp-comparison__customer">{{ block.settings.customer_name | escape }}</p>
                {%- endif -%}
                {%- if block.settings.concern_tag != blank -%}
                  <p class="lp-comparison__concern">{{ block.settings.concern_tag | escape }}</p>
                {%- endif -%}
                {%- if block.settings.usage_tag != blank -%}
                  <p class="lp-comparison__usage">{{ block.settings.usage_tag | escape }}</p>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <div class="lp-results-timeline__disclaimer">{{ section.settings.disclaimer }}</div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Results Timeline",
  "tag": "section",
  "class": "sk-lp-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "Realistiske resultater fra ekte brukere"
    },
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "<p>Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan.</p>"
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Før / Etter",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Før-bilde (portrett 4:5 anbefalt)"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "Etter-bilde (portrett 4:5 anbefalt)"
        },
        {
          "type": "text",
          "id": "before_label",
          "label": "Før-merkelapp",
          "default": "UKE 0"
        },
        {
          "type": "text",
          "id": "after_label",
          "label": "Etter-merkelapp",
          "default": "UKE 8"
        },
        {
          "type": "text",
          "id": "before_alt",
          "label": "Før-bilde alt-tekst",
          "info": "Beskriv hva bildet faktisk viser."
        },
        {
          "type": "text",
          "id": "after_alt",
          "label": "Etter-bilde alt-tekst"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Kunde",
          "info": "F.eks. «Maria, 48 – Oslo»"
        },
        {
          "type": "text",
          "id": "concern_tag",
          "label": "Concern",
          "info": "F.eks. «Fine linjer og trøtt hud»"
        },
        {
          "type": "text",
          "id": "usage_tag",
          "label": "Bruks-/tids-tag",
          "info": "F.eks. «10 min, 5x/uke · Etter 8 uker»"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Results Timeline",
      "category": "Skinora",
      "blocks": [
        {
          "type": "comparison",
          "settings": {
            "before_label": "UKE 0",
            "after_label": "UKE 8",
            "customer_name": "Maria, 48 – Oslo",
            "concern_tag": "Fine linjer og trøtt hud",
            "usage_tag": "10 min, 5x/uke"
          }
        },
        {
          "type": "comparison",
          "settings": {
            "before_label": "UKE 0",
            "after_label": "UKE 8",
            "customer_name": "Ingrid, 44 – Bergen",
            "concern_tag": "Aldersflekker og solskader",
            "usage_tag": "10 min, 4x/uke"
          }
        }
      ]
    }
  ]
}
{% endschema %}
