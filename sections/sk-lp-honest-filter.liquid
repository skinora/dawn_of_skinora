{%- comment -%}
  sk-lp-honest-filter.liquid
  LP Honest Filter — bygger tillit ved å være ærlig om hvem produktet IKKE passer for.
  Plasseres mellom LP Mechanism og Klinikksammenligning.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-honest-filter.css' | asset_url | stylesheet_tag }}

<section
  class="sk-honest-filter"
  style="--bg: {{ section.settings.background }}; --accent: {{ section.settings.accent }};"
>
  <div class="sk-honest-filter__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="lp-eyebrow sk-honest-filter__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="lp-section-heading sk-honest-filter__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="sk-honest-filter__intro">{{ section.settings.intro }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="sk-honest-filter__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter_item' -%}
            <li class="sk-honest-filter__item" {{ block.shopify_attributes }}>
              <span class="sk-honest-filter__icon" aria-hidden="true">✗</span>
              <div class="sk-honest-filter__body">
                {%- if block.settings.lead != blank -%}
                  <strong class="sk-honest-filter__lead">{{ block.settings.lead }}</strong>
                {%- endif -%}
                {%- if block.settings.explanation != blank -%}
                  <p class="sk-honest-filter__explanation">{{ block.settings.explanation }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <hr class="sk-honest-filter__separator" aria-hidden="true">

    {%- if section.settings.closing != blank -%}
      <div class="sk-honest-filter__closing">{{ section.settings.closing }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '#kjop' }}"
        class="lp-btn lp-btn--hero"
      >
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Honest Filter",
  "tag": "section",
  "class": "sk-honest-filter-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ÆRLIG SNAKK" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Skinora® Clear er ikke for alle." },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro-paragraf",
      "info": "Sett scenen for hvem dette ikke passer for. Hold til 2–3 setninger.",
      "default": "<p>Vi har bygget Skinora Clear for én type kunde. Hvis du kjenner deg igjen i punktene under, er ikke dette riktig produkt for deg — og det er helt greit. Vi vil heller at du finner det som virker.</p>"
    },
    {
      "type": "richtext",
      "id": "closing",
      "label": "Avslutnings-tekst",
      "info": "Husk å oppdatere antallet (\"alle fire\") hvis du endrer antall filter-punkter.",
      "default": "<h3>Hvis du nikker nei til alle fire — er du nøyaktig den vi bygget dette for.</h3><p>Vi gir deg 30 dager på å bevise det for deg selv.</p>"
    },
    { "type": "text", "id": "cta_label", "label": "CTA-tekst", "default": "PRØV RISIKOFRITT I 30 DAGER →" },
    { "type": "url", "id": "cta_url", "label": "CTA-lenke" },
    {
      "type": "color",
      "id": "accent",
      "label": "Aksentfarge",
      "info": "Brukes på X-ikonene og den lille separatoren over avslutnings-teksten.",
      "default": "#A0522D"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Bakgrunnsfarge",
      "default": "#F6F2ED"
    }
  ],
  "blocks": [
    {
      "type": "filter_item",
      "name": "Filter-punkt",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "lead", "label": "Hovedlinje (bold)" },
        { "type": "textarea", "id": "explanation", "label": "Forklaring" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "LP Honest Filter",
      "blocks": [
        {
          "type": "filter_item",
          "settings": {
            "lead": "Du har alvorlig cystisk akne som krever resept-behandling.",
            "explanation": "Hvis du står på Roaccutan eller isotretinoin — eller burde stå på det — er LED ikke nok. Snakk med fastlege først."
          }
        },
        {
          "type": "filter_item",
          "settings": {
            "lead": "Du er gravid eller ammer.",
            "explanation": "LED-lys er ikke farlig — men det finnes ikke nok kliniske data på akkurat denne gruppen. Vi velger føre-var."
          }
        },
        {
          "type": "filter_item",
          "settings": {
            "lead": "Du forventer resultater på under 4 uker.",
            "explanation": "Huden trenger to fulle sykluser før den viser tydelig forskjell. Hvis du vil ha umiddelbar effekt, er ikke LED riktig verktøy."
          }
        },
        {
          "type": "filter_item",
          "settings": {
            "lead": "Du har ikke tid til 10 minutter, 3–5 ganger i uken.",
            "explanation": "Konsistens er hele forskjellen mellom suksess og frustrasjon. Bruker du den sporadisk, kaster du pengene dine."
          }
        }
      ]
    }
  ]
}
{% endschema %}
