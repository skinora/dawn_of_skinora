{%- comment -%}
  sk-lp-radiance-face.liquid
  Landing page section for Skinora® Radiance Face LED mask.
  Uses a dedicated page template: page.sk-lp-radiance-face.json
  All styles loaded via: section-sk-lp-radiance-face.css
{%- endcomment -%}

{%- if section.settings.hero_image != blank -%}
  <link
    rel="preload"
    as="image"
    imagesrcset="{{ section.settings.hero_image | image_url: width: 400 }} 400w, {{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1000 }} 1000w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w, {{ section.settings.hero_image | image_url: width: 1600 }} 1600w"
    imagesizes="(max-width: 991px) 100vw, 50vw"
    fetchpriority="high"
  >
{%- endif -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.product_url | split: '/products/' | last | split: '?' | first -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<div class="sk-lp">
  {%- comment -%} ========== 1. ANNOUNCEMENT BAR ========== {%- endcomment -%}
  <div class="lp-announcement-bar">
    {{ section.settings.announcement_text }}
  </div>

  {%- comment -%} ========== 2. HEADER (logo only) ========== {%- endcomment -%}
  <header class="lp-header">
    {%- if section.settings.logo != blank -%}
      <img
        class="lp-header__logo"
        src="{{ section.settings.logo | image_url: height: 64 }}"
        alt="{{ shop.name }}"
        width="auto"
        height="32"
        loading="eager"
      >
    {%- else -%}
      <span class="lp-header__logo-text">{{ shop.name }}</span>
    {%- endif -%}
  </header>

  <main>
    {%- comment -%} ========== 3. HERO ========== {%- endcomment -%}
    <section class="lp-hero">
      <div class="lp-hero__grid">
        <div class="lp-hero__content">
          <p class="lp-eyebrow">{{ section.settings.hero_eyebrow }}</p>
          <h2 class="lp-hero__title">{{ section.settings.hero_title }}</h2>
          <p class="lp-hero__text">{{ section.settings.hero_text }}</p>
          <div class="lp-hero__pills">
            <span class="lp-hero__pill"><span class="lp-hero__pill-check">✓</span> Norsk merke</span>
            <span class="lp-hero__pill"><span class="lp-hero__pill-check">✓</span> 60 dagers garanti</span>
            <span class="lp-hero__pill"><span class="lp-hero__pill-check">✓</span> Gratis frakt</span>
          </div>
          <div class="lp-hero__actions">
            <button type="button" class="lp-btn" data-product-handle="{{ sk_lp_handle }}">
              {{ section.settings.hero_cta_text }}
            </button>
            <a href="#slik-bruker-du" class="lp-hero__link">Se hvordan den brukes (60 sek) ↓</a>
          </div>
        </div>
        <div class="lp-hero__image">
          {%- if section.settings.hero_image != blank -%}
            <img
              src="{{ section.settings.hero_image | image_url: width: 800 }}"
              srcset="{{ section.settings.hero_image | image_url: width: 400 }} 400w, {{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1000 }} 1000w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w, {{ section.settings.hero_image | image_url: width: 1600 }} 1600w"
              sizes="(max-width: 991px) 100vw, 50vw"
              alt="{{ section.settings.hero_image.alt | default: 'Skinora Radiance Face' }}"
              width="{{ section.settings.hero_image.width }}"
              height="{{ section.settings.hero_image.height }}"
              loading="eager"
              fetchpriority="high"
            >
          {%- else -%}
            <div class="lp-hero__image-placeholder">[ Radiance Face produktbilde ]</div>
          {%- endif -%}
        </div>
      </div>
    </section>

    {%- comment -%} ========== 4. TRUST BAR ========== {%- endcomment -%}
    <section class="lp-trustbar">
      <div class="lp-container">
        <div class="lp-trustbar__grid">
          <div class="lp-trustbar__item">
            <span class="lp-trustbar__icon">🇳🇴</span>
            <span class="lp-trustbar__text">Norskutviklet</span>
          </div>
          <div class="lp-trustbar__item">
            <span class="lp-trustbar__icon">📦</span>
            <span class="lp-trustbar__text">Sendes fra norsk lager</span>
          </div>
          <div class="lp-trustbar__item">
            <span class="lp-trustbar__icon">🔄</span>
            <span class="lp-trustbar__text">60 dagers garanti</span>
          </div>
          <div class="lp-trustbar__item">
            <span class="lp-trustbar__icon">🔒</span>
            <span class="lp-trustbar__text">Vipps &amp; Klarna</span>
          </div>
        </div>
      </div>
    </section>

    {%- comment -%} ========== 5. PROBLEM ========== {%- endcomment -%}
    <section class="lp-problem">
      <div class="lp-container--narrow">
        <h2 class="lp-section-heading">Kjenner du igjen dette?</h2>
        <p class="lp-section-intro">
          Med årene endres huden – det er helt naturlig. Men du trenger ikke bare akseptere det.
        </p>
        <ul class="lp-problem__list">
          <li class="lp-problem__item">
            <span class="lp-problem__check">✓</span>
            Huden ser mer sliten ut enn du føler deg
          </li>
          <li class="lp-problem__item">
            <span class="lp-problem__check">✓</span>
            Mindre naturlig glød og mer gusten hudtone
          </li>
          <li class="lp-problem__item">
            <span class="lp-problem__check">✓</span>
            Ujevn hudtone eller pigmentflekker
          </li>
          <li class="lp-problem__item">
            <span class="lp-problem__check">✓</span>
            Tørrhetslinjer og endret hudtekstur
          </li>
          <li class="lp-problem__item">
            <span class="lp-problem__check">✓</span>
            Du vil gjøre noe aktivt – uten å oppsøke klinikk
          </li>
        </ul>
      </div>
    </section>

    {%- comment -%} ========== 6. RESULTS ========== {%- endcomment -%}
    <section class="lp-results">
      <div class="lp-container">
        <h2 class="lp-section-heading">Hva kan du forvente?</h2>
        <p class="lp-section-intro">Realistiske resultater fra ekte brukere</p>
        <div class="lp-results__grid">
          <div class="lp-results__card">
            <p class="lp-results__period">Etter 2–4 uker</p>
            <p class="lp-results__text">Mer glød og jevnere uttrykk</p>
          </div>
          <div class="lp-results__card">
            <p class="lp-results__period">Etter 6–8 uker</p>
            <p class="lp-results__text">Mer stabil hudtone og forbedret tekstur</p>
          </div>
          <div class="lp-results__card">
            <p class="lp-results__period">Over tid</p>
            <p class="lp-results__text">Well-aging effekt og vedlikehold av hudens vitalitet</p>
          </div>
        </div>
        <p class="lp-results__disclaimer">
          Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan.
        </p>
      </div>
    </section>

    {%- comment -%} ========== 7. HOW TO USE ========== {%- endcomment -%}
    <section id="slik-bruker-du" class="lp-how-to-use">
      <div class="lp-container">
        <h2 class="lp-section-heading">Slik bruker du den</h2>
        <p class="lp-section-intro">&nbsp;</p>
        <div class="lp-steps">
          <div class="lp-step">
            <div class="lp-step__number">1</div>
            <h3 class="lp-step__title">Rens huden</h3>
            <p class="lp-step__text">Fjern sminke og smuss. Tørk forsiktig.</p>
          </div>
          <div class="lp-step">
            <div class="lp-step__number">2</div>
            <h3 class="lp-step__title">Bruk masken i 10 minutter</h3>
            <p class="lp-step__text">Sett på, slå på. Slapp av mens lyset jobber.</p>
          </div>
          <div class="lp-step">
            <div class="lp-step__number">3</div>
            <h3 class="lp-step__title">Avslutt med fukt eller serum</h3>
            <p class="lp-step__text">Lås inn effekten med din favoritt fuktighetskrem.</p>
          </div>
        </div>
        <div class="lp-how-to-use__tips">
          <span class="lp-how-to-use__tip">Fungerer morgen eller kveld</span>
          <span class="lp-how-to-use__tip">Kan brukes foran TV eller i senga</span>
          <span class="lp-how-to-use__tip">Anbefalt frekvens: 3–5 ganger i uken</span>
        </div>
      </div>
    </section>

    {%- comment -%} ========== 8. WHY RADIANCE ========== {%- endcomment -%}
    <section class="lp-why-radiance">
      <div class="lp-container">
        <h2 class="lp-section-heading">Hvorfor Radiance er annerledes</h2>
        <p class="lp-section-intro">&nbsp;</p>
        <div class="lp-why-radiance__grid">
          <div class="lp-why-radiance__card">
            <div class="lp-why-radiance__icon">🔬</div>
            <h3 class="lp-why-radiance__title">Klinisk dokumentert teknologi</h3>
            <p class="lp-why-radiance__text">
              LED-bølgelengder som stimulerer hudens naturlige kollagen- og elastinproduksjon.
            </p>
          </div>
          <div class="lp-why-radiance__card">
            <div class="lp-why-radiance__icon">😌</div>
            <h3 class="lp-why-radiance__title">Komfortabel passform</h3>
            <p class="lp-why-radiance__text">Utviklet for daglig hjemmebruk – myk, lett og enkel å ha på.</p>
          </div>
          <div class="lp-why-radiance__card">
            <div class="lp-why-radiance__icon">🎛️</div>
            <h3 class="lp-why-radiance__title">Enkel å bruke</h3>
            <p class="lp-why-radiance__text">Få knapper, ingen komplisert rutine. På – og slapp av.</p>
          </div>
          <div class="lp-why-radiance__card">
            <div class="lp-why-radiance__icon">🛡️</div>
            <h3 class="lp-why-radiance__title">Premium kvalitet og garanti</h3>
            <p class="lp-why-radiance__text">Norsk kundeservice og 60 dagers fornøydgaranti.</p>
          </div>
        </div>
      </div>
    </section>

    {%- comment -%} ========== 9. REVIEWS ========== {%- endcomment -%}
    <section class="lp-reviews">
      <div class="lp-container">
        <h2 class="lp-section-heading">Det norske kvinner sier</h2>
        <p class="lp-reviews__score">{{ section.settings.reviews_score }}</p>
        <div class="lp-reviews__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              <div class="lp-review-card" {{ block.shopify_attributes }}>
                <div class="lp-review-card__stars">★★★★★</div>
                <p class="lp-review-card__text">{{ block.settings.review_text }}</p>
                <p class="lp-review-card__author">{{ block.settings.review_author }}</p>
                <p class="lp-review-card__verified">Verifisert kjøper ✓</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>

    {%- comment -%} ========== 10. TRUST FULL ========== {%- endcomment -%}
    <section class="lp-trust-full">
      <div class="lp-container">
        <h2 class="lp-section-heading">Trygg handel – alltid</h2>
        <p class="lp-section-intro">&nbsp;</p>
        <div class="lp-trust-full__grid">
          <div class="lp-trust-full__card">
            <div class="lp-trust-full__icon">🔄</div>
            <h3 class="lp-trust-full__title">60 dagers fornøydgaranti</h3>
            <p class="lp-trust-full__text">Ikke fornøyd? Du får pengene tilbake – ingen spørsmål.</p>
          </div>
          <div class="lp-trust-full__card">
            <div class="lp-trust-full__icon">📦</div>
            <h3 class="lp-trust-full__title">Gratis frakt</h3>
            <p class="lp-trust-full__text">Sendes fra norsk lager. Levering 2–4 virkedager.</p>
          </div>
          <div class="lp-trust-full__card">
            <div class="lp-trust-full__icon">📞</div>
            <h3 class="lp-trust-full__title">Norsk kundeservice</h3>
            <p class="lp-trust-full__text">Spørsmål? Vi er her. hello@skinora.no</p>
          </div>
          <div class="lp-trust-full__card">
            <div class="lp-trust-full__icon">💳</div>
            <h3 class="lp-trust-full__title">Sikker betaling</h3>
            <p class="lp-trust-full__text">Vipps, Klarna, Visa og Mastercard.</p>
          </div>
          <div class="lp-trust-full__card">
            <div class="lp-trust-full__icon">🏆</div>
            <h3 class="lp-trust-full__title">2 års reklamasjonsrett</h3>
            <p class="lp-trust-full__text">Full reklamasjonsrett i henhold til norsk lov.</p>
          </div>
        </div>
      </div>
    </section>

    {%- comment -%} ========== 11. WHAT'S IN THE BOX ========== {%- endcomment -%}
