                sizes="(max-width: 991px) 100vw, 50vw"
                alt="{{ section.settings.unboxing_image.alt | default: 'Hva du får i esken' }}"
                width="{{ section.settings.unboxing_image.width }}"
                height="{{ section.settings.unboxing_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="lp-whats-in-box__image-placeholder">[ Bilde: Unboxing / innhold i esken ]</div>
            {%- endif -%}
          </div>
          <div class="lp-whats-in-box__content">
            <h2 class="lp-section-heading">Hva får du i esken?</h2>
            <ul class="lp-whats-in-box__list">
              <li class="lp-whats-in-box__item">
                <span class="lp-whats-in-box__item-icon">💡</span>
                Skinora® Radiance Face LED-maske
              </li>
              <li class="lp-whats-in-box__item">
                <span class="lp-whats-in-box__item-icon">🔌</span>
                USB-C ladekabel
              </li>
              <li class="lp-whats-in-box__item">
                <span class="lp-whats-in-box__item-icon">🕶️</span>
                Øyebeskyttelse
              </li>
              <li class="lp-whats-in-box__item">
                <span class="lp-whats-in-box__item-icon">📖</span>
                Bruksanvisning (norsk)
              </li>
              <li class="lp-whats-in-box__item">
                <span class="lp-whats-in-box__item-icon">🎁</span>
                Premium oppbevaringspose
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {%- comment -%} ========== 12. FAQ ========== {%- endcomment -%}
    <section class="lp-faq">
      <div class="lp-container">
        <h2 class="lp-section-heading">Ofte stilte spørsmål</h2>
        <p class="lp-section-intro">&nbsp;</p>
        <div class="lp-faq__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              <div class="lp-faq__item" {{ block.shopify_attributes }}>
                <button class="lp-faq__question" type="button" aria-expanded="false">
                  {{ block.settings.question }}
                  <span class="lp-faq__icon">+</span>
                </button>
                <div class="lp-faq__answer">
                  <div class="lp-faq__answer-inner">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>

    {%- comment -%} ========== 13. CTA FINAL ========== {%- endcomment -%}
    <section id="kjop" class="lp-cta-final">
      <div class="lp-container--narrow" style="text-align:center;">
        <h2 class="lp-cta-final__heading">{{ section.settings.cta_heading }}</h2>
        <p class="lp-cta-final__text">{{ section.settings.cta_text }}</p>
        <p class="lp-cta-final__price">{{ section.settings.price_text }}</p>
        <button type="button" class="lp-btn" data-product-handle="{{ sk_lp_handle }}">
          {{ section.settings.cta_button_text }}
        </button>
        <div class="lp-cta-final__guarantees">
          <span class="lp-cta-final__guarantee">🔄 60 dagers garanti</span>
          <span class="lp-cta-final__guarantee">📦 Gratis frakt</span>
          <span class="lp-cta-final__guarantee">🔒 Sikker betaling</span>
        </div>
      </div>
    </section>
  </main>
</div>

{%- comment -%} FAQ accordion JS {%- endcomment -%}
<script>
  (function initLpFaqAccordion() {
    var items = document.querySelectorAll('.sk-lp .lp-faq__item');
    items.forEach(function (item) {
      var btn = item.querySelector('.lp-faq__question');
      btn.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        items.forEach(function (i) {
          i.classList.remove('is-open');
          i.querySelector('.lp-faq__question').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>

