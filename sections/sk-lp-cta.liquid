{%- comment -%}
  sk-lp-cta.liquid
  Final CTA section with heading, text, price, button and guarantee badges.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-cta.css' | asset_url | stylesheet_tag }}

{%- assign sk_lp_handle = section.settings.product_url | split: '/products/' | last | split: '?' | first -%}
{%- assign sk_lp_product = all_products[sk_lp_handle] -%}
{%- assign sk_lp_variant = sk_lp_product.selected_or_first_available_variant -%}

<script src="{{ 'sk-lp-cart-add.js' | asset_url }}" defer="defer"></script>

<!-- SECTION: Closing CTA -->
<div class="sk-lp">
  <section id="{{ section.settings.anchor_id | default: 'kjop' }}" class="lp-cta-final">
    <div class="lp-container--narrow">
      {%- if section.settings.eyebrow != blank -%}
        <div class="lp-cta-final__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="lp-cta-final__heading">{{ section.settings.heading }}</h2>
      <p class="lp-cta-final__text">{{ section.settings.text }}</p>

      <div class="lp-cta-final__card">
        <div class="lp-cta-final__price-block">
          <p class="lp-cta-final__price">{{ section.settings.price_text }}</p>
          {%- if section.settings.klarna_text != blank -%}
            <p class="lp-cta-final__permonth">{{ section.settings.klarna_text }}</p>
          {%- endif -%}
        </div>

        <form
          action="{{ routes.cart_add_url }}"
          method="post"
          enctype="multipart/form-data"
          class="lp-cta-form"
          data-cta="final"
        >
          <input type="hidden" name="id" value="{{ sk_lp_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button
            type="submit"
            class="lp-btn lp-cta-final__btn"
            data-product-handle="{{ sk_lp_handle }}"
          >
            <span class="lp-cta-final__btn-label">{{ section.settings.button_text }}</span>
            <svg class="lp-cta-final__btn-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

        {%- if section.blocks.size > 0 -%}
          <ul class="lp-cta-final__guarantees">
            {%- for block in section.blocks -%}
              <li class="lp-cta-final__guarantee" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <img
                    src="{{ block.settings.icon | image_url: height: 32 }}"
                    alt=""
                    width="16"
                    height="16"
                    loading="lazy"
                  >
                {%- else -%}
                  <svg class="lp-cta-final__guarantee-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
                    <circle cx="10" cy="10" r="8.2" stroke="currentColor" stroke-width="1.4"/>
                    <path d="M6.4 10.4l2.4 2.4 4.8-5.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                <span class="lp-cta-final__guarantee-text">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP CTA",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (liten label over overskrift)",
      "default": "Kom i gang"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Klar for synlige resultater?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Brødtekst",
      "default": "Gi huden din den behandlingen den fortjener – hjemme, på dine premisser, med teknologi som faktisk virker."
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Pris (visning)",
      "default": "4 390 kr"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knapptekst",
      "default": "Bestill nå"
    },
    {
      "type": "url",
      "id": "product_url",
      "label": "Produktlenke"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anker-ID",
      "default": "kjop"
    },
    {
      "type": "html",
      "id": "klarna_text",
      "label": "Pris pr. måned (HTML, vises under prisen)",
      "default": "Eller <strong>122 kr\/mnd<\/strong> med Klarna"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Garanti-badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "60 dagers garanti"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP CTA",
      "blocks": [
        { "type": "badge", "settings": { "text": "60 dagers garanti" } },
        { "type": "badge", "settings": { "text": "Sendes innen 24 t" } },
        { "type": "badge", "settings": { "text": "Trygg betaling" } }
      ]
    }
  ]
}
{% endschema %}
