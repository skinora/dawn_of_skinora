{{ 'section-sk-customer-service.css' | asset_url | stylesheet_tag }}
{{ 'honeypot.css' | asset_url | stylesheet_tag }}

<div class="sk-customer-service page-width">
  <h1 class="sk-header__section sk-section-heading sk-section-heading--h1 sk-customer-service__heading">
    Kundeservice
  </h1>

  <div class="sk-customer-service__grid">
    <div class="sk-customer-service__info">
      <h3 class="sk-header__section sk-section-heading sk-section-heading--h3 sk-customer-service__card-heading">
        Kontakt oss
      </h3>
      <p>Har du spørsmål om produkter, bestilling eller levering? Vi hjelper deg gjerne.</p>

      <ul class="sk-customer-service__details">
        <li><strong>Svartid:</strong> innen 24–48 timer (hverdager)</li>
        <li><strong>Åpningstid:</strong> 09–16 (CET)</li>
      </ul>
    </div>

    <div class="sk-customer-service__form">
      <h3 class="sk-header__section sk-section-heading sk-section-heading--h3 sk-customer-service__card-heading">
        Send oss en melding
      </h3>

      {% form 'contact', id: 'contact_form', class: 'contact-form hp-protected' %}
        {%- if form.posted_successfully? -%}
          <p class="skcs-status skcs-status--success">Takk! Meldingen din er sendt. Vi svarer så fort vi kan.</p>

          <script>
            (function resetContactForm() {
              var formEl = document.getElementById('contact_form');
              if (formEl) {
                formEl.reset();
              }
            })();
          </script>

          {%- comment -%}
            Ønsker du redirect til en takk-side i stedet?
            Fjern kommentaren under og sett riktig URL (f.eks. /pages/takk)
          {%- endcomment -%}
          {%- comment -%}
            <script>window.location='/pages/takk';</script>
          {%- endcomment -%}

        {%- elsif form.errors -%}
          <p class="skcs-status skcs-status--error">Oi! Noe gikk galt. Sjekk feltene og prøv igjen.</p>
        {%- endif -%}

        {%- comment -%}
          Disse skjulte feltene gjør innboksemnet tydeligere og lar deg filtrere i e-post.
        {%- endcomment -%}
        <input type="hidden" name="contact[subject]" value="Kundeservice – ny henvendelse fra {{ shop.name }}">
        <input type="hidden" name="contact[tags]" value="Kundeservice, Kontakt">

        {%- comment -%}
          ── HONEYPOT LAG 1: Skjult felt ──
          Usynlig for ekte brukere, men bots fyller det ut automatisk.
        {%- endcomment -%}
        <div class="hp-trap" aria-hidden="true">
          <label for="hp-website">Nettside (ikke fyll ut)</label>
          <input
            type="text"
            name="hp-website"
            id="hp-website"
            autocomplete="off"
            tabindex="-1"
            value=""
          >
        </div>

        {%- comment -%}
          ── HONEYPOT LAG 2: Tidssjekk ──
          Lagrer timestamp ved sidelast. JS blokkerer innsending < 3 sek.
        {%- endcomment -%}
        <input type="hidden" name="hp-timestamp" id="hp-timestamp" value="">

        <label for="ContactFormName">Navn</label>
        <input type="text" id="ContactFormName" name="contact[name]" autocomplete="name" required>

        <label for="ContactFormEmail">E-post</label>
        <input type="email" id="ContactFormEmail" name="contact[email]" autocomplete="email" required>

        <label for="ContactFormOrder">Ordrenummer (valgfritt)</label>
        <input type="text" id="ContactFormOrder" name="contact[order_number]" inputmode="numeric" pattern="[0-9#\- ]*">
        <textarea
          id="ContactFormMessage"
          name="contact[body]"
          rows="6"
          placeholder="Hva kan vi hjelpe deg med?"
          required
        ></textarea>

        <button type="submit" class="sk-customer-service__button">Send melding</button>
      {% endform %}

      <script>
        (function clearContactQuery() {
          var search = window.location.search || '';
          if (search.indexOf('contact_posted=true') !== -1 || search.indexOf('form_type=contact') !== -1) {
            var cleanUrl = window.location.origin + window.location.pathname + window.location.hash;
            try {
              window.history.replaceState({}, document.title, cleanUrl);
            } catch (e) {
              window.location.href = cleanUrl;
            }
          }
        })();
      </script>
    </div>
  </div>
</div>

<script src="{{ 'honeypot.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "SK Kundeservice",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "SK Kundeservice"
    }
  ]
}
{% endschema %}
