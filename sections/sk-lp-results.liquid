{%- comment -%}
  sk-lp-results.liquid
  Expected results timeline with dynamic cards.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Results Timeline -->
<div class="sk-lp">
  <section class="lp-results">
    <div class="lp-container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.intro != blank -%}
        <p class="lp-section-intro">{{ section.settings.intro }}</p>
      {%- endif -%}

      {%- if section.settings.image -%}
        <div class="lp-results__image" style="text-align:center;margin-bottom:32px;">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag: loading: 'lazy', widths: '600,900,1200', sizes: '(max-width: 991px) 100vw, 800px'
          }}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div
          class="lp-results__timeline"
          role="region"
          aria-roledescription="carousel"
          aria-label="Forventede resultater"
          tabindex="0"
        >
          {%- for block in section.blocks -%}
            <article
              class="lp-results__step"
              role="group"
              aria-roledescription="slide"
              aria-label="Steg {{ forloop.index }} av {{ section.blocks.size }}"
              {{ block.shopify_attributes }}
            >
              <figure class="lp-results__media">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
                    sizes="(max-width: 767px) 84vw, 360px"
                    width="800"
                    height="1000"
                    alt="{{ block.settings.image.alt | default: block.settings.period | escape }}"
                    loading="lazy"
                    decoding="async"
                  >
                {%- endif -%}
                <span class="lp-results__numeral" aria-hidden="true">{{ forloop.index }}</span>
              </figure>
              <div class="lp-results__card">
                <p class="lp-results__period">{{ block.settings.period }}</p>
                <p class="lp-results__text">{{ block.settings.text }}</p>
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 1 -%}
          <div class="lp-results__dots" role="tablist" aria-label="Bla mellom steg">
            {%- for block in section.blocks -%}
              <button
                type="button"
                class="lp-results__dot"
                aria-label="Gå til steg {{ forloop.index }}"
                data-index="{{ forloop.index0 }}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="lp-results__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </section>
</div>

<script src="{{ 'lp-results.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "LP Results",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva kan du forvente?"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "Realistiske resultater fra ekte brukere"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer-tekst",
      "default": "Resultat varierer fra person til person. Vi lover ikke mirakler – vi lover en plan."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Before/After-bilde"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Resultatkort",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Progressbilde"
        },
        {
          "type": "text",
          "id": "period",
          "label": "Tidsperiode",
          "default": "Etter 2–4 uker"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beskrivelse",
          "default": "Mer glød og jevnere uttrykk"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Results",
      "blocks": [
        { "type": "card", "settings": { "period": "Etter 2–4 uker", "text": "Mer glød og jevnere uttrykk" } },
        {
          "type": "card",
          "settings": { "period": "Etter 6–8 uker", "text": "Mer stabil hudtone og forbedret tekstur" }
        },
        {
          "type": "card",
          "settings": { "period": "Over tid", "text": "Well-aging effekt og vedlikehold av hudens vitalitet" }
        }
      ]
    }
  ]
}
{% endschema %}
