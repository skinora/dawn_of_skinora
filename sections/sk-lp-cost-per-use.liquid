{%- comment -%}
  sk-lp-cost-per-use.liquid
  Cost-per-use comparison: large number + 12-month savings bars.
  CSS-only chart, no JS.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<style>
  .lp-cpu {
    background: transparent;
    padding: clamp(56px, 8vw, 96px) 16px;
  }
  .lp-cpu__inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .lp-cpu__eyebrow {
    display: block;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(58, 52, 72, 0.7);
    margin-bottom: 12px;
  }
  .lp-cpu__big {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', Georgia, serif;
    font-size: clamp(64px, 14vw, 120px);
    font-weight: 400;
    line-height: 1;
    color: #3a3448;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .lp-cpu__sub {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: clamp(15px, 2.4vw, 17px);
    font-weight: 500;
    line-height: 1.5;
    color: #4a4458;
    margin: 0 auto 40px;
    max-width: 480px;
  }

  .lp-cpu__compare-title {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(58, 52, 72, 0.7);
    margin: 0 0 20px;
  }
  .lp-cpu__bars {
    display: flex;
    flex-direction: column;
    gap: 18px;
    text-align: left;
  }
  .lp-cpu__bar {
    display: block;
  }
  .lp-cpu__bar-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #30273e;
    margin-bottom: 6px;
  }
  .lp-cpu__bar-value {
    font-weight: 400;
    color: #4a4458;
    font-size: 13px;
  }
  .lp-cpu__bar-track {
    width: 100%;
    height: 14px;
    background: rgba(48, 39, 62, 0.06);
    border-radius: 999px;
    overflow: hidden;
  }
  .lp-cpu__bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width 600ms ease;
  }
  .lp-cpu__bar--clinic .lp-cpu__bar-fill {
    width: 100%;
    background: linear-gradient(90deg, #c9a98a, #b08a6b);
  }
  .lp-cpu__bar--brand .lp-cpu__bar-fill {
    width: 50%;
    background: linear-gradient(90deg, #3a3448, #5a4f78);
  }
  .lp-cpu__footnote {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12px;
    font-style: italic;
    color: rgba(58, 52, 72, 0.6);
    margin: 24px 0 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-cpu__bar-fill {
      transition: none;
    }
  }
</style>

<section class="sk-lp-section lp-cpu" aria-labelledby="lp-cpu-heading-{{ section.id }}">
  <div class="lp-cpu__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="lp-cpu__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <p
      id="lp-cpu-heading-{{ section.id }}"
      class="lp-cpu__big"
    >
      {{ section.settings.big_number | default: '28 kr' }}
    </p>
    <p class="lp-cpu__sub">
      {{ section.settings.sub_text | default: 'per behandling — én gang betalt, ubegrenset bruk' }}
    </p>

    {%- if section.settings.show_comparison -%}
      <p class="lp-cpu__compare-title">
        {{ section.settings.compare_title | default: '12 måneders kostnad' }}
      </p>
      <div class="lp-cpu__bars">
        <div class="lp-cpu__bar lp-cpu__bar--clinic">
          <div class="lp-cpu__bar-label">
            <span>{{ section.settings.clinic_label | default: 'Klinikk (12 mnd, 1×/mnd)' }}</span>
            <span class="lp-cpu__bar-value">
              {{- section.settings.clinic_value | default: '9 600 – 18 000 kr' -}}
            </span>
          </div>
          <div class="lp-cpu__bar-track" aria-hidden="true">
            <span class="lp-cpu__bar-fill"></span>
          </div>
        </div>
        <div class="lp-cpu__bar lp-cpu__bar--brand">
          <div class="lp-cpu__bar-label">
            <span>{{ section.settings.brand_label | default: 'Skinora Clear' }}</span>
            <span class="lp-cpu__bar-value">
              {{- section.settings.brand_value | default: '4 390 kr én gang' -}}
            </span>
          </div>
          <div class="lp-cpu__bar-track" aria-hidden="true">
            <span class="lp-cpu__bar-fill"></span>
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.footnote != blank -%}
      <p class="lp-cpu__footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Cost-per-use",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    { "type": "header", "content": "Hovedtall" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Investeringen som lønner seg"
    },
    {
      "type": "text",
      "id": "big_number",
      "label": "Stort tall",
      "default": "28 kr"
    },
    {
      "type": "textarea",
      "id": "sub_text",
      "label": "Underskrift",
      "default": "per behandling — én gang betalt, ubegrenset bruk"
    },

    { "type": "header", "content": "12-måneders sammenligning" },
    {
      "type": "checkbox",
      "id": "show_comparison",
      "label": "Vis sammenligning",
      "default": true
    },
    {
      "type": "text",
      "id": "compare_title",
      "label": "Sammenligningstittel",
      "default": "12 måneders kostnad"
    },
    {
      "type": "text",
      "id": "clinic_label",
      "label": "Klinikk-etikett",
      "default": "Klinikk (12 mnd, 1×/mnd)"
    },
    {
      "type": "text",
      "id": "clinic_value",
      "label": "Klinikk-verdi",
      "default": "9 600 – 18 000 kr"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Skinora-etikett",
      "default": "Skinora Clear"
    },
    {
      "type": "text",
      "id": "brand_value",
      "label": "Skinora-verdi",
      "default": "4 390 kr én gang"
    },

    { "type": "header", "content": "Footnote" },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote (valgfritt)",
      "default": "Basert på 3 behandlinger/uke i 12 måneder."
    }
  ],
  "presets": [
    {
      "name": "LP Cost-per-use"
    }
  ]
}
{% endschema %}
