{%- comment -%}
  sk-lp-tech-specs.liquid
  Technical specifications section for Skinora Radiance Face.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-tech-specs.css' | asset_url | stylesheet_tag }}

<!-- SECTION: Technical Specifications -->
<div class="sk-lp">
  <section class="sk-tech-specs">
    <div class="sk-tech-specs__container">
      <h2 class="lp-section-heading">{{ section.settings.heading }}</h2>
      <table class="sk-tech-specs__table">
        <tbody>
          {%- for block in section.blocks -%}
            <tr {{ block.shopify_attributes }}>
              <td>{{ block.settings.label }}</td>
              <td>{{ block.settings.value }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Tech Specs",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Tekniske spesifikasjoner"
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spesifikasjon",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Egenskap"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Verdi"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Tech Specs",
      "blocks": [
        {
          "type": "spec",
          "settings": { "label": "LED-bølgelengder", "value": "630 nm (rødt) + 830 nm (nær-infrarødt)" }
        },
        { "type": "spec", "settings": { "label": "Antall LED-er", "value": "[CONFIRM]" } },
        { "type": "spec", "settings": { "label": "Behandlingstid", "value": "10 minutter per økt" } },
        {
          "type": "spec",
          "settings": { "label": "Batteri", "value": "USB-C oppladbart, ca. 20 behandlinger per lading" }
        },
        { "type": "spec", "settings": { "label": "Sertifisering", "value": "CE" } },
        { "type": "spec", "settings": { "label": "Materiale", "value": "Medisinsk silikon" } },
        { "type": "spec", "settings": { "label": "Vekt", "value": "[CONFIRM]" } }
      ]
    }
  ]
}
{% endschema %}
