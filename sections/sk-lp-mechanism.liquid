{%- comment -%}
  sk-lp-mechanism.liquid
  "Hvordan det fungerer" — wavelength mechanism explainer.
  Two side-by-side cards (stacked on mobile) + trust line below.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<style>
  .lp-mech {
    background: transparent;
    padding: clamp(56px, 8vw, 96px) 16px;
  }
  .lp-mech__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .lp-mech__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    width: 100%;
    margin: 0 auto clamp(32px, 5vw, 56px);
  }
  .lp-mech__head > * {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  /* Mobile: force vertical stack regardless of inherited section group layout */
  @media (max-width: 768px) {
    body .lp-mech .lp-mech__head {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 4px !important;
      margin: 0 auto 28px !important;
    }
    body .lp-mech .lp-mech__head > * {
      display: block !important;
      width: 100% !important;
      max-width: 100% !important;
      float: none !important;
      clear: both !important;
      grid-column: 1 / -1 !important;
      box-sizing: border-box !important;
      text-align: center !important;
    }
    body .lp-mech .lp-mech__title {
      font-size: clamp(1.5rem, 7vw, 2rem) !important;
      line-height: 1.2 !important;
      margin: 0 0 0.75rem !important;
    }
    body .lp-mech .lp-mech__intro {
      font-size: 1rem !important;
      line-height: 1.55 !important;
      margin: 0 0 1.5rem !important;
    }
  }
  .lp-mech__eyebrow {
    display: block;
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(58, 52, 72, 0.7);
    margin: 0 0 0.75rem;
  }
  .lp-mech__title {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', Georgia, serif;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 400;
    color: #3a3448;
    letter-spacing: 0.4px;
    line-height: 1.15;
    margin: 0 0 1rem;
    word-break: normal;
    overflow-wrap: break-word;
    hyphens: none;
  }
  .lp-mech__intro {
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    line-height: 1.55;
    color: #4a4458;
    margin: 0 0 2.5rem;
  }

  .lp-mech__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 28px;
    align-items: stretch;
  }
  @media (min-width: 1024px) {
    .lp-mech__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .lp-mech__card {
    background: #fff;
    border: 1px solid rgba(48, 39, 62, 0.08);
    border-radius: 16px;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    text-align: left;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
  }
  .lp-mech__badge {
    width: 84px;
    height: 84px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    margin: 4px 0 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .sk-mechanism__badge--blue {
    background: radial-gradient(circle at 30% 30%, #7a7eea 0%, #3b3fbf 100%);
  }
  .sk-mechanism__badge--red {
    background: radial-gradient(circle at 30% 30%, #ff7a85 0%, #e63946 100%);
  }
  .sk-mechanism__badge--nir {
    background: radial-gradient(circle at 30% 30%, #d04a6e 0%, #9b1b3a 100%);
  }

  @keyframes sk-pulse-blue {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(59, 63, 191, 0.45);
    }
    50% {
      box-shadow: 0 0 0 18px rgba(59, 63, 191, 0);
    }
  }
  @keyframes sk-pulse-red {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.4);
    }
    50% {
      box-shadow: 0 0 0 18px rgba(230, 57, 70, 0);
    }
  }
  @keyframes sk-pulse-nir {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(155, 27, 58, 0.4);
    }
    50% {
      box-shadow: 0 0 0 18px rgba(155, 27, 58, 0);
    }
  }
  .sk-mechanism__badge--blue {
    animation: sk-pulse-blue 2.8s ease-out infinite;
  }
  .sk-mechanism__badge--red {
    animation: sk-pulse-red 2.8s ease-out infinite 0.5s;
  }
  .sk-mechanism__badge--nir {
    animation: sk-pulse-nir 2.8s ease-out infinite 1s;
  }

  @media (prefers-reduced-motion: reduce) {
    .sk-mechanism__badge--blue,
    .sk-mechanism__badge--red,
    .sk-mechanism__badge--nir {
      animation: none;
    }
  }

  .lp-mech__label-pill {
    display: inline-block;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    margin: 0 0 12px;
    color: #30273e;
    background: rgba(48, 39, 62, 0.06);
    align-self: flex-start;
  }
  .lp-mech__wavelength {
    display: block;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: rgba(48, 39, 62, 0.6);
    letter-spacing: 0.06em;
    margin: 0 0 6px;
  }
  .lp-mech__card-title {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #30273e;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .lp-mech__card-text {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14px;
    line-height: 1.55;
    color: #4a4458;
    margin: 0;
  }
  .lp-mech__diagram,
  .lp-mech__depth {
    margin: 24px auto;
    max-width: 600px;
    text-align: center;
  }
  .lp-mech__depth img {
    width: 100%;
    height: auto;
    max-height: 160px;
    object-fit: contain;
    aspect-ratio: 600 / 120;
    border-radius: 8px;
  }
  .lp-mech__depth-caption {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12.5px;
    font-style: italic;
    color: rgba(58, 52, 72, 0.7);
    margin: 8px 0 0;
  }
  .lp-mech__depth-caption p {
    margin: 0;
  }
  .lp-mech__diagram img {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }
  .lp-mech__timeline {
    text-align: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13.5px;
    line-height: 1.55;
    color: #4a4458;
    max-width: 720px;
    margin: 2rem auto 0;
    padding: 0 8px;
  }
  .lp-mech__timeline .citation-link {
    color: inherit;
    text-decoration: none;
    font-size: 0.75em;
    margin-left: 2px;
  }
  .lp-mech__timeline .citation-link:hover,
  .lp-mech__timeline .citation-link:focus-visible {
    text-decoration: underline;
  }
  .lp-mech__trust {
    text-align: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13px;
    font-style: italic;
    color: rgba(58, 52, 72, 0.7);
    margin: 0;
    padding: 0 8px;
  }

  /* ===== Hero row (image + paragraph + bullets) ===== */
  .lp-mech__hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 4vw, 40px);
    align-items: center;
    margin: 0 0 clamp(40px, 6vw, 64px);
  }
  @media (min-width: 990px) {
    .lp-mech__hero {
      grid-template-columns: 60% 40%;
      gap: clamp(32px, 5vw, 56px);
    }
  }
  .lp-mech__hero-image {
    width: 100%;
  }
  .lp-mech__hero-image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
  }
  .lp-mech__hero-caption {
    margin: 8px 0 0;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12.5px;
    font-style: italic;
    color: rgba(58, 52, 72, 0.65);
    text-align: center;
  }
  .lp-mech__hero-content {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .lp-mech__hero-text {
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: clamp(0.95rem, 2vw, 1.0625rem);
    line-height: 1.6;
    color: #4a4458;
  }
  .lp-mech__hero-text p {
    margin: 0 0 0.5em;
  }
  .lp-mech__hero-text p:last-child {
    margin-bottom: 0;
  }

  .lp-mech__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .lp-mech__bullet {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14.5px;
    line-height: 1.5;
    color: #4a4458;
  }
  .lp-mech__bullet-dot {
    flex: 0 0 auto;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 0.4em;
    background: #3b3fbf;
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.04);
  }
  .lp-mech__bullet-text {
    flex: 1 1 auto;
  }
  .lp-mech__bullet-text strong {
    color: #30273e;
    font-weight: 700;
  }
  .lp-mech__bullet-text p {
    margin: 0;
  }

  /* Card hover lift */
  .lp-mech__card {
    transition: transform 220ms ease, box-shadow 220ms ease;
  }
  @media (hover: hover) {
    .lp-mech__card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lp-mech__card {
      transition: none;
    }
    .lp-mech__card:hover {
      transform: none;
    }
  }
</style>

<section class="sk-lp-section lp-mech" aria-labelledby="lp-mech-heading-{{ section.id }}">
  <div class="lp-mech__inner">
    <header class="lp-mech__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="lp-mech__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 id="lp-mech-heading-{{ section.id }}" class="lp-mech__title">
        {{ section.settings.heading | default: 'Hvordan det fungerer' }}
      </h2>
      {%- if section.settings.intro != blank -%}
        <p class="lp-mech__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    {%- if section.settings.diagram_image != blank -%}
      <div class="lp-mech__diagram">
        <img
          src="{{ section.settings.diagram_image | image_url: width: 1080 }}"
          srcset="{{ section.settings.diagram_image | image_url: width: 540 }} 540w, {{ section.settings.diagram_image | image_url: width: 1080 }} 1080w"
          sizes="(max-width: 768px) 90vw, 540px"
          width="1080"
          height="608"
          alt="{{ section.settings.diagram_alt | default: 'Diagram av blått og rødt LED-lys' | escape }}"
          loading="lazy"
          decoding="async"
        >
      </div>
    {%- endif -%}

    {%- assign hero_bullets = section.blocks | where: 'type', 'bullet' -%}
    {%- if section.settings.hero_image != blank or section.settings.hero_paragraph != blank or hero_bullets.size > 0 -%}
      <div class="lp-mech__hero">
        {%- if section.settings.hero_image != blank -%}
          <div class="lp-mech__hero-image">
            <img
              src="{{ section.settings.hero_image | image_url: width: 1200 }}"
              srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 989px) 92vw, 60vw"
              alt="{{ section.settings.hero_image_alt | default: 'Illustrasjon av hvordan 415nm, 630nm og 830nm lys trenger inn i hudens lag' | escape }}"
              loading="lazy"
              decoding="async"
              width="{{ section.settings.hero_image.width }}"
              height="{{ section.settings.hero_image.height }}"
            >
            {%- if section.settings.hero_image_caption != blank -%}
              <p class="lp-mech__hero-caption">{{ section.settings.hero_image_caption }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="lp-mech__hero-content">
          {%- if section.settings.hero_paragraph != blank -%}
            <div class="lp-mech__hero-text">{{ section.settings.hero_paragraph }}</div>
          {%- endif -%}
          {%- if hero_bullets.size > 0 -%}
            <ul class="lp-mech__bullets">
              {%- for block in hero_bullets -%}
                <li class="lp-mech__bullet" {{ block.shopify_attributes }}>
                  <span
                    class="lp-mech__bullet-dot"
                    aria-hidden="true"
                    {% if block.settings.dot_color != blank %}
                      style="background: {{ block.settings.dot_color }};"
                    {% endif %}
                  ></span>
                  <span class="lp-mech__bullet-text">{{ block.settings.text }}</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="lp-mech__grid">
      <article class="lp-mech__card">
        {%- if section.settings.card1_label != blank -%}
          <span class="lp-mech__label-pill">{{ section.settings.card1_label }}</span>
        {%- endif -%}
        <div
          class="lp-mech__badge sk-mechanism__badge--blue"
          role="img"
          aria-label="Bølgelengde {{ section.settings.card1_wavelength | default: '415' | replace: ' nm', '' }} nanometer"
          {% if section.settings.card1_color_from != blank and section.settings.card1_color_to != blank %}
            style="background: radial-gradient(circle at 30% 30%, {{ section.settings.card1_color_to }} 0%, {{ section.settings.card1_color_from }} 100%);"
          {% endif %}
        >
          {{ section.settings.card1_wavelength | default: '415 nm' }}
        </div>
        {%- if section.settings.card1_wavelength != blank -%}
          <span class="lp-mech__wavelength">{{ section.settings.card1_wavelength }}</span>
        {%- endif -%}
        <h3 class="lp-mech__card-title">
          {{
            section.settings.card1_title
            | default: section.settings.blue_title
            | default: 'Reduserer bakteriene bak utbrudd'
          }}
        </h3>
        <div class="lp-mech__card-text">
          {{ section.settings.card1_body | default: section.settings.blue_text }}
        </div>
      </article>

      <article class="lp-mech__card">
        {%- if section.settings.card2_label != blank -%}
          <span class="lp-mech__label-pill">{{ section.settings.card2_label }}</span>
        {%- endif -%}
        <div
          class="lp-mech__badge sk-mechanism__badge--red"
          role="img"
          aria-label="Bølgelengde {{ section.settings.card2_wavelength | default: '630' | replace: ' nm', '' }} nanometer"
          {% if section.settings.card2_color_from != blank and section.settings.card2_color_to != blank %}
            style="background: radial-gradient(circle at 30% 30%, {{ section.settings.card2_color_to }} 0%, {{ section.settings.card2_color_from }} 100%);"
          {% endif %}
        >
          {{ section.settings.card2_wavelength | default: '630 nm' }}
        </div>
        {%- if section.settings.card2_wavelength != blank -%}
          <span class="lp-mech__wavelength">{{ section.settings.card2_wavelength }}</span>
        {%- endif -%}
        <h3 class="lp-mech__card-title">
          {{
            section.settings.card2_title
            | default: section.settings.red_title
            | default: 'Demper betennelse og rødhet'
          }}
        </h3>
        <div class="lp-mech__card-text">
          {{ section.settings.card2_body | default: section.settings.red_text }}
        </div>
      </article>

      <article class="lp-mech__card">
        {%- if section.settings.card3_label != blank -%}
          <span class="lp-mech__label-pill">{{ section.settings.card3_label }}</span>
        {%- endif -%}
        <div
          class="lp-mech__badge sk-mechanism__badge--nir"
          role="img"
          aria-label="Bølgelengde {{ section.settings.card3_wavelength | default: '830' | replace: ' nm', '' }} nanometer"
          {% if section.settings.card3_color_dark != blank and section.settings.card3_color_light != blank %}
            style="background: radial-gradient(circle at 30% 30%, {{ section.settings.card3_color_light }} 0%, {{ section.settings.card3_color_dark }} 100%);"
          {% endif %}
        >
          {{ section.settings.card3_wavelength | default: '830 nm' }}
        </div>
        {%- if section.settings.card3_wavelength != blank -%}
          <span class="lp-mech__wavelength">{{ section.settings.card3_wavelength }}</span>
        {%- endif -%}
        <h3 class="lp-mech__card-title">
          {{ section.settings.card3_title | default: 'Styrker hudens egen reparasjon' }}
        </h3>
        <div class="lp-mech__card-text">
          {{ section.settings.card3_body }}
        </div>
      </article>
    </div>

    {%- if section.settings.show_depth_diagram and section.settings.depth_diagram != blank -%}
      <div class="lp-mech__depth">
        <img
          src="{{ section.settings.depth_diagram | image_url: width: 1200 }}"
          srcset="{{ section.settings.depth_diagram | image_url: width: 600 }} 600w, {{ section.settings.depth_diagram | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 640px) 90vw, 600px"
          alt="{{ section.settings.depth_diagram_alt | default: 'Diagram som viser at hver bølgelengde når en annen dybde i huden' | escape }}"
          loading="lazy"
          decoding="async"
          width="600"
          height="120"
        >
        {%- if section.settings.depth_caption != blank -%}
          <div class="lp-mech__depth-caption">{{ section.settings.depth_caption }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.timeline_line != blank -%}
      <p class="lp-mech__timeline">
        {{ section.settings.timeline_line }}
        {%- if section.settings.timeline_citation_marker != blank -%}
          <sup
            ><a href="#kilder" class="citation-link" aria-label="Se kilder">
              {{- section.settings.timeline_citation_marker -}}
            </a></sup
          >
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- if section.settings.trust_line != blank -%}
      <p class="lp-mech__trust" style="margin-top:16px;">
        {{ section.settings.trust_line }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Mechanism",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    { "type": "header", "content": "Header" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Tre bølgelengder. Ett mål."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hvordan Skinora® Clear virker"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "Tre kliniske bølgelengder – samme prinsipp som brukes på hudklinikk, tilpasset trygg bruk hjemme."
    },

    { "type": "header", "content": "Hero-rad (illustrasjon + tekst)" },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero-illustrasjon (60%-kolonne, venstre)"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Alt-tekst for hero-illustrasjon",
      "default": "Illustrasjon av hvordan 415nm, 630nm og 830nm lys trenger inn i hudens lag"
    },
    {
      "type": "text",
      "id": "hero_image_caption",
      "label": "Bildetekst under illustrasjon",
      "default": "Illustrasjon: omtrentlig inntrengningsdybde i huden."
    },
    {
      "type": "richtext",
      "id": "hero_paragraph",
      "label": "Hero-paragraf (40%-kolonne, høyre)",
      "default": "<p>Skinora® Clear kombinerer tre bølgelengder lys som trenger ned i hver sitt lag av huden. Sammen angriper de aknen fra tre vinkler samtidig – bakteriene som starter utbruddet, betennelsen som gjør det synlig, og reparasjonen som får huden tilbake i balanse.</p>"
    },

    { "type": "header", "content": "Kort 1 — Blått lys" },
    {
      "type": "text",
      "id": "card1_label",
      "label": "Etikett (pill)",
      "default": "Blått lys"
    },
    {
      "type": "text",
      "id": "card1_wavelength",
      "label": "Bølgelengde",
      "default": "415 nm"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Tittel",
      "default": "Reduserer bakteriene bak utbrudd"
    },
    {
      "type": "richtext",
      "id": "card1_body",
      "label": "Brødtekst",
      "default": "<p>Blått lys virker i det øverste hudlaget og bryter ned forbindelsene som lar <em>Cutibacterium acnes</em> overleve i porene. Færre bakterier betyr færre nye kviser.</p>"
    },
    {
      "type": "color",
