{%- comment -%}
  sk-lp-mechanism.liquid
  "Hvordan det fungerer" — wavelength mechanism explainer.
  Two side-by-side cards (stacked on mobile) + trust line below.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}

<style>
  .lp-mech {
    background: transparent;
    padding: clamp(56px, 8vw, 96px) 16px;
  }
  .lp-mech__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .lp-mech__head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(32px, 5vw, 56px);
  }
  .lp-mech__eyebrow {
    display: block;
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(58, 52, 72, 0.7);
    margin-bottom: 12px;
  }
  .lp-mech__title {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', Georgia, serif;
    font-size: clamp(26px, 4vw, 34px);
    font-weight: 400;
    color: #3a3448;
    letter-spacing: 0.4px;
    line-height: 1.25;
    margin: 0 0 12px;
  }
  .lp-mech__intro {
    font-family: 'sofia-pro', sofia-pro-fallback, Assistant, sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #4a4458;
    margin: 0;
  }

  .lp-mech__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 28px;
  }
  @media (min-width: 768px) {
    .lp-mech__grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
  .lp-mech__card {
    background: #fff;
    border: 1px solid rgba(48, 39, 62, 0.08);
    border-radius: 14px;
    padding: clamp(20px, 3vw, 28px);
    text-align: left;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
  }
  .lp-mech__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #fff;
    text-transform: uppercase;
  }
  .lp-mech__icon--blue {
    background: radial-gradient(circle at 30% 30%, #6aa9ff 0%, #2563eb 70%, #1e3a8a 100%);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
  }
  .lp-mech__icon--red {
    background: radial-gradient(circle at 30% 30%, #ff8a8a 0%, #d6336c 70%, #8b1d3f 100%);
    box-shadow: 0 6px 20px rgba(214, 51, 108, 0.35);
  }
  .lp-mech__label-pill {
    display: inline-block;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 12px;
    color: #30273e;
    background: rgba(48, 39, 62, 0.06);
  }
  .lp-mech__wavelength {
    display: block;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: rgba(48, 39, 62, 0.6);
    letter-spacing: 0.06em;
    margin: 0 0 6px;
  }
  .lp-mech__card-title {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #30273e;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .lp-mech__card-text {
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14px;
    line-height: 1.55;
    color: #4a4458;
    margin: 0;
  }
  .lp-mech__diagram {
    margin: 8px auto 24px;
    max-width: 540px;
    text-align: center;
  }
  .lp-mech__diagram img {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }
  .lp-mech__timeline {
    text-align: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 14px;
    line-height: 1.55;
    color: #4a4458;
    margin: 4px 0 0;
    padding: 0 8px;
  }
  .lp-mech__timeline .citation-link {
    color: inherit;
    text-decoration: none;
    font-size: 0.75em;
    margin-left: 2px;
  }
  .lp-mech__timeline .citation-link:hover,
  .lp-mech__timeline .citation-link:focus-visible {
    text-decoration: underline;
  }
  .lp-mech__trust {
    text-align: center;
    font-family: 'sofia-pro', sofia-pro-fallback, sans-serif;
    font-size: 13px;
    font-style: italic;
    color: rgba(58, 52, 72, 0.7);
    margin: 0;
    padding: 0 8px;
  }
</style>

<section class="sk-lp-section lp-mech" aria-labelledby="lp-mech-heading-{{ section.id }}">
  <div class="lp-mech__inner">
    <header class="lp-mech__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="lp-mech__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 id="lp-mech-heading-{{ section.id }}" class="lp-mech__title">
        {{ section.settings.heading | default: 'Hvordan det fungerer' }}
      </h2>
      {%- if section.settings.intro != blank -%}
        <p class="lp-mech__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    {%- if section.settings.diagram_image != blank -%}
      <div class="lp-mech__diagram">
        <img
          src="{{ section.settings.diagram_image | image_url: width: 1080 }}"
          srcset="{{ section.settings.diagram_image | image_url: width: 540 }} 540w, {{ section.settings.diagram_image | image_url: width: 1080 }} 1080w"
          sizes="(max-width: 768px) 90vw, 540px"
          width="1080"
          height="608"
          alt="{{ section.settings.diagram_alt | default: 'Diagram av blått og rødt LED-lys' | escape }}"
          loading="lazy"
          decoding="async"
        >
      </div>
    {%- endif -%}

    <div class="lp-mech__grid">
      <article class="lp-mech__card">
        {%- if section.settings.card1_label != blank -%}
          <span class="lp-mech__label-pill">{{ section.settings.card1_label }}</span>
        {%- endif -%}
        <div
          class="lp-mech__icon lp-mech__icon--blue"
          aria-hidden="true"
          {% if section.settings.card1_color_from != blank and section.settings.card1_color_to != blank %}
            style="background: radial-gradient(circle at 30% 30%, {{ section.settings.card1_color_to }} 0%, {{ section.settings.card1_color_from }} 70%, {{ section.settings.card1_color_from }} 100%);"
          {% endif %}
        >
          {{ section.settings.card1_wavelength | default: '415 nm' }}
        </div>
        {%- if section.settings.card1_wavelength != blank -%}
          <span class="lp-mech__wavelength">{{ section.settings.card1_wavelength }}</span>
        {%- endif -%}
        <h3 class="lp-mech__card-title">
          {{
            section.settings.card1_title
            | default: section.settings.blue_title
            | default: 'Reduserer bakteriene bak utbrudd'
          }}
        </h3>
        <div class="lp-mech__card-text">
          {{ section.settings.card1_body | default: section.settings.blue_text }}
        </div>
      </article>

      <article class="lp-mech__card">
        {%- if section.settings.card2_label != blank -%}
          <span class="lp-mech__label-pill">{{ section.settings.card2_label }}</span>
        {%- endif -%}
        <div
          class="lp-mech__icon lp-mech__icon--red"
          aria-hidden="true"
          {% if section.settings.card2_color_from != blank and section.settings.card2_color_to != blank %}
            style="background: radial-gradient(circle at 30% 30%, {{ section.settings.card2_color_to }} 0%, {{ section.settings.card2_color_from }} 70%, {{ section.settings.card2_color_from }} 100%);"
          {% endif %}
        >
          {{ section.settings.card2_wavelength | default: '633 nm' }}
        </div>
        {%- if section.settings.card2_wavelength != blank -%}
          <span class="lp-mech__wavelength">{{ section.settings.card2_wavelength }}</span>
        {%- endif -%}
        <h3 class="lp-mech__card-title">
          {{
            section.settings.card2_title
            | default: section.settings.red_title
            | default: 'Demper betennelse og støtter reparasjon'
          }}
        </h3>
        <div class="lp-mech__card-text">
          {{ section.settings.card2_body | default: section.settings.red_text }}
        </div>
      </article>
    </div>

    {%- if section.settings.timeline_line != blank -%}
      <p class="lp-mech__timeline">
        {{ section.settings.timeline_line }}
        {%- if section.settings.timeline_citation_marker != blank -%}
          <sup
            ><a href="#kilder" class="citation-link" aria-label="Se kilder">
              {{- section.settings.timeline_citation_marker -}}
            </a></sup
          >
        {%- endif -%}
      </p>
    {%- endif -%}

    {%- if section.settings.trust_line != blank -%}
      <p class="lp-mech__trust" style="margin-top:16px;">
        {{ section.settings.trust_line }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Mechanism",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    { "type": "header", "content": "Header" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Tre bølgelengder. Ett mål."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hvordan Skinora® Clear virker"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro-tekst",
      "default": "To bølgelengder med lys, samme prinsipp som brukes på hudklinikk – tilpasset for trygg bruk hjemme."
    },

    { "type": "header", "content": "Kort 1 — Blått lys" },
    {
      "type": "text",
      "id": "card1_label",
      "label": "Etikett (pill)",
      "default": "Blått lys"
    },
    {
      "type": "text",
      "id": "card1_wavelength",
      "label": "Bølgelengde",
      "default": "415 nm"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Tittel",
      "default": "Reduserer bakteriene bak utbrudd"
    },
    {
      "type": "richtext",
      "id": "card1_body",
      "label": "Brødtekst",
      "default": "<p>Når blått lys treffer huden, bryter det ned forbindelsene som lar <em>Cutibacterium acnes</em> — bakterien bak de fleste utbrudd — overleve i porene. Færre bakterier betyr færre nye kviser.</p>"
    },
    {
      "type": "color",
      "id": "card1_color_from",
      "label": "Blå gradient (mørk)",
      "default": "#1e6dff"
    },
    {
      "type": "color",
      "id": "card1_color_to",
      "label": "Blå gradient (lys)",
      "default": "#6aa7ff"
    },

    { "type": "header", "content": "Kort 2 — Rødt lys" },
    {
      "type": "text",
      "id": "card2_label",
      "label": "Etikett (pill)",
      "default": "Rødt lys"
    },
    {
      "type": "text",
      "id": "card2_wavelength",
      "label": "Bølgelengde",
      "default": "633 nm"
    },
    {
      "type": "text",
      "id": "card2_title",
      "label": "Tittel",
      "default": "Demper betennelse og støtter reparasjon"
    },
    {
      "type": "richtext",
      "id": "card2_body",
      "label": "Brødtekst",
      "default": "<p>Rødt lys trenger dypere ned i huden og roer den inflammatoriske responsen, samtidig som det støtter hudens egen reparasjon. Resultatet: mindre rødhet, raskere tilheling.</p>"
    },
    {
      "type": "color",
      "id": "card2_color_from",
      "label": "Rød gradient (mørk)",
      "default": "#d33333"
    },
    {
      "type": "color",
      "id": "card2_color_to",
      "label": "Rød gradient (lys)",
      "default": "#ff7a7a"
    },

    { "type": "header", "content": "Tidslinje + kilde" },
    {
      "type": "textarea",
      "id": "timeline_line",
      "label": "Tidslinje-tekst",
      "default": "Forskning viser at de fleste ser de første tegnene etter 2–4 uker med jevn bruk, og full effekt etter 6–8 uker."
    },
    {
      "type": "text",
      "id": "timeline_citation_marker",
      "label": "Kildemerke (lenker til #kilder)",
      "default": "¹"
    },

    { "type": "header", "content": "Trust-linje (valgfritt)" },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust-linje under kortene",
      "default": "Klinisk dokumentert teknologi – samme prinsipp som hos hudterapeut."
    },

    { "type": "header", "content": "Diagram (valgfritt)" },
    {
      "type": "image_picker",
      "id": "diagram_image",
      "label": "Diagrambilde"
    },
    {
      "type": "text",
      "id": "diagram_alt",
      "label": "Bildebeskrivelse (alt)",
      "default": "Diagram av blått og rødt LED-lys"
    }
  ],
  "presets": [
    {
      "name": "LP Mechanism"
    }
  ]
}
{% endschema %}
