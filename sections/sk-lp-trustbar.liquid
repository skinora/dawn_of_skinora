{%- comment -%}
  sk-lp-trustbar.liquid
  Horizontal trust / USP bar for landing pages. Each item is a dynamic block.
{%- endcomment -%}

{{ 'section-sk-lp-radiance-face.css' | asset_url | stylesheet_tag }}
{{ 'section-sk-lp-trustbar.css' | asset_url | stylesheet_tag }}

<div class="sk-lp">
  <section class="lp-trustbar">
    <div class="lp-trustbar__grid">
      {%- for block in section.blocks -%}
        <div class="lp-trustbar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="lp-trustbar__icon"
              ><img
                src="{{ block.settings.icon | image_url: height: 48 }}"
                alt=""
                role="presentation"
                width="48"
                height="48"
                loading="lazy"
            ></span>
          {%- endif -%}
          <span class="lp-trustbar__text">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP Trust Bar",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Trust-element",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ikon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Gratis frakt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Trust Bar",
      "blocks": [
        { "type": "item", "settings": { "text": "Norskutviklet" } },
        { "type": "item", "settings": { "text": "Sendes fra norsk lager" } },
        { "type": "item", "settings": { "text": "30 dagers garanti" } },
        { "type": "item", "settings": { "text": "Vipps & Klarna" } }
      ]
    }
  ]
}
{% endschema %}
