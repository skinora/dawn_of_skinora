{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Local restyling — uses Skinora typography tokens so the banner matches
  the LP design language. Scoped to this section instance via
  `.section-{{ section.id }}`, so nothing leaks globally. The full webshop
  redesign will replace this; until then, this keeps the collection
  header clean, modern, and brand-aligned.
{%- endcomment -%}
{%- style -%}
  .collection-hero.section-{{ section.id }} {
    --sk-collection-header-max: {{ section.settings.header_max_width }}px;
    --sk-collection-text-align: {{ section.settings.header_align }};
    background: var(--paper-0);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__inner {
    padding-top: var(--space-section-md);
    padding-bottom: var(--space-6);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__text-wrapper {
    max-width: var(--sk-collection-header-max);
    margin-inline: auto;
    text-align: var(--sk-collection-text-align);
    padding: 0;
  }

  /* H1 — match the LP serif display treatment */
  .collection-hero.section-{{ section.id }} .collection-hero__title {
    font-family: var(--ff-serif);
    font-size: var(--fs-4xl);
    font-weight: var(--fw-medium);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--ink-900);
    margin: 0;
  }

  .collection-hero.section-{{ section.id }} .sk-collection-hero__subheading {
    font-family: var(--ff-sans);
    font-size: var(--fs-lg);
    font-weight: var(--fw-regular);
    line-height: var(--lh-normal);
    color: var(--ink-500);
    max-width: 52ch;
    margin: var(--space-3) auto 0;
  }

  /* Kill the 2008-style horizontal rule — whitespace handles separation */
  .collection-hero.section-{{ section.id }} .sk-collection-hero__divider {
    display: none;
  }

  .collection-hero.section-{{ section.id }} .sk-collection-hero__description {
    margin-top: var(--space-6);
  }

  /* Description body — brand-tuned typography */
  .collection-hero.section-{{ section.id }} .collection-hero__description.rte {
    max-width: var(--measure-body);
    margin-inline: auto;
    text-align: left;
    font-family: var(--ff-sans);
    font-size: var(--fs-md);
    line-height: var(--lh-normal);
    color: var(--ink-700);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte p {
    margin: 0 0 var(--space-4);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte p:last-child {
    margin-bottom: 0;
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte strong {
    color: var(--ink-900);
    font-weight: var(--fw-semibold);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte a {
    color: var(--ink-900);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .collection-hero.section-{{ section.id }} .collection-hero__description.rte a:hover {
    color: var(--accent-clay);
  }

  /* Bullet list — drop default disc markers, use a small clay dot */
  .collection-hero.section-{{ section.id }} .collection-hero__description.rte ul {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte li {
    position: relative;
    padding-left: 1.25em;
  }

  .collection-hero.section-{{ section.id }} .collection-hero__description.rte li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-clay);
  }

  @media screen and (max-width: 749px) {
    .collection-hero.section-{{ section.id }} .collection-hero__inner {
      padding-top: var(--space-section-sm);
      padding-bottom: var(--space-5);
    }
    .collection-hero.section-{{ section.id }} .sk-collection-hero__description {
      margin-top: var(--space-5);
    }
  }
{%- endstyle -%}

{%- assign hero_title = section.settings.heading_override | default: collection.title -%}
{%- assign subheading_plain = section.settings.subheading | strip_html | strip -%}

<div class="collection-hero section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner container {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      <h1 class="collection-hero__title">
        {{- hero_title | escape -}}
      </h1>

      {%- if subheading_plain != blank -%}
        <p class="sk-collection-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_divider -%}
      <div class="sk-collection-hero__divider" aria-hidden="true"></div>
    {%- endif -%}

    {%- if section.settings.show_collection_description -%}
      <div class="sk-collection-hero__description">
        <div class="collection-hero__description rte">{{ collection.description }}</div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "text",
      "id": "heading_override",
      "label": "Heading override",
      "info": "Optional. If blank, uses collection title."
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "range",
      "id": "header_max_width",
      "min": 480,
      "max": 960,
      "step": 16,
      "unit": "px",
      "label": "Header max width",
      "default": 720
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
