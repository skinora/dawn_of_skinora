{%- comment -%}
  sk-lp-cross-sell.liquid
  Editorial cross-sell product tiles for landing pages.
  - Auto-fetches product data via product_list setting (or falls back to manual blocks).
  - Auto-excludes the current page's matching product handle.
  - Premium "matted print" card style on warm-cream background.
{%- endcomment -%}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#FAF7F2'
  assign current_handle = page.handle
-%}

<style>
  .sk-xsell {
    background: {{ bg_color }};
    padding: 96px 0;
    font-family: 'sofia-pro', 'sofia-pro-fallback', Assistant, sans-serif;
    color: #1A2543;
  }
  .sk-xsell__container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .sk-xsell__header {
    max-width: 560px;
    margin: 0 0 48px;
  }
  .sk-xsell__eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1A2543;
    font-weight: 600;
    margin: 0 0 12px;
  }
  .sk-xsell__heading {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 400;
    line-height: 1.15;
    color: #1A2543;
    margin: 0 0 16px;
  }
  .sk-xsell__sub {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.5;
    color: #4A5568;
    margin: 0;
  }

  .sk-xsell__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
  }

  .sk-xsell__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid rgba(20, 30, 55, 0.06);
    border-radius: 20px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    height: 100%;
    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__card:focus-visible {
    outline: 2px solid #1A2543;
    outline-offset: 4px;
    border-radius: 22px;
  }

  .sk-xsell__image-wrap {
    margin: 16px 16px 0;
    border-radius: 14px;
    overflow: hidden;
    background: linear-gradient(160deg, #EEF1F6 0%, #E2E8F0 100%);
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sk-xsell__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__image-placeholder {
    color: #94A3B8;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sk-xsell__body {
    padding: 20px 20px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .sk-xsell__tag {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6B7280;
    margin: 0 0 8px;
    font-weight: 500;
  }
  .sk-xsell__name {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 500;
    color: #1A2543;
    margin: 0 0 8px;
    line-height: 1.25;
  }
  .sk-xsell__benefit {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: #4A5568;
    margin: 0 0 16px;
    flex: 1;
  }
  .sk-xsell__price {
    font-size: 16px;
    font-weight: 600;
    color: #1A2543;
    margin: 0 0 16px;
  }
  .sk-xsell__cta {
    font-size: 14px;
    font-weight: 600;
    color: #1A2543;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .sk-xsell__cta-arrow {
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .sk-xsell__section-cta-wrap {
    text-align: center;
    margin-top: 48px;
  }
  .sk-xsell__section-cta {
    display: inline-block;
    position: relative;
    color: #1A2543;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    padding-bottom: 4px;
  }
  .sk-xsell__section-cta::after {
    content: '';
    position: absolute;
    left: 25%;
    bottom: 0;
    width: 50%;
    height: 1px;
    background: #1A2543;
    transition: left 280ms cubic-bezier(0.4, 0, 0.2, 1), width 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__section-cta:hover::after,
  .sk-xsell__section-cta:focus-visible::after {
    left: 0;
    width: 100%;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .sk-xsell__card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(20, 30, 55, 0.10);
    }
    .sk-xsell__card:hover .sk-xsell__image {
      transform: scale(1.04);
    }
    .sk-xsell__card:hover .sk-xsell__cta-arrow {
      transform: translateX(4px);
    }
  }

  @media (max-width: 749px) {
    .sk-xsell {
      padding: 64px 0;
    }
    .sk-xsell__container {
      padding: 0 16px;
    }
    .sk-xsell__header {
      text-align: center;
      margin: 0 auto 32px;
    }
    .sk-xsell__grid {
      gap: 20px;
    }
    .sk-xsell__name {
      font-size: 18px;
    }
  }
</style>

<section class="sk-xsell" aria-labelledby="sk-xsell-heading">
  <div class="sk-xsell__container">
    <div class="sk-xsell__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="sk-xsell__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 id="sk-xsell-heading" class="sk-xsell__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sk-xsell__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <ul class="sk-xsell__grid" role="list">
      {%- comment -%} Render from product_list setting if any, else fall back to blocks {%- endcomment -%}
      {%- assign rendered_count = 0 -%}
      {%- for product in section.settings.products -%}
        {%- if product.handle == current_handle -%}
          {%- continue -%}
        {%- endif -%}
        {%- assign rendered_count = rendered_count | plus: 1 -%}
        {%- assign tag_label = '' -%}
        {%- assign benefit_text = '' -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank and block.settings.product.handle == product.handle -%}
            {%- assign tag_label = block.settings.tag -%}
            {%- assign benefit_text = block.settings.benefit -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign card_alt = product.featured_image.alt | default: product.title -%}
        {%- capture card_aria -%}Utforsk {{ product.title }} – fra {{ product.price | money }}{%- endcapture -%}
        <li>
          <a href="{{ product.url }}" class="sk-xsell__card" aria-label="{{ card_aria | escape }}">
            <div class="sk-xsell__image-wrap">
              {%- if product.featured_image -%}
                <img
                  class="sk-xsell__image"
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1000 }} 1000w"
                  sizes="(max-width: 749px) 100vw, (max-width: 1240px) 50vw, 400px"
                  alt="{{ card_alt | escape }}"
                  width="800"
                  height="1000"
                  loading="lazy"
                  decoding="async"
                >
              {%- else -%}
                <span class="sk-xsell__image-placeholder">{{ product.title }}</span>
              {%- endif -%}
            </div>
            <div class="sk-xsell__body">
              {%- if tag_label != blank -%}
                <p class="sk-xsell__tag" aria-hidden="true">{{ tag_label }}</p>
              {%- endif -%}
              <p class="sk-xsell__name">{{ product.title }}</p>
              {%- if benefit_text != blank -%}
                <p class="sk-xsell__benefit">{{ benefit_text }}</p>
              {%- endif -%}
              <p class="sk-xsell__price">fra {{ product.price | money }}</p>
              <span class="sk-xsell__cta">Utforsk <span class="sk-xsell__cta-arrow" aria-hidden="true">→</span></span>
            </div>
          </a>
        </li>
      {%- endfor -%}

      {%- if rendered_count == 0 -%}
        {%- comment -%} Fallback: render blocks where a product is selected {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank and block.settings.product.handle != current_handle -%}
            {%- assign p = block.settings.product -%}
            {%- assign card_alt = p.featured_image.alt | default: p.title -%}
            {%- capture card_aria -%}Utforsk {{ p.title }} – fra {{ p.price | money }}{%- endcapture -%}
            <li {{ block.shopify_attributes }}>
              <a href="{{ p.url }}" class="sk-xsell__card" aria-label="{{ card_aria | escape }}">
                <div class="sk-xsell__image-wrap">
                  {%- if p.featured_image -%}
                    <img
                      class="sk-xsell__image"
                      src="{{ p.featured_image | image_url: width: 800 }}"
                      srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 800 }} 800w, {{ p.featured_image | image_url: width: 1000 }} 1000w"
                      sizes="(max-width: 749px) 100vw, (max-width: 1240px) 50vw, 400px"
                      alt="{{ card_alt | escape }}"
                      width="800"
                      height="1000"
                      loading="lazy"
                      decoding="async"
                    >
                  {%- else -%}
                    <span class="sk-xsell__image-placeholder">{{ p.title }}</span>
                  {%- endif -%}
                </div>
                <div class="sk-xsell__body">
                  {%- if block.settings.tag != blank -%}
                    <p class="sk-xsell__tag" aria-hidden="true">{{ block.settings.tag }}</p>
                  {%- endif -%}
                  <p class="sk-xsell__name">{{ p.title }}</p>
                  {%- if block.settings.benefit != blank -%}
                    <p class="sk-xsell__benefit">{{ block.settings.benefit }}</p>
                  {%- endif -%}
                  <p class="sk-xsell__price">fra {{ p.price | money }}</p>
                  <span class="sk-xsell__cta"
                    >Utforsk <span class="sk-xsell__cta-arrow" aria-hidden="true">→</span></span
                  >
                </div>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>

    {%- if section.settings.show_section_cta and section.settings.section_cta_text != blank -%}
      <div class="sk-xsell__section-cta-wrap">
        <a href="{{ section.settings.section_cta_url | default: '/collections/all' }}" class="sk-xsell__section-cta">
          {{ section.settings.section_cta_text }} →
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Cross-sell",
  "tag": "section",
  "class": "sk-lp-section",
  "settings": [
    {
      "type": "header",
      "content": "Innhold"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OPPDAG MER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Andre Skinora-produkter"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Bygg ditt komplette LED-rituale – designet for ansikt, hals og kropp."
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Produkter",
      "limit": 3,
      "info": "Velg opp til 3 produkter. Det aktuelle produktet for siden filtreres automatisk bort."
    },
    {
      "type": "header",
      "content": "Seksjons-CTA"
    },
    {
      "type": "checkbox",
      "id": "show_section_cta",
      "label": "Vis seksjons-CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "section_cta_text",
      "label": "CTA-tekst",
      "default": "Se alle Skinora-produkter"
    },
    {
      "type": "url",
      "id": "section_cta_url",
      "label": "CTA-lenke",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Stil"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Bakgrunnsfarge",
      "default": "#FAF7F2"
    }
  ],
  "blocks": [
    {
      "type": "card_meta",
      "name": "Kort-metadata (valgfritt)",
      "settings": [
        {
          "type": "paragraph",
          "content": "Knytt eyebrow-tag og fordeltekst til et spesifikt produkt valgt over."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Eyebrow-tag",
          "info": "F.eks. ANSIKT, HALS & DEKOLLETÉ, KROPP"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Fordeltekst (maks 70 tegn)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Cross-sell",
      "category": "Skinora",
      "blocks": [{ "type": "card_meta" }, { "type": "card_meta" }]
    }
  ]
}
{% endschema %}
