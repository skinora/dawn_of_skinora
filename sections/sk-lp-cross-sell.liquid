{%- comment -%}
  sk-lp-cross-sell.liquid
  Editorial cross-sell product tiles for landing pages.
  - Block-based: each "product_card" block = one tile with its own product + eyebrow tag + benefit.
  - Auto-excludes the current page's matching product (e.g. on /pages/skinora-clear, skips skinora-clear).
  - Strict 4:5 image frame, SVG-skipping, lazy-loaded.
{%- endcomment -%}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#FAF7F2'
  assign current_handle = page.handle
  assign current_product_handle = page.handle | remove: 'skinora-' | prepend: 'skinora-'
-%}

<style>
  .sk-xsell {
    background: {{ bg_color }};
    padding: 96px 0;
    font-family: 'sofia-pro', 'sofia-pro-fallback', Assistant, sans-serif;
    color: #1A2543;
  }
  .sk-xsell__container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .sk-xsell__header {
    max-width: 560px;
    margin: 0 0 48px;
  }
  .sk-xsell__eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1A2543;
    font-weight: 600;
    margin: 0 0 12px;
  }
  .sk-xsell__heading {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 400;
    line-height: 1.15;
    color: #1A2543;
    margin: 0 0 16px;
  }
  .sk-xsell__sub {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.5;
    color: #4A5568;
    margin: 0;
  }

  .sk-xsell__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
    justify-content: center;
  }
  .sk-xsell__grid > li {
    display: flex;
    justify-content: center;
  }

  .sk-xsell__card {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 420px;
    background: #fff;
    border: 1px solid rgba(20, 30, 55, 0.06);
    border-radius: 20px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    text-decoration: none;
    color: inherit;
    padding: 16px 16px 24px;
    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__card:focus-visible {
    outline: 2px solid #1A2543;
    outline-offset: 4px;
    border-radius: 22px;
  }

  .sk-xsell__media {
    aspect-ratio: 4 / 5;
    border-radius: 14px;
    overflow: hidden;
    background: linear-gradient(160deg, #EEF1F6 0%, #E2E8F0 100%);
    margin-bottom: 20px;
  }
  .sk-xsell__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94A3B8;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sk-xsell__body {
    padding: 0 4px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .sk-xsell__tag {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6B7280;
    font-weight: 500;
    margin: 0 0 8px;
  }
  .sk-xsell__name {
    font-family: 'freight-text-pro', 'freight-text-pro-fallback', 'Playfair Display', Georgia, serif;
    font-size: clamp(18px, 1.4vw, 22px);
    font-weight: 500;
    color: #1A2543;
    margin: 0 0 8px;
    line-height: 1.25;
  }
  .sk-xsell__benefit {
    font-size: 15px;
    line-height: 1.5;
    color: #4A5568;
    margin: 0 0 16px;
    flex: 1;
  }
  .sk-xsell__price {
    font-size: 16px;
    font-weight: 600;
    color: #1A2543;
    margin: 0 0 12px;
  }
  .sk-xsell__cta {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: #1A2543;
    letter-spacing: 0.02em;
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sk-xsell__section-cta-wrap {
    text-align: center;
    margin-top: 48px;
  }
  .sk-xsell__section-cta {
    display: inline-block;
    position: relative;
    color: #1A2543;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    padding-bottom: 4px;
  }
  .sk-xsell__section-cta::after {
    content: '';
    position: absolute;
    left: 25%;
    bottom: 0;
    width: 50%;
    height: 1px;
    background: #1A2543;
    transition: left 280ms cubic-bezier(0.4, 0, 0.2, 1), width 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sk-xsell__section-cta:hover::after,
  .sk-xsell__section-cta:focus-visible::after {
    left: 0;
    width: 100%;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .sk-xsell__card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(20, 30, 55, 0.10);
    }
    .sk-xsell__card:hover .sk-xsell__media img {
      transform: scale(1.04);
    }
    .sk-xsell__card:hover .sk-xsell__cta {
      transform: translateX(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sk-xsell__card,
    .sk-xsell__media img,
    .sk-xsell__cta {
      transition: none !important;
    }
    .sk-xsell__card:hover {
      transform: none;
    }
    .sk-xsell__card:hover .sk-xsell__media img {
      transform: none;
    }
  }

  @media (max-width: 749px) {
    .sk-xsell {
      padding: 64px 0;
    }
    .sk-xsell__container {
      padding: 0 16px;
    }
    .sk-xsell__header {
      text-align: center;
      margin: 0 auto 32px;
    }
    .sk-xsell__grid {
      gap: 20px;
    }
  }
</style>

<section class="sk-xsell" aria-labelledby="sk-xsell-heading">
  <div class="sk-xsell__container">
    <div class="sk-xsell__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="sk-xsell__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 id="sk-xsell-heading" class="sk-xsell__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sk-xsell__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <ul class="sk-xsell__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type != 'product_card' -%}{%- continue -%}{%- endif -%}
        {%- assign p = block.settings.product -%}
        {%- if p == blank -%}{%- continue -%}{%- endif -%}
        {%- if p.handle == current_handle or p.handle == current_product_handle -%}{%- continue -%}{%- endif -%}

        {%- comment -%} Pick a real raster image, skipping SVG line-art {%- endcomment -%}
        {%- assign card_img = blank -%}
        {%- assign feat_src = p.featured_image.src | default: '' -%}
        {%- assign feat_is_svg = false -%}
        {%- if feat_src contains '.svg' -%}{%- assign feat_is_svg = true -%}{%- endif -%}
        {%- if p.featured_image and feat_is_svg == false -%}
          {%- assign card_img = p.featured_image -%}
        {%- endif -%}
        {%- if card_img == blank -%}
          {%- for media in p.media -%}
            {%- assign m_src = media.src | default: '' -%}
            {%- assign m_is_svg = false -%}
            {%- if m_src contains '.svg' -%}{%- assign m_is_svg = true -%}{%- endif -%}
            {%- if media.media_type == 'image' and m_is_svg == false -%}
              {%- assign card_img = media -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- assign tag_label = block.settings.eyebrow_tag -%}
        {%- assign benefit_text = block.settings.benefit -%}
        {%- assign card_alt = p.title | append: ' – ' | append: benefit_text | default: p.title -%}
        {%- capture card_aria -%}Utforsk {{ p.title }} – fra {{ p.price | money }}{%- endcapture -%}

        <li {{ block.shopify_attributes }}>
          <a href="{{ p.url }}" class="sk-xsell__card" aria-label="{{ card_aria | escape }}">
            <div class="sk-xsell__media">
              {%- if card_img != blank -%}
                <img
                  src="{{ card_img | image_url: width: 800 }}"
                  srcset="{{ card_img | image_url: width: 400 }} 400w, {{ card_img | image_url: width: 800 }} 800w, {{ card_img | image_url: width: 1200 }} 1200w"
                  sizes="(min-width: 768px) 380px, 90vw"
                  width="800"
                  height="1000"
                  loading="lazy"
                  decoding="async"
                  alt="{{ card_alt | escape }}"
                >
              {%- else -%}
                <span class="sk-xsell__media-placeholder">{{ p.title }}</span>
              {%- endif -%}
            </div>
            <div class="sk-xsell__body">
              {%- if tag_label != blank -%}
                <span class="sk-xsell__tag" aria-hidden="true">{{ tag_label }}</span>
              {%- endif -%}
              <h3 class="sk-xsell__name">{{ p.title }}</h3>
              {%- if benefit_text != blank -%}
                <p class="sk-xsell__benefit">{{ benefit_text }}</p>
              {%- endif -%}
              <p class="sk-xsell__price">fra {{ p.price | money }}</p>
              <span class="sk-xsell__cta">Utforsk →</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.show_section_cta and section.settings.section_cta_text != blank -%}
      <div class="sk-xsell__section-cta-wrap">
        <a href="{{ section.settings.section_cta_url | default: '/collections/all' }}" class="sk-xsell__section-cta">
          {{ section.settings.section_cta_text }} →
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LP Cross-sell",
  "tag": "section",
  "class": "sk-lp-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Innhold"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OPPDAG MER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Andre Skinora-produkter"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Bygg ditt komplette LED-rituale – designet for ansikt, hals og kropp."
    },
    {
      "type": "header",
      "content": "Seksjons-CTA"
    },
    {
      "type": "checkbox",
      "id": "show_section_cta",
      "label": "Vis seksjons-CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "section_cta_text",
      "label": "CTA-tekst",
      "default": "Se alle Skinora-produkter"
    },
    {
      "type": "url",
      "id": "section_cta_url",
      "label": "CTA-lenke"
    },
    {
      "type": "header",
      "content": "Stil"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Bakgrunnsfarge",
      "default": "#FAF7F2"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Produktkort",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "eyebrow_tag",
          "label": "Kategori-tag",
          "default": "ANSIKT"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Kort fordel (1 setning)",
          "default": "Rødt og NIR-lys for fastere, mer utstrålende hud."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP Cross-sell",
      "category": "Skinora",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
