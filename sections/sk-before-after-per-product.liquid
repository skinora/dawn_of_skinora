{% comment %}
  SK Before/After Per-Product Section
  Scroll-snap carousel — zero external JS dependencies.
  Data sourced from product.metafields.custom.before_after_testimonial_product
{% endcomment %}

<style>
  .sk-before-after {
    padding: 0 0 5rem;
    background-color: var(--color-white);
    position: relative;
    overflow: visible;
  }

  .sk-ba-slide {
    display: flex;
    justify-content: center;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .sk-testimonial-card {
    width: 100%;
    background: #fff;
    border-radius: 0;
    overflow: hidden;
    --sk-ba-image-base-height: clamp(260px, 30vw, 360px);
  }

  .sk-testimonial-card__images {
    position: relative;
    height: calc(var(--sk-ba-image-base-height) * 1.15);
    overflow: hidden;
  }

  .sk-testimonial-card__images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sk-ba-pill {
    position: absolute;
    top: 1.2rem;
    padding: 0.6rem 1.4rem;
    font-size: clamp(1.2rem, 1.5vw, 1.3rem);
    background: rgba(245, 245, 245, 0.95);
    border-radius: 0;
    font-weight: 500;
    color: var(--color-neutral-3);
    z-index: 3;
  }
  .sk-ba-pill--before {
    left: 1.2rem;
  }
  .sk-ba-pill--after {
    right: 1.2rem;
  }

  .sk-testimonial-card__content {
    padding: clamp(1.6rem, 2vw, 1.8rem) clamp(1.8rem, 2.5vw, 2rem) clamp(1rem, 1.25vw, 1.1rem);
    text-align: left;
  }

  .sk-testimonial-card__title {
    font-size: clamp(1.6rem, 2vw, 1.8rem);
    font-weight: 600;
    margin-bottom: 0.6rem;
    color: var(--color-black);
  }

  .sk-testimonial-card__meta {
    font-size: clamp(1.3rem, 1.8vw, 1.4rem);
    color: var(--color-neutral-2);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .sk-testimonial-card__text {
    font-size: clamp(1.4rem, 1.8vw, 1.5rem);
    line-height: 1.5;
    color: var(--color-neutral-3);
  }

  /* === PROGRESS DOTS (mobile only) === */
  .sk-before-after .sk-ba-progress {
    display: flex;
    justify-content: center;
    margin-top: 0.75rem;
  }
  .sk-before-after .sk-ba-progress__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }
  .sk-before-after .sk-ba-progress__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.2s ease, transform 0.2s ease;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .sk-before-after .sk-ba-progress__dot--active {
    background: var(--color-brand);
    transform: scale(1.25);
  }

  /* === SCROLL-SNAP TRACK === */
  .sk-before-after-viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .sk-ba-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .sk-ba-track::-webkit-scrollbar {
    display: none;
  }

  .sk-ba-slide {
    flex: 0 0 100%;
  }

  @media (min-width: 700px) {
    .sk-ba-slide {
      flex: 0 0 calc(50% - 10px);
    }
  }
  @media (min-width: 1024px) {
    .sk-ba-slide {
      flex: 0 0 calc(33.333% - 14px);
    }
  }

  /* === ARROWS === */
  .sk-before-after .sk-ba-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-white);
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
    z-index: 10;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    cursor: pointer;
    padding: 0;
  }
  .sk-before-after .sk-ba-arrow::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-top: 2px solid var(--color-brand);
    border-right: 2px solid var(--color-brand);
    top: 50%;
    left: 50%;
    transition: border-color 0.25s ease;
  }
  .sk-before-after .sk-ba-arrow--prev {
    left: clamp(12px, 2vw, 24px);
  }
  .sk-before-after .sk-ba-arrow--next {
    right: clamp(12px, 2vw, 24px);
  }
  .sk-before-after .sk-ba-arrow--prev::after {
    transform: translate(-50%, -50%) rotate(-135deg);
  }
  .sk-before-after .sk-ba-arrow--next::after {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .sk-before-after .sk-ba-arrow[data-visible='true'] {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 900px) {
    .sk-before-after .sk-ba-progress {
      display: none !important;
    }
    .sk-before-after-viewport {
      overflow: visible;
    }
    .sk-ba-track {
      overflow: hidden;
    }
  }
</style>

<section class="sk-before-after" data-section-id="{{ section.id }}">
  <div class="page-width">
    {% if section.settings.section_title != blank %}
      <div class="sk-section-header sk-section-header--center">
        <h2 class="sk-section-header__title">
          {{ section.settings.section_title }}
        </h2>
        {% if section.settings.section_subtitle != blank %}
          <p class="sk-section-header__subtitle">
            {{ section.settings.section_subtitle }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="sk-before-after-viewport">
      <div class="sk-ba-track">
        {% for item in product.metafields.custom.before_after_testimonial_product.value %}
          {% liquid
            assign image_value = item.image.value | default: item.image
            assign testimonial_alt_text = item.alt_text.value | default: item.alt_text
            assign testimonial_title = item.title.value | default: item.title
            assign testimonial_meta = item.meta.value | default: item.meta
            assign testimonial_quote = item.quote.value | default: item.quote
            assign display_alt = testimonial_alt_text | default: testimonial_title | default: 'Før og etter – Skinora Clear'

            assign img_src = null
            assign img_srcset = ''
            assign img_w = 460
            assign img_h = 360

            if image_value != blank
              if image_value.preview_image
                assign img_obj = image_value.preview_image
                assign img_src = img_obj | image_url: width: 460
                assign img_w = img_obj.width | default: 460
                assign img_h = img_obj.height | default: 360
                assign s300 = img_obj | image_url: width: 300
                assign s400 = img_obj | image_url: width: 400
                assign s500 = img_obj | image_url: width: 500
                assign img_srcset = s300 | append: ' 300w, ' | append: s400 | append: ' 400w, ' | append: s500 | append: ' 500w'
              elsif image_value.width
                assign img_obj = image_value
                assign img_src = img_obj | image_url: width: 460
                assign img_w = img_obj.width | default: 460
                assign img_h = img_obj.height | default: 360
                assign s300 = img_obj | image_url: width: 300
                assign s400 = img_obj | image_url: width: 400
                assign s500 = img_obj | image_url: width: 500
                assign img_srcset = s300 | append: ' 300w, ' | append: s400 | append: ' 400w, ' | append: s500 | append: ' 500w'
              else
                assign img_src = image_value | file_url
              endif
            endif
          %}
          <div class="sk-ba-slide">
            <div class="sk-testimonial-card">
              <div class="sk-testimonial-card__images">
                {% if img_src %}
                  <img
                    src="{{ img_src }}"
                    srcset="{{ img_srcset }}"
                    sizes="(max-width: 749px) 85vw, 400px"
                    alt="{{ display_alt | escape }}"
                    width="{{ img_w }}"
                    height="{{ img_h }}"
                    loading="lazy"
                    decoding="async"
                  >
                {% endif %}
                <span class="sk-ba-pill sk-ba-pill--before">FØR</span>
                <span class="sk-ba-pill sk-ba-pill--after">...OG ETTER</span>
              </div>

              <div class="sk-testimonial-card__content">
                {% if testimonial_title != blank %}
                  <h3 class="sk-testimonial-card__title">
                    {{ testimonial_title }}
                  </h3>
                {% endif %}
                {% if testimonial_meta != blank %}
                  <div class="sk-testimonial-card__meta">
                    {{ testimonial_meta }}
                    <span>✔</span>
                  </div>
                {% endif %}
                {% if testimonial_quote != blank %}
                  <p class="sk-testimonial-card__text">"{{ testimonial_quote }}"</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      <button type="button" class="sk-ba-arrow sk-ba-arrow--prev" aria-label="Forrige" data-visible="false"></button>
      <button type="button" class="sk-ba-arrow sk-ba-arrow--next" aria-label="Neste" data-visible="false"></button>
    </div>

    {% assign testimonials_count = product.metafields.custom.before_after_testimonial_product.value | size -%}
    {%- if testimonials_count > 0 %}
      <div class="sk-ba-progress" role="status" aria-live="polite">
        <div class="sk-ba-progress__dots" role="tablist" aria-label="Testimonials progress">
          {% for item in product.metafields.custom.before_after_testimonial_product.value %}
            <button
              type="button"
              role="tab"
              class="sk-ba-progress__dot{% if forloop.first %} sk-ba-progress__dot--active{% endif %}"
              data-index="{{ forloop.index0 }}"
              aria-label="Vis eksempel {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            ></button>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  {%- comment -%} Scroll-snap carousel — no Swiper dependency {%- endcomment -%}
  (function () {
    var root = document.querySelector('.sk-before-after[data-section-id="{{ section.id }}"]');
    if (!root) return;
    var track = root.querySelector('.sk-ba-track');
    var slides = root.querySelectorAll('.sk-ba-slide');
    var prevBtn = root.querySelector('.sk-ba-arrow--prev');
    var nextBtn = root.querySelector('.sk-ba-arrow--next');
    var dots = root.querySelectorAll('.sk-ba-progress__dot');
    if (!track || !slides.length) return;

    var activeIndex = 0;
    function setActive(idx) {
      if (idx === activeIndex && idx !== 0) return;
      activeIndex = idx;
      dots.forEach(function (d, i) {
        var on = i === idx;
        d.classList.toggle('sk-ba-progress__dot--active', on);
        on ? d.setAttribute('aria-current', 'true') : d.removeAttribute('aria-current');
      });
      updateArrows();
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting && e.intersectionRatio > 0.5)
          setActive(Array.prototype.indexOf.call(slides, e.target));
      });
    }, { root: track, threshold: 0.5 });
    slides.forEach(function (s) { io.observe(s); });

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.dataset.visible = track.scrollLeft > 2 ? 'true' : 'false';
      nextBtn.dataset.visible =
        track.scrollLeft + track.clientWidth < track.scrollWidth - 2 ? 'true' : 'false';
    }
    var arrowTicking = false;
    track.addEventListener('scroll', function () {
      if (!arrowTicking) {
        arrowTicking = true;
        requestAnimationFrame(function () { updateArrows(); arrowTicking = false; });
      }
    }, { passive: true });

    /* Cache slide width — updated via ResizeObserver to avoid per-click reflow */
    var cachedSlideW = slides[0] ? slides[0].offsetWidth + 20 : 0;
    if (window.ResizeObserver && slides[0]) {
      new ResizeObserver(function (entries) {
        cachedSlideW = entries[0].contentRect.width + 20;
      }).observe(slides[0]);
    }
    function step(dir) {
      track.scrollBy({ left: dir * cachedSlideW, behavior: 'smooth' });
    }
    if (prevBtn) prevBtn.addEventListener('click', function () { step(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { step(1); });

    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        var i = parseInt(d.dataset.index, 10);
        if (slides[i]) slides[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      });
    });
    requestAnimationFrame(updateArrows);
  })();
</script>

{% schema %}
{
  "name": "SK Before/After Product",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Real results"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Subtitle",
      "default": "See the amazing transformations our customers have achieved"
    }
  ],
  "presets": [
    {
      "name": "SK Before/After Product"
    }
  ]
}
{% endschema %}
