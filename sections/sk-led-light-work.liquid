<style>
  /* === SECTION WRAPPER === */
  .sk-wavelengths {
    --sk-spacing-unit: 4px;
    --sk-title-block-height: calc(var(--sk-spacing-unit) * 22);

    /* Map section colors to existing theme tokens (no hex). */
    --sk-color-brand: rgb(var(--color-foreground));
    --sk-color-neutral: rgba(var(--color-foreground), 0.6);
    --sk-color-neutral-dark: rgba(var(--color-foreground), 0.75);
    --sk-color-border: rgba(var(--color-foreground), 0.12);
    --sk-color-body: rgb(var(--color-foreground));
    --sk-color-tag-text: rgb(var(--color-background));

    padding: clamp(calc(var(--sk-spacing-unit) * 6), 4vw, calc(var(--sk-spacing-unit) * 8)) 0;
    background: rgb(var(--color-background));
  }

  /* Section-only overflow guard. */
  #sk-wavelengths-{{ section.id }} {
    overflow-x: clip !important;
  }

  @supports not (overflow: clip) {
    #sk-wavelengths-{{ section.id }} {
      overflow-x: hidden !important;
    }
  }

  /* === DESKTOP GRID === */
  .sk-wavelengths__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(calc(var(--sk-spacing-unit) * 10), 6vw, calc(var(--sk-spacing-unit) * 12));
    max-width: calc(var(--sk-spacing-unit) * 450);
    margin: calc(var(--sk-spacing-unit) * 6) auto 0;
    padding: 0 calc(var(--sk-spacing-unit) * 6);
    align-items: start;
  }

  .sk-wavelengths__slider {
    display: none;
    margin-top: calc(var(--sk-spacing-unit) * 3);
    position: relative;
    padding: 0 clamp(calc(var(--sk-spacing-unit) * 4), 4vw, calc(var(--sk-spacing-unit) * 6));
  }

  .sk-wavelengths__empty {
    text-align: center;
    color: var(--sk-color-neutral);
    font-size: 14px;
    margin-top: calc(var(--sk-spacing-unit) * 4);
  }

  /* === CARD WRAPPER === */
  .sk-wavelength {
    background: rgb(var(--color-background));
    border-radius: calc(var(--sk-spacing-unit) * 2);
    padding: calc(var(--sk-spacing-unit) * 8);
    border: none;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: none;
    position: relative;
    overflow: visible;
    margin-top: calc(var(--sk-spacing-unit) * 2);
  }

  .sk-wavelength--has-tag {
    margin-top: calc(var(--sk-spacing-unit) * 6);
  }

  /* === IMAGE WRAPPER === */
  .sk-wavelength__visual {
    width: 100%;
    max-width: calc(var(--sk-spacing-unit) * 138);
    margin: 0 auto calc(var(--sk-spacing-unit) * 4);
    aspect-ratio: 1 / 0.75;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sk-wavelength__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: calc(var(--sk-spacing-unit) * 2) !important;
  }

  .sk-tag {
    position: absolute;
    top: calc(var(--sk-spacing-unit) * -4);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    padding: calc(var(--sk-spacing-unit) * 2) calc(var(--sk-spacing-unit) * 5);
    color: var(--sk-color-tag-text);
    background: var(--sk-color-brand);
    border-radius: 999px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    isolation: isolate;
  }

  .sk-tag::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(var(--color-background), 0.7) 45%,
      transparent 90%
    );
    transform: translateX(-150%);
    pointer-events: none;
    z-index: -1;
    opacity: 0;
  }

  .sk-tag.sk-tag--shimmer::after {
    animation: sk-tag-shimmer 1.4s ease-out forwards;
    opacity: 1;
  }

  @keyframes sk-tag-shimmer {
    0% {
      transform: translateX(-150%);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    60% {
      transform: translateX(150%);
      opacity: 1;
    }
    100% {
      transform: translateX(150%);
      opacity: 0;
    }
  }

  .sk-wavelength__eyebrow {
    margin: 0;
    color: rgba(var(--color-foreground), 0.65);
    font-weight: var(--font-body-weight-medium);
  }

  .sk-wavelength__header {
    min-height: var(--sk-title-block-height);
    max-height: var(--sk-title-block-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: calc(var(--sk-spacing-unit) * 2);
    margin-bottom: calc(var(--sk-spacing-unit) * 6);
    overflow: hidden;
  }

  /* === TITLES === */
  .sk-wavelength__title {
    font-family: var(--font-body-family);
    font-size: 22px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    color: var(--sk-color-brand);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* === BENEFITS LIST === */
  .sk-wavelength__benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
    width: 100%;
    max-width: calc(var(--sk-spacing-unit) * 125);
  }

  .sk-wavelength__benefits li {
    font-family: var(--font-body-family);
    font-size: 16px;
    margin-bottom: calc(var(--sk-spacing-unit) * 2);
    display: grid;
    grid-template-columns: calc(var(--sk-spacing-unit) * 3) 1fr;
    column-gap: calc(var(--sk-spacing-unit) * 2);
    align-items: center;
    line-height: 1.6;
    color: rgba(var(--sk-color-body-text), .9);
    font-weight: 300;
  }

  .sk-wavelength__benefits li::before {
    content: '';
    width: calc(var(--sk-spacing-unit) * 2);
    height: calc(var(--sk-spacing-unit) * 2);
    border-radius: 50%;
    background: var(--sk-color-brand);
    margin-top: 0;
  }

  /* Scroll-snap track (mobile carousel). */
  .sk-llw-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
    padding: calc(var(--sk-spacing-unit) * 7) 0 calc(var(--sk-spacing-unit) * 6);
  }
  .sk-llw-track::-webkit-scrollbar { display: none; }
  .sk-llw-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  .sk-llw-dots {
    position: static;
    margin: calc(var(--sk-spacing-unit) * 1) auto 0;
    width: auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: calc(var(--sk-spacing-unit) * 2);
  }

  .sk-llw-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    padding: 0;
    cursor: pointer;
    margin: 0;
    background: var(--sk-color-brand);
    opacity: 0.25;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .sk-llw-dot--active {
    opacity: 1;
    transform: scale(1.25);
  }

  .sk-wavelengths__arrow {
    position: absolute;
    top: 50%;
    width: calc(var(--sk-spacing-unit) * 9);
    height: calc(var(--sk-spacing-unit) * 9);
    border: none;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    color: rgba(var(--color-foreground), 0.35);
    font-size: 26px;
    line-height: 1;
    transform: translateY(-50%);
    transition: color 0.2s ease, opacity 0.2s ease;
    pointer-events: auto;
    text-shadow: 0 3px 10px rgba(var(--color-shadow), 0.18);
    padding: calc(var(--sk-spacing-unit) * 2);
  }

  .sk-wavelengths__arrow--prev {
    left: calc(var(--sk-spacing-unit) * 3);
  }

  .sk-wavelengths__arrow--next {
    right: calc(var(--sk-spacing-unit) * 3);
  }

  .sk-wavelengths__arrow:hover {
    color: rgba(var(--color-foreground), 0.6);
  }

  .sk-wavelengths__arrow[data-visible="false"] {
    opacity: 0;
    pointer-events: none;
  }

  .sk-wavelengths__arrow-icon {
    width: calc(var(--sk-spacing-unit) * 4);
    height: calc(var(--sk-spacing-unit) * 4);
    border: 1.5px solid currentColor;
    border-bottom: none;
    border-left: none;
    display: inline-block;
    filter: drop-shadow(0 1px 2px rgba(var(--color-shadow), 0.15));
  }

  .sk-wavelengths__arrow--prev .sk-wavelengths__arrow-icon {
    transform: rotate(225deg);
  }

  .sk-wavelengths__arrow--next .sk-wavelengths__arrow-icon {
    transform: rotate(45deg);
  }



  /* === MOBILE SLIDER === */
  @media (max-width: 750px) {
    .sk-wavelengths__grid {
      display: none;
    }

    .sk-wavelengths__slider {
      display: block;
      margin-top: calc(var(--sk-spacing-unit) * -3);

      /* Full-bleed implementation moved to wrapper (no horizontal scroll). */
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      overflow-x: clip;
      padding-left: calc(var(--sk-spacing-unit) * 6);
      padding-right: calc(var(--sk-spacing-unit) * 6);
    }

    @supports not (overflow: clip) {
      .sk-wavelengths__slider {
        overflow-x: hidden;
      }
    }

    .sk-wavelengths {
      --sk-title-block-height: calc(var(--sk-spacing-unit) * 20);
    }

    .sk-wavelength {
      padding: calc(var(--sk-spacing-unit) * 5) calc(var(--sk-spacing-unit) * 3);
      margin-top: calc(var(--sk-spacing-unit) * -2);
    }

    .sk-wavelength--has-tag {
      margin-top: calc(var(--sk-spacing-unit) * 1);
    }

    .sk-wavelengths__arrow {
      width: auto;
      height: auto;
      padding: calc(var(--sk-spacing-unit) * 4);
      box-shadow: none;
    }

    .sk-wavelength__visual {
      max-width: calc(var(--sk-spacing-unit) * 120);
      width: 100%;
      margin: 0 0 calc(var(--sk-spacing-unit) * 4);
    }

    .sk-wavelength__title {
      font-size: 20px;
    }

    .sk-wavelength__benefits li {
      font-family: var(--font-body-family);
      font-size: 16px;
      line-height: 1.6;
      color: rgba(var(--sk-color-body-text), .9);
      font-weight: 300;
    }
  }
</style>

<section id="sk-wavelengths-{{ section.id }}" class="sk-wavelengths section--full-bleed sk-body-text--strong">
  <div class="page-width">
    {% assign sk_header_has_content = false %}
    {% if section.settings.sk_led_light_work_eyebrow != blank %}
      {% assign sk_header_has_content = true %}
    {% endif %}
    {% if section.settings.sk_led_light_work_heading != blank %}
      {% assign sk_header_has_content = true %}
    {% endif %}
    {% if section.settings.sk_led_light_work_subheading != blank %}
      {% assign sk_header_has_content = true %}
    {% endif %}

    {% if sk_header_has_content %}
      <div class="sk-section-header sk-section-header--center">
        {% if section.settings.sk_led_light_work_eyebrow != blank %}
          <p class="sk-section-header__eyebrow sk-copy-eyebrow">{{ section.settings.sk_led_light_work_eyebrow }}</p>
        {% endif %}

        {% if section.settings.sk_led_light_work_heading != blank %}
          <h2 class="sk-section-header__title sk-heading-size--large sk-heading-text--strong">
            {{ section.settings.sk_led_light_work_heading }}
          </h2>
        {% endif %}

        {% if section.settings.sk_led_light_work_subheading != blank %}
          <p class="sk-section-header__subtitle sk-heading-text--soft">
            {{ section.settings.sk_led_light_work_subheading }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign sk_metafield_handle = 'product.metafields.custom["led_light_work_cards"]'
    %}

    {% if product.metafields.custom.led_light_work_cards.value != blank %}
      {% assign sk_cards = product.metafields.custom.led_light_work_cards.value %}
      <!-- DESKTOP GRID -->
      <div class="sk-wavelengths__grid">
        {% for card in sk_cards %}
          {% liquid
            assign card_image = card.image.value | default: card.image
            assign card_eyebrow = card.eyebrow.value | default: card.eyebrow
            assign card_title = card.title.value | default: card.title
            assign title_parts = card_title | split: '|'
            assign card_primary_title = ''
            assign card_secondary_title = ''
            if title_parts.size > 1
              assign card_primary_title = title_parts[0] | strip
              assign card_secondary_title = title_parts[1] | strip
            else
              assign card_secondary_title = card_title | strip
            endif
            assign card_benefits = card.benefits.value | default: card.benefits
            assign card_highlight_tag = card.highlight_tag_text.value | default: card.highlight_tag_text
            assign card_show_highlight = card.show_highlight_text.value | default: card.show_highlight_text
          %}
          <div class="sk-wavelength{% if card_show_highlight %} sk-wavelength--has-tag{% endif %}">
            {% if card_show_highlight %}
              <span class="sk-tag">
                {{ card_highlight_tag | default: 'NY DYPTVIRKENDE BØLGELENGDE' }}
              </span>
            {% endif %}

            {% if card_image %}
              <div class="sk-wavelength__visual">
                <img
                  src="{{ card_image | image_url: width: 1000 }}"
                  alt="{{ card_title | default: 'Skinora LED lys' | escape }}"
                  loading="lazy"
                  width="{{ card_image.width | default: 1000 }}"
                  height="{{ card_image.height | default: 750 }}"
                >
              </div>
            {% endif %}

            {% if card_eyebrow != blank or card_primary_title != blank or card_secondary_title != blank %}
              <div class="sk-wavelength__header">
                {% if card_eyebrow != blank %}
                  <p class="sk-wavelength__eyebrow sk-copy-eyebrow">{{ card_eyebrow }}</p>
                {% endif %}

                {% if card_primary_title != blank or card_secondary_title != blank %}
                  <h3 class="sk-wavelength__title">
                    {% if card_primary_title != blank %}
                      {{ card_primary_title }}
                    {% endif %}
                    {% if card_primary_title != blank and card_secondary_title != blank %}
                      |
                    {% endif %}
                    {% if card_secondary_title != blank %}
                      <em>{{ card_secondary_title }}</em>
                    {% endif %}
                  </h3>
                {% endif %}
              </div>
            {% endif %}

            {% if card_benefits != blank %}
              <ul class="sk-wavelength__benefits">
                {% assign items = card_benefits | newline_to_br | split: '<br />' %}
                {% for item in items %}
                  {% assign line = item | strip %}
                  {% if line != blank %}
                    <li>{{ line }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <!-- MOBILE SCROLL-SNAP SLIDER -->
      <div class="sk-wavelengths__slider">
        <div class="sk-llw-track">
          {% for card in product.metafields.custom.led_light_work_cards.value %}
            {% liquid
              assign card_image = card.image.value | default: card.image
              assign card_eyebrow = card.eyebrow.value | default: card.eyebrow
              assign card_title = card.title.value | default: card.title
              assign title_parts = card_title | split: '|'
              assign card_primary_title = ''
              assign card_secondary_title = ''
              if title_parts.size > 1
                assign card_primary_title = title_parts[0] | strip
                assign card_secondary_title = title_parts[1] | strip
              else
                assign card_secondary_title = card_title | strip
              endif
              assign card_benefits = card.benefits.value | default: card.benefits
              assign card_highlight_tag = card.highlight_tag_text.value | default: card.highlight_tag_text
              assign card_show_highlight = card.show_highlight_text.value | default: card.show_highlight_text
            %}
            <div class="sk-llw-slide">
              <div class="sk-wavelength{% if card_show_highlight %} sk-wavelength--has-tag{% endif %}">
                {% if card_show_highlight %}
                  <span class="sk-tag">
                    {{ card_highlight_tag | default: 'NY DYPTVIRKENDE BØLGELENGDE' }}
                  </span>
                {% endif %}

                {% if card_image %}
                  <div class="sk-wavelength__visual">
                    <img
                      src="{{ card_image | image_url: width: 800 }}"
                      alt="{{ card_title | default: 'Skinora LED lys' | escape }}"
                      loading="lazy"
                      width="{{ card_image.width | default: 800 }}"
                      height="{{ card_image.height | default: 600 }}"
                    >
                  </div>
                {% endif %}

                {% if card_eyebrow != blank or card_primary_title != blank or card_secondary_title != blank %}
                  <div class="sk-wavelength__header">
                    {% if card_eyebrow != blank %}
                      <p class="sk-wavelength__eyebrow sk-copy-eyebrow">{{ card_eyebrow }}</p>
                    {% endif %}

                    {% if card_primary_title != blank or card_secondary_title != blank %}
                      <h3 class="sk-wavelength__title">
                        {% if card_primary_title != blank %}
                          {{ card_primary_title }}
                        {% endif %}
                        {% if card_primary_title != blank and card_secondary_title != blank %}
                          |
                        {% endif %}
                        {% if card_secondary_title != blank %}
                          <em>{{ card_secondary_title }}</em>
                        {% endif %}
                      </h3>
                    {% endif %}
                  </div>
                {% endif %}

                {% if card_benefits != blank %}
                  <ul class="sk-wavelength__benefits">
                    {% assign items = card_benefits | newline_to_br | split: '<br />' %}
                    {% for item in items %}
                      {% assign line = item | strip %}
                      {% if line != blank %}
                        <li>{{ line }}</li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="sk-llw-dots">
          {% for card in product.metafields.custom.led_light_work_cards.value %}
            <button
              type="button"
              class="sk-llw-dot{% if forloop.first %} sk-llw-dot--active{% endif %}"
              data-index="{{ forloop.index0 }}"
              aria-label="Vis kort {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
        <button
          type="button"
          class="sk-wavelengths__arrow sk-wavelengths__arrow--prev"
          aria-label="Forrige lysbilde"
          data-visible="false"
        >
          <span class="sk-wavelengths__arrow-icon" aria-hidden="true"></span>
        </button>
        <button
          type="button"
          class="sk-wavelengths__arrow sk-wavelengths__arrow--next"
          aria-label="Neste lysbilde"
          data-visible="true"
        >
          <span class="sk-wavelengths__arrow-icon" aria-hidden="true"></span>
        </button>
      </div>
    {% else %}
      {% if request.design_mode %}
        <p class="sk-wavelengths__empty">
          Ingen data funnet. Legg til metaobjekter på <code>{{ sk_metafield_handle }}</code> for å fylle ut kortene.
        </p>
      {% endif %}
    {% endif %}
  </div>
</section>

<script>
  var skShimmerObserver = null;

  function skTriggerShimmer(tag) {
    if (!tag) return;
    tag.classList.remove('sk-tag--shimmer');
    // Force reflow to restart animation
    void tag.offsetWidth;
    tag.classList.add('sk-tag--shimmer');
    window.setTimeout(function () {
      tag.classList.remove('sk-tag--shimmer');
    }, 1600);
  }

  function skTriggerAllShimmers(scope) {
    var root = scope || document;
    var selector = root === document ? '.sk-wavelengths .sk-tag' : '.sk-tag';
    root.querySelectorAll(selector).forEach(skTriggerShimmer);
  }

  function skInitShimmerObserver(scopeEl) {
    var root = scopeEl || document;

    if (!('IntersectionObserver' in window)) {
      skTriggerAllShimmers(root);
      return null;
    }

    if (skShimmerObserver) {
      skShimmerObserver.disconnect();
      skShimmerObserver = null;
    }

    skShimmerObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.querySelectorAll('.sk-tag').forEach(skTriggerShimmer);
          }
        });
      },
      {
        threshold: [0, 0.45],
        rootMargin: '0px 0px -10% 0px',
      }
    );

    root.querySelectorAll('.sk-wavelength').forEach(function (card) {
      skShimmerObserver.observe(card);
    });

    return skShimmerObserver;
  }

  document.addEventListener('DOMContentLoaded', function () {
    var sectionEl = document.getElementById('sk-wavelengths-{{ section.id }}');
    if (!sectionEl) {
      skTriggerAllShimmers();
      return;
    }

    skInitShimmerObserver(sectionEl);

    /* --- Mobile scroll-snap carousel --- */
    var track = sectionEl.querySelector('.sk-llw-track');
    var slides = sectionEl.querySelectorAll('.sk-llw-slide');
    var dots = sectionEl.querySelectorAll('.sk-llw-dot');
    var prevBtn = sectionEl.querySelector('.sk-wavelengths__arrow--prev');
    var nextBtn = sectionEl.querySelector('.sk-wavelengths__arrow--next');
    if (!track || !slides.length) {
      skTriggerAllShimmers(sectionEl);
      return;
    }

    var activeIndex = 0;

    function setActive(idx) {
      if (idx === activeIndex && idx !== 0) return;
      activeIndex = idx;
      dots.forEach(function (d, i) {
        d.classList.toggle('sk-llw-dot--active', i === idx);
      });
      /* Shimmer on active slide */
      if (slides[idx]) {
        slides[idx].querySelectorAll('.sk-tag').forEach(skTriggerShimmer);
      }
      updateArrows();
    }

    /* Track active slide via IntersectionObserver */
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting && e.intersectionRatio > 0.5) {
            setActive(Array.prototype.indexOf.call(slides, e.target));
          }
        });
      },
      { root: track, threshold: 0.5 }
    );
    slides.forEach(function (s) {
      io.observe(s);
    });

    function updateArrows() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.dataset.visible = track.scrollLeft > 2 ? 'true' : 'false';
      nextBtn.dataset.visible = track.scrollLeft + track.clientWidth < track.scrollWidth - 2 ? 'true' : 'false';
    }
    track.addEventListener('scroll', updateArrows, { passive: true });

    function step(dir) {
      var w = slides[0].offsetWidth + 20;
      track.scrollBy({ left: dir * w, behavior: 'smooth' });
    }
    if (prevBtn)
      prevBtn.addEventListener('click', function () {
        step(-1);
      });
    if (nextBtn)
      nextBtn.addEventListener('click', function () {
        step(1);
      });

    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        var i = parseInt(d.dataset.index, 10);
        if (slides[i]) slides[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      });
    });

    updateArrows();
    skTriggerAllShimmers(sectionEl);
  });
</script>

{% schema %}
{
  "name": "SK Led Light Work",
  "settings": [
    {
      "type": "text",
      "id": "sk_led_light_work_eyebrow",
      "label": "Eyebrow label",
      "default": "VITENSKAPEN BAK SKINORA LED"
    },
