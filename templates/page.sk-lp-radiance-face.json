    "faq": {
      "type": "sk-lp-faq",
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "Hvor ofte bør jeg bruke masken?",
            "answer": "Vi anbefaler 3–5 økter i uken, à 10 minutter. Du kan bruke den morgen eller kveld – det som passer best for deg."
          }
        },
        "faq_xgRBbg": {
          "type": "faq",
          "settings": {
            "question": "Hvem bør starte litt forsiktig?",
            "answer": "Hvis du bruker lysømfintlige medisiner, har lysallergi, eller har en hudtilstand som blir lett irritert, anbefaler vi å starte med kortere økter og følge med på huden. Ved epilepsi eller kjent reaksjon på lys, rådfør deg med lege før bruk. Hvis du nylig har gjort laser/peeling/microneedling, vent til huden har roet seg."
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Når kan jeg forvente å se resultater?",
            "answer": "De fleste merker forbedring i glød og hudtone etter 2–4 uker. For mer synlige resultater som jevnere tekstur og reduserte pigmentflekker, anbefaler vi minst 6–8 uker med jevnlig bruk."
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "Er LED-lys trygt for huden?",
            "answer": "Ja. LED-terapi er en ikke-invasiv teknologi som er grundig testet og brukes av hudterapeuter verden over. Den inneholder ingen UV-stråler og er skånsom mot alle hudtyper."
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "Kan jeg bruke den sammen med hudpleieproduktene mine?",
            "answer": "Absolutt. Bruk masken på ren hud, og påfør serum eller fuktighetskrem etterpå for å forsterke effekten. Unngå produkter med retinol rett før bruk."
          }
        },
        "faq_5": {
          "type": "faq",
          "settings": {
            "question": "Hva om jeg ikke er fornøyd?",
            "answer": "Du har 60 dagers fornøydgaranti. Hvis du ikke er fornøyd, sender du den tilbake og får full refusjon – ingen spørsmål stilt. Kontakt oss på hello@skinora.no."
          }
        },
        "faq_6": {
          "type": "faq",
          "settings": {
            "question": "Hvor lang er leveringstiden?",
            "answer": "Vi sender fra norsk lager, og leveringstiden er normalt 2–4 virkedager. Frakt er alltid gratis."
          }
        },
        "faq_freq": {
          "type": "faq",
          "settings": {
            "question": "Hvor ofte må jeg bruke den for at det skal være verdt det?",
            "answer": "Vi anbefaler 3–5 ganger i uken, 10 minutter per økt. Det tilsvarer én sesong med favorittserien din i uken. Mange merker de første resultatene etter 2–4 uker med jevn bruk. Og fordi du betaler én gang og bruker den ubegrenset, blir prisen per behandling lavere jo mer du bruker den."
          }
        },
        "faq_noresult": {
          "type": "faq",
          "settings": {
            "question": "Hva om jeg ikke ser noen forskjell?",
            "answer": "Da vil vi at du skal sende den tilbake – og du får pengene tilbake, uten spørsmål. Det er hele poenget med vår 60 dagers fornøydgaranti. Vi er trygge på at jevn bruk gir resultater, men vi vet at hud er individuell. Har du ikke sett endring innen 60 dager, kontakter du oss på hello@skinora.no – og vi ordner resten."
          }
        },
        "faq_price": {
          "type": "faq",
          "settings": {
            "question": "Er 4.690 kr mye å betale for en LED-maske?",
            "answer": "Sammenlignet med klinikk er det faktisk det motsatte. Én LED-behandling hos hudterapeut koster typisk 800–1.500 kr. Med Skinora® Radiance Face betaler du én gang og kan bruke masken ubegrenset hjemme. Etter bare 3–6 behandlinger har produktet betalt seg selv – resten er ren gevinst. Du kan også dele opp betalingen med Klarna fra 130 kr/mnd."
          }
        }
      },
