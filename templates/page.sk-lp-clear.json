    "reviews": {
      "type": "sk-lp-reviews",
      "blocks": {
        "review_wxnFyr": {
          "type": "review",
          "settings": {
            "text": "Jeg har aldri hatt akne, men de siste to årene har pannen min vært dekket av små røde kuler som bare ikke ville forsvinne. Tror det startet med mye trening i hjelm og stress fra studiene. Jeg prøvde alt – salicylsyre, retinol, dyre serum, hudterapeut – og fikk det ned i korte perioder, men aldri borte. Etter åtte uker med Skinora® Clear, 4 kvelder i uken, er pannen min nesten helt rolig. Jeg slipper å sjekke speilet hver morgen for å se hva som dukket opp i løpet av natten. Det er en lettelse jeg ikke visste jeg trengte.",
            "author": "Linnea S., 26, Stavanger",
            "concern_tag": "PANNE & T-SONE",
            "usage_tag": "",
            "before_image": "shopify://shop_images/panne_tsone_kviser_for.png",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/etter_bruk_ren_hud.png",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        },
        "review_ktegL7": {
          "type": "review",
          "settings": {
            "text": "Etter to runder med Roaccutan var aknen borte, men huden var rød, ujevn og lett irritabel. Jeg hadde gitt opp å finne noe som faktisk roet det ned uten å være aggressivt. Skinora® Clear er det første jeg har brukt der jeg ser forskjell uten å bli tørr eller flassete. Etter seks uker er rødheten merkbart mindre, og de få nye utbruddene jeg får, går vekk etter et par dager i stedet for å verke i ukevis. Stille, men virker.",
            "author": "Sondre B., 29, Oslo",
            "concern_tag": "Voksenakne, post-akne-arr og rødhet",
            "usage_tag": "",
            "before_image": "shopify://shop_images/kundebildet_for.png",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/kundebilde_etter.png",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        },
        "review_CC7jeb": {
          "type": "review",
          "settings": {
            "text": "Jeg har slitt med smertefulle kuler langs kjeven og haken siden jeg var 24 — alltid verst rett før mensen, alltid på samme sted. Har prøvd antibiotika, p-piller, retinol, klinikkbehandlinger. Noe hjalp en stund, så kom det tilbake. Etter åtte uker med Skinora® Clear, 4 ganger i uken, er det stille på huden min. Jeg våkner ikke til en ny verkende kul. Det høres så enkelt ut, men det har endret hverdagen min.",
            "author": "Marte H., 34, Trondheim",
            "concern_tag": "Hormonell akne på hake og kjeve",
            "usage_tag": "",
            "before_image": "shopify://shop_images/for.png",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/etter.png",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        },
        "rev_1": {
          "type": "review",
          "settings": {
            "text": "Hver eneste måned, en uke før mensen, kom de samme betente kvisene langs kjeven og haken. Jeg avlyste dater, droppet trening og la et tykt lag foundation før jeg gikk ut for å hente posten. Etter 5 uker med Skinora er utbruddene færre, mindre røde, og de gror på dager i stedet for uker. I går gikk jeg på jobb uten sminke. Bare det er verdt hver krone.",
            "author": "Ida L., 28, Bergen",
            "concern_tag": "Rødhet & utbrudd · 10 min, 5x/uke",
            "usage_tag": "",
            "before_image": "shopify://shop_images/hormonell_akne_kundebilde_for.png",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/hormonell_akne_kundebilde_etter.png",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        },
        "rev_2": {
          "type": "review",
          "settings": {
            "text": "To runder med antibiotika, retinol som svidde, syrer som gjorde huden tynn og rød – jeg hadde brukt over 30 000 kr på huden min uten å bli bedre. Skinora var ærlig talt et siste forsøk før jeg booket ny time hos hudlege. Etter 6 uker er huden roligere enn den har vært siden 20-årene. Jeg ser meg selv i speilet uten å lete etter feil for første gang på årevis.",
            "author": "Emilie K., 34, Oslo",
            "concern_tag": "Tørr, uren hud · 10 min, 4x/uke",
            "usage_tag": "",
            "before_image": "shopify://shop_images/acneutsatthud_bildet_for.png",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/kundebildet_etter.jpg",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        },
        "rev_3": {
          "type": "review",
          "settings": {
            "text": "Pannen og nesen min har alltid vært full av små underhudskviser man knapt ser på bilder – men som lyser opp i sterk belysning og kjennes med en gang noen kommer nært. Jeg snudde meg vekk for kyss, unngikk selfies forfra, og hatet kontorlysene på jobb. Etter 4 uker er huden så mye jevnere at sminken legger seg flatt, og kjæresten min faktisk spurte hva jeg hadde gjort før jeg rakk å si det selv.",
            "author": "Nora T., 25, Drammen",
            "concern_tag": "T-sone, nærkontakt-skam · 10 min, 3x/uke",
            "usage_tag": "",
            "before_image": "shopify://shop_images/kunde_for_bildet.webp",
            "before_alt": "Før behandling med Skinora Clear",
            "after_image": "shopify://shop_images/kundebildet_etter.webp",
            "after_alt": "Etter 8 uker med Skinora Clear",
            "before_label": "Før",
            "after_label": "Etter"
          }
        }
      },
      "block_order": [
        "review_wxnFyr",
